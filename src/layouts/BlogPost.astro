---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import { Comment, MediumZoom } from 'astro-pure/advanced'
import { TOC } from 'astro-pure/components/pages'
import { findTranslatedEntry, getLocalizedContentHref, getAllBlogEntries } from '@/content-utils'
import ArticleBottom from '@/components/blog/ArticleBottom.astro'
import Copyright from '@/components/blog/Copyright.astro'
import Hero from '@/components/blog/Hero.astro'
import { LOCALES, getCurrentLocale, type Locale } from '@/i18n'
import PageLayout from '@/layouts/ContentLayout.astro'
import { getIntegrationConfig } from '@/site-config'

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post,
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props
const { id, data } = post

const {
  description,
  heroImage,
  publishDate,
  title,
  updatedDate,
  draft: isDraft,
  comment: enableComment
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : '/images/social-card.png'
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--un-text-opacity))'
const locale = getCurrentLocale(Astro.url.pathname, Astro.currentLocale)
const integ = getIntegrationConfig(locale)
const allPosts = await getAllBlogEntries()

const localeAlternates = Object.fromEntries(
  LOCALES.map((targetLocale) => {
    const translated = findTranslatedEntry(allPosts, post, targetLocale as Locale)
    return [
      targetLocale,
      translated ? getLocalizedContentHref('blog', translated, targetLocale as Locale) : `/${targetLocale}/blog`
    ]
  })
) as Partial<Record<Locale, string>>
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back='/blog'
  {localeAlternates}
>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <Hero {data} {remarkPluginFrontmatter} slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <Copyright {data} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    {/* Comment */}
    {!isDraft && enableComment && <Comment class='mt-3 sm:mt-6' />}
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}
