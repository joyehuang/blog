---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/BaseLayout.astro'
import { Icon } from 'astro-pure/user'

export const prerender = true

const allCurated = (await getCollection('curated'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const typeIcons: Record<string, string> = {
  paper: '📄',
  blog: '📝',
  article: '📰',
  report: '📋'
}
---

<PageLayout meta={{ title: 'Curated' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-3'>
      <h1 class='mt-8 text-3xl font-bold'>Curated</h1>
      <p class='text-sm text-muted-foreground'>
        收集好的技术博客、论文、repo — 已经读过了，整理好了，可以直接用
      </p>
    </section>

    <div class='animate flex w-full flex-col gap-y-4 md:w-4/5 lg:w-5/6'>
      <ul class='flex flex-col gap-y-3'>
        {
          allCurated.map((item) => {
            const linkHref = item.data.relatedArchive?.length
              ? `/archive/${item.data.relatedArchive[0]}`
              : item.data.source

            return (
              <li class='flex flex-col rounded-2xl border bg-background px-5 py-4 transition-colors hover:bg-muted'>
                <div class='flex items-center gap-2 text-xs text-muted-foreground mb-1.5'>
                  <span class='rounded-md border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider'>
                    {typeIcons[item.data.type] || '📋'} {item.data.type}
                  </span>
                  <span>{item.data.sourceAuthor || item.data.sourceTitle || item.data.source.replace(/https?:\/\//, '').split('/')[0]}</span>
                </div>
                <div class='flex items-start justify-between gap-4'>
                  <div class='min-w-0 flex-1'>
                    <a
                      href={linkHref}
                      target={item.data.relatedArchive?.length ? '_self' : '_blank'}
                      class='font-medium hover:text-primary transition-colors'
                    >
                      {item.data.title}
                    </a>
                    <p class='mt-1 text-sm text-muted-foreground line-clamp-2'>
                      {item.data.description}
                    </p>
                  </div>
                  <a
                    href={item.data.source}
                    target='_blank'
                    class='shrink-0 text-muted-foreground hover:text-primary transition-colors mt-1'
                    title='查看原文'
                  >
                    <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'/><polyline points='15 3 21 3 21 9'/><line x1='10' y1='14' x2='21' y2='3'/></svg>
                  </a>
                </div>
                {
                  item.data.relatedArchive?.length && (
                    <div class='mt-2 text-xs text-muted-foreground'>
                      <a
                        href={`/archive/${item.data.relatedArchive[0]}`}
                        class='hover:text-primary transition-colors'
                      >
                        → 阅读笔记
                      </a>
                    </div>
                  )
                }
              </li>
            )
          })
        }

        {
          allCurated.length === 0 && (
            <p class='text-center text-sm text-muted-foreground py-12'>
              还没有收录内容
            </p>
          )
        }
      </ul>
    </div>
  </main>
</PageLayout>
