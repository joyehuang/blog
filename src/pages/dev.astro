---
export const prerender = true

import { getBlogCollection, sortMDByDate } from 'astro-pure/server'

import DevModeRoute from '@/components/terminal/DevModeRoute'
import type { PostSummary } from '@/components/terminal/types'

import '@/assets/styles/app.css'

const all = await getBlogCollection()
const recent = sortMDByDate(all).slice(0, 8)

const posts: PostSummary[] = recent.map((p) => {
  const fm = p.data as Record<string, unknown>
  const date = (fm.publishDate ?? fm.date) as Date | string | undefined
  const formatted =
    date instanceof Date
      ? date.toISOString().slice(0, 10)
      : typeof date === 'string'
        ? date.slice(0, 10)
        : ''
  const slug = p.id
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
  return {
    slug,
    href: `/blog/${encodeURI(p.id)}`,
    title: (fm.title as string) ?? p.id,
    date: formatted,
    description: fm.description as string | undefined
  }
})
---

<!doctype html>
<html lang='zh-CN'>
  <head>
    <meta charset='utf-8' />
    <meta content='width=device-width, initial-scale=1.0' name='viewport' />
    <title>Dev Mode · Joye</title>
    <link rel='icon' type='image/png' sizes='32x32' href='/favicon/favicon-32x32.png' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap'
    />
    <link rel='stylesheet' href='/styles/global.css' />
    <script is:inline>
      // mirror ThemeProvider.astro: 'system' or missing → follow prefers-color-scheme
      ;(() => {
        let stored = null
        try {
          stored = localStorage.getItem('theme')
        } catch {
          /* ignore */
        }
        const resolved =
          !stored || stored === 'system'
            ? matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light'
            : stored
        document.documentElement.classList.toggle('dark', resolved === 'dark')
      })()
    </script>
  </head>
  <body>
    <DevModeRoute client:load posts={posts} />
  </body>
</html>
