---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import RoadmapColumn from '@/components/site/RoadmapColumn.astro'
import { roadmap } from '@/data/roadmap'
import type { RoadmapStatus } from '@/data/roadmap'
import { useTranslations } from '@/i18n/ui'

export const prerender = true

const lang = 'zh' as const
const t = useTranslations(lang)

const horizons: RoadmapStatus[] = ['now', 'next', 'later', 'done']
const grouped = horizons.map((status) => ({
  status,
  items: roadmap.filter((item) => item.status === status)
}))
---

<PageLayout meta={{ title: 'Roadmap', description: t('roadmap.subtitle') }}>
  <Button title='Back' href='/about' style='back' />
  <header class='mb-8 mt-4'>
    <h1 class='text-2xl font-medium sm:text-3xl'>{t('roadmap.title')}</h1>
    <p class='mt-2 max-w-2xl leading-relaxed text-muted-foreground'>
      {t('roadmap.subtitle')}
    </p>
  </header>

  <div class='flex flex-col gap-8'>
    {grouped.map(({ status, items }) => (
      <RoadmapColumn status={status} items={items} lang={lang} />
    ))}
  </div>
</PageLayout>
