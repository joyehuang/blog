---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]

let siteStats: { totalViews: number; pages: number } | null = null
try {
  const res = await fetch('https://waline.joyehuang.me/api/stats', {
    signal: AbortSignal.timeout(3000)
  })
  if (res.ok) siteStats = await res.json()
} catch {}
---

<PageLayout title='About' {headings} info='/about'>
  <p>Developer</p>
  <p>
    I'm a second-year undergraduate at the University of Melbourne. Outside of coding I spend time
    on music, scale models, and photography (a new hobby!). Currently focused on frontend, with the
    goal of becoming a full-stack developer — and an open-source contributor. My taste for music
    started with piano and cello, which my parents pushed me into.
  </p>
  <p>
    My motto: Build fast, learn faster. <Spoiler></Spoiler>
  </p>
  <Button title='Sponsor Me' class='w-fit' href='/en/projects#sponsorship' style='ahead' />

  {
    siteStats && (
      <p class='mt-6 text-sm text-muted-foreground'>
        <strong class='text-foreground'>{siteStats.totalViews.toLocaleString()}</strong> total post
        reads across {siteStats.pages} {siteStats.pages === 1 ? 'post' : 'posts'} so far.
      </p>
    )
  }

  {/* hobbies */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>
      <strong>Music</strong> — Learned piano and cello growing up. Though it started as parental
      pressure, music has become something I can't imagine life without. I'll occasionally play
      a few favorite pieces to unwind.
    </li>
    <li>
      <strong>Model Building</strong> — I enjoy assembling all kinds of models. The process from
      zero to finished piece trains both my hands and my patience.
    </li>
    <li>
      <strong>Photography</strong> — A new hobby! I use the camera to capture small moments and
      explore different perspectives and lighting.
    </li>
    <li>
      <strong>Open Source</strong> — Working toward becoming an active open-source contributor,
      learning and growing through code and community.
    </li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>Here are the tools and technologies I use daily:</p>
  <ToolSection
    class='mb-5'
    title='AI & Code Assistants'
    tools={[
      {
        name: 'ChatGPT',
        description: 'AI Assistant',
        href: 'https://chat.openai.com/',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      },
      {
        name: 'Claude Code',
        description: 'AI Coding Assistant',
        href: 'https://claude.ai/',
        icon: import('@/assets/tools/claude.svg?raw')
      },
      {
        name: 'GitHub Copilot',
        description: 'AI Code Completion',
        href: 'https://github.com/features/copilot',
        icon: import('@/assets/tools/github.svg?raw')
      },
      {
        name: 'v0 by Vercel',
        description: 'AI UI Generator',
        href: 'https://v0.dev/',
        icon: import('@/assets/tools/v0.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Design'
    tools={[
      {
        name: 'Figma',
        description: 'UI/UX Design',
        href: 'https://www.figma.com/',
        icon: import('@/assets/tools/figma.svg?raw')
      },
      {
        name: 'Canva',
        description: 'Graphic Design',
        href: 'https://www.canva.com/',
        icon: import('@/assets/tools/canva.svg?raw')
      },
      {
        name: 'Claude Code',
        description: 'Agentic Design Partner',
        href: 'https://claude.ai/',
        icon: import('@/assets/tools/claude.svg?raw')
      },
      {
        name: 'Pencil',
        description: 'AI-Native Design Editor',
        href: 'https://www.pencil.dev/'
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'Cursor',
        description: 'AI-Powered IDE',
        href: 'https://cursor.sh/',
        icon: import('@/assets/tools/cursor.svg?raw')
      },
      {
        name: 'VS Code',
        description: 'Code Editor',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Git',
        description: 'Version Control',
        href: 'https://git-scm.com/',
        icon: import('@/assets/tools/git.svg?raw')
      },
      {
        name: 'Postman',
        description: 'API Testing',
        href: 'https://www.postman.com/',
        icon: import('@/assets/tools/postman.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Obsidian',
        description: 'Knowledge Base',
        href: 'https://obsidian.md/',
        icon: import('@/assets/tools/obsidian.svg?raw')
      },
      {
        name: 'Notion',
        description: 'Project Management',
        href: 'https://www.notion.so/',
