---
import links from 'public/links.json'
import config from 'virtual:config'

import { Comment } from 'astro-pure/advanced'
import { Collapse, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import FriendList from '@/components/links/FriendList.astro'
import FriendConstellation from '@/components/links/FriendConstellation.astro'
import FriendPostcards from '@/components/links/FriendPostcards.astro'
import FriendLogbook from '@/components/links/FriendLogbook.astro'
import FriendStickers from '@/components/links/FriendStickers.astro'

const headings = [
  { depth: 2, slug: 'friend-links', text: 'Friend Links' },
  { depth: 2, slug: 'apply-links', text: 'Apply Links' }
]

const { friends } = links
const linksConf = config.integ.links

const allApplyText = linksConf.applyTip.map(({ name, val }) => `${name}: ${val}`).join('\n')
const copyAllScript = `navigator.clipboard.writeText(${JSON.stringify(allApplyText)});document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied all info to clipboard'}}))`
---

<PageLayout title='Links' {headings} info='/links'>
  <h2 id='friend-links'>Friend Links</h2>
  <p>Personal sites of friends I've exchanged links with. Pick a way to look at them —</p>

  <div class='friend-views' data-friend-views>
    <div class='friend-views-tabs' role='tablist' aria-label='Friend list view'>
      <button type='button' role='tab' data-view='constellation' class='view-tab is-active'>Constellation</button>
      <button type='button' role='tab' data-view='postcard' class='view-tab'>Postcard</button>
      <button type='button' role='tab' data-view='logbook' class='view-tab'>Logbook</button>
      <button type='button' role='tab' data-view='stickers' class='view-tab'>Stickers</button>
    </div>
    <div class='view-panel is-active' data-view='constellation'>
      <FriendConstellation list={friends[0]} meLabel='joyehuang.me' />
    </div>
    <div class='view-panel' data-view='postcard'>
      <FriendPostcards list={friends[0]} />
    </div>
    <div class='view-panel' data-view='logbook'>
      <FriendLogbook list={friends[0]} />
    </div>
    <div class='view-panel' data-view='stickers'>
      <FriendStickers list={friends[0]} />
    </div>
  </div>

  <script is:inline>
    ;(() => {
      const root = document.querySelector('[data-friend-views]')
      if (!root) return
      const tabs = root.querySelectorAll('.view-tab')
      const panels = root.querySelectorAll('.view-panel')
      const KEY = 'friend-view'
      const apply = (view) => {
        tabs.forEach((t) => t.classList.toggle('is-active', t.dataset.view === view))
        panels.forEach((p) => p.classList.toggle('is-active', p.dataset.view === view))
      }
      const saved = localStorage.getItem(KEY)
      if (saved && root.querySelector(`.view-tab[data-view="${saved}"]`)) apply(saved)
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const view = tab.dataset.view
          apply(view)
          localStorage.setItem(KEY, view)
        })
      })
    })()
  </script>

  <style>
    .friend-views {
      margin: 1rem 0 1.5rem;
    }
    .friend-views-tabs {
      display: inline-flex;
      gap: 0.25rem;
      padding: 0.25rem;
      margin-bottom: 1rem;
      border-radius: 0.5rem;
      border: 1px solid hsl(var(--border));
      background: hsl(var(--muted) / 0.4);
    }
    .view-tab {
      padding: 0.35rem 0.85rem;
      border-radius: 0.35rem;
      border: none;
      background: transparent;
      color: hsl(var(--muted-foreground));
      font-size: 0.85rem;
      cursor: pointer;
      transition:
        background 160ms ease,
        color 160ms ease;
      font-family: inherit;
    }
    .view-tab:hover {
      color: hsl(var(--foreground));
    }
    .view-tab.is-active {
      background: hsl(var(--background));
      color: hsl(var(--foreground));
      box-shadow: 0 1px 2px hsl(var(--background) / 0.5);
    }
    .view-panel {
      display: none;
    }
    .view-panel.is-active {
      display: block;
    }
  </style>
  <Collapse title='Links with Bad Status'>
    <FriendList list={friends[1]} />
  </Collapse>
  <Collapse title='Link History Book'>
    <Timeline events={linksConf.logbook} />
  </Collapse>

  {/*
  <h2 id='special-links'>Special Links</h2>
  <FriendList list={friends[2]} />
  */}

  <h2 id='apply-links'>Apply Links</h2>
  <p>
    Site info (click a row to copy, or
    <button
      type='button'
      class='cursor-pointer underline underline-offset-4'
      onclick={copyAllScript}
    >
      copy all
    </button>):
  </p>
  <blockquote class='not-prose grid grid-cols-[auto_1fr] gap-x-2 break-words border-s-4 ps-4'>
    {
      linksConf.applyTip.map(({ name, val }) => {
        const script = `navigator.clipboard.writeText('${val}');document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied "${val}" to clipboard!'}}))`
        return (
          <>
            <span class='text-end'>{name}:</span>
            <samp class='cursor-pointer' onclick={script}>
              {val}
            </samp>
          </>
        )
      })
    }
  </blockquote>

  <p>
    When applying, please follow this template in a comment (<a
      href='https://github.com/joyehuang/blog/pulls'
      target='_blank'>opening a PR</a
    > may be faster). A few notes on the application:
  </p>
  <ul>
    <li>You've added this site to your own friend links.</li>
    <li>Make sure your site is alive.</li>
    <li>Blog content complies with local laws.</li>
  </ul>
  <Comment slot='bottom' />
</PageLayout>
