---
import { getCollection } from 'astro:content'
import { sortCuratedEntries } from '@/lib/curated'

import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import CuratedLibrary from '@/components/curated/CuratedLibrary.astro'
import TranslationNotice from '@/components/TranslationNotice.astro'

export const prerender = true

const allCurated = sortCuratedEntries(
  (await getCollection('curated')).filter((entry) => !entry.data.draft)
)
---

<PageLayout
  meta={{
    title: 'Curated',
    description: 'A filtered library of technical blogs, papers, reports, and repos.'
  }}
  highlightColor='#659EB9'
>
  <TranslationNotice lang='en' />
  <Button title='Back' href='/en' style='back' />
  <CuratedLibrary items={allCurated} lang='en' />
</PageLayout>
