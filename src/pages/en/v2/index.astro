---
import { getCollection } from 'astro:content'

import PageLayout from '@/layouts/BaseLayout.astro'
import ImmersiveHome from '@/components/home/ImmersiveHome.astro'

export const prerender = true

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-AU', { year: 'numeric', month: 'short', day: '2-digit' }).format(date)

const posts = (await getCollection('blogEn'))
  .filter((post) => (import.meta.env.PROD ? !post.data.draft : true) && post.data.translationKey)
  .sort(
    (a, b) =>
      +(b.data.updatedDate ?? b.data.publishDate) - +(a.data.updatedDate ?? a.data.publishDate)
  )
  .slice(0, 5)
  .map((post) => ({
    title: post.data.title,
    href: `/en/blog/${post.data.translationKey}`,
    meta: formatDate(post.data.updatedDate ?? post.data.publishDate),
    kind: 'Essay'
  }))

const notes = (await getCollection('notesEn'))
  .filter((note) => !note.data.draft && note.data.translationKey)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)
  .map((note) => ({
    title: note.data.title,
    href: `/en/notes/${note.data.translationKey}`,
    meta: formatDate(note.data.updatedDate ?? note.data.date),
    kind: note.data.type
  }))

const repoDefinitions = [
  {
    name: 'Learn-Open-Harness',
    fullName: 'joyehuang/Learn-Open-Harness',
    href: 'https://github.com/joyehuang/Learn-Open-Harness',
    eyebrow: 'Original project · Agent Harness',
    description:
      'Build an agent harness from first principles: loops, tools, memory, and multi-agent work.',
    fallbackStars: 297
  },
  {
    name: 'minimind-notes',
    fullName: 'joyehuang/minimind-notes',
    href: 'https://github.com/joyehuang/minimind-notes',
    eyebrow: 'Original project · LLM from scratch',
    description:
      'Rebuild a small language model from Transformer through SFT, one experiment at a time.',
    fallbackStars: 93
  },
  {
    name: 'Token Monitor',
    fullName: 'Javis603/token-monitor',
    href: 'https://github.com/Javis603/token-monitor',
    eyebrow: 'Upstream contributor · 3 merged / 1 open',
    description:
      'Contributed activity heatmaps, fresh provider sync, accurate reset windows, and compact token totals.',
    image: '/images/open-source/token-monitor-dashboard.png',
    imageAlt: 'Token Monitor usage dashboard with activity, model, and tool breakdowns',
    fallbackStars: 628
  }
]

const repos = await Promise.all(
  repoDefinitions.map(async (repo) => {
    try {
      const response = await fetch(`https://api.github.com/repos/${repo.fullName}`, {
        headers: { Accept: 'application/vnd.github+json' }
      })
      if (!response.ok) return { ...repo, stars: repo.fallbackStars }
      const data = (await response.json()) as { stargazers_count?: number }
      return { ...repo, stars: data.stargazers_count ?? repo.fallbackStars }
    } catch {
      return { ...repo, stars: repo.fallbackStars }
    }
  })
)
---

<PageLayout
  meta={{
    title: 'Joye — AI Agent Product Engineer · V2',
    description:
      'AI agent product engineer working across multi-agent research, image creation, and video editing.'
  }}
  chrome={false}
>
  <ImmersiveHome locale='en' {posts} {notes} {repos} />
</PageLayout>
