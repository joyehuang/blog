---
/**
 * Archive Module - /archive (singular)
 * This is a knowledge base for ideas, snippets, and semi-finished materials.
 * Note: This is different from /archives (plural) which shows blog posts grouped by year.
 */
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { getCollection } from 'astro:content'
import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArchives = await getCollection('archive')
  const sortedArchives = allArchives
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

  return paginate(sortedArchives, {
    pageSize: 20
  })
}

interface Props {
  page: Page<CollectionEntry<'archive'>>
}

const { page } = Astro.props as unknown as Props

const allArchives = (await getCollection('archive')).filter((entry) => !entry.data.draft)
const uniqueTags = [...new Set(allArchives.flatMap((entry) => entry.data.tags))].sort()
const uniqueStatuses = [...new Set(allArchives.map((entry) => entry.data.status))].sort()

const statusCounts = allArchives.reduce(
  (acc, entry) => {
    acc[entry.data.status] = (acc[entry.data.status] || 0) + 1
    return acc
  },
  {} as Record<string, number>
)

const meta = {
  description: 'Agent 学习、工程化选型对比、面试题笔记——未成稿，但都是一手思考',
  title: page.currentPage === 1 ? 'Notes' : `Notes - Page ${page.currentPage}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: '← 上一页',
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: '下一页 →',
      url: page.url.next
    }
  })
}

const typeLabels: Record<string, string> = {
  note: '笔记',
  snippet: '片段',
  draft: '草稿',
  idea: '想法',
  research: '研究',
  reference: '参考'
}

const statusLabels: Record<string, string> = {
  'in-progress': '进行中',
  incomplete: '未完成',
  ready: '已整理',
  archived: '已归档'
}

const statusColors: Record<string, string> = {
  'in-progress': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
  incomplete: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300',
  ready: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300',
  archived: 'bg-gray-100 text-gray-600 dark:bg-gray-800/30 dark:text-gray-400'
}

const statusDotColors: Record<string, string> = {
  'in-progress': 'bg-yellow-500',
  incomplete: 'bg-red-500',
  ready: 'bg-green-500',
  archived: 'bg-gray-400'
}

const typeColors: Record<string, string> = {
  note: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  snippet: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  draft: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
  idea: 'bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-300',
  research: 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-300',
  reference: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-3 flex items-center gap-3'>
        <div class='rounded-lg bg-muted/50 p-3'>
          <span class='text-2xl'>📒</span>
        </div>
        <div>
          <h1 class='text-3xl font-medium'>Notes</h1>
          <p class='text-sm text-muted-foreground'>一手笔记 · 持续生长中</p>
        </div>
      </div>
      <p class='max-w-3xl text-muted-foreground'>
        这里是我平时沉淀的一手笔记：Agent 学习、工程化选型对比（Embedding、向量库、AI SDK 等）、面试里遇到的好题目。
        还没打磨成博客，但都是最新的思考——比成稿博客更接近"现在在想什么"。
      </p>
    </div>

    {
      page.data.length === 0 ? (
        <p class='mt-8'>No archive entries yet.</p>
      ) : (
        <div class='mt-10 grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section id='content' class='animate' aria-label='Archive entries'>
            <div class='mb-3 flex flex-col justify-between text-sm text-muted-foreground sm:mb-5 sm:flex-row'>
              <span>
                显示第 {page.start + 1}-{page.end + 1} 条，共 {page.total} 条
              </span>
              {page.lastPage > 1 && (
                <span>
                  第 {page.currentPage} / {page.lastPage} 页
                </span>
              )}
            </div>

            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((entry) => (
                <li>
                  <a
                    href={`/archive/${entry.id}`}
                    class='group block rounded-xl border border-border bg-card px-5 py-5 transition hover:border-foreground/20 hover:shadow-sm'
                    data-astro-prefetch
                  >
                    <div class='flex items-start justify-between gap-4'>
                      <div class='min-w-0 flex-1 space-y-2'>
                        <h3 class='text-lg font-medium leading-tight group-hover:text-foreground'>
                          {entry.data.title}
                        </h3>
                        {entry.data.description && (
                          <p class='text-sm leading-6 text-muted-foreground'>
                            {entry.data.description}
                          </p>
                        )}

                        <div class='flex flex-wrap items-center gap-x-2 gap-y-2 text-xs text-muted-foreground'>
                          <span
                            class={`rounded-md px-2 py-0.5 font-medium ${typeColors[entry.data.type]}`}
                          >
                            {typeLabels[entry.data.type] || entry.data.type}
                          </span>
                          <span>·</span>
                          <time datetime={entry.data.date.toISOString()}>
                            {entry.data.date.toLocaleDateString('zh-CN', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric'
                            })}
                          </time>
                          {entry.data.updatedDate && (
                            <span>
                              · 更新于{' '}
                              {entry.data.updatedDate.toLocaleDateString('zh-CN', {
                                month: 'short',
                                day: 'numeric'
                              })}
                            </span>
                          )}
                          {entry.data.tags.length > 0 && (
                            <>
                              <span>·</span>
                              <div class='flex flex-wrap gap-1.5'>
                                {entry.data.tags.map((tag: string) => (
                                  <span class='rounded-md bg-muted px-2 py-0.5'>{tag}</span>
                                ))}
                              </div>
                            </>
                          )}
                        </div>
                      </div>

                      <span
                        class={`mt-0.5 shrink-0 rounded-md px-2 py-1 text-xs font-medium ${statusColors[entry.data.status]}`}
                      >
                        {statusLabels[entry.data.status]}
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>

            {page.lastPage > 1 && (
              <div class='mt-8'>
                <Paginator {...paginationProps} />
              </div>
            )}
          </section>

          <aside class='animate' id='sidebar'>
            {!!uniqueTags.length && (
              <section class='mb-8'>
                <div class='mb-4 flex items-center justify-between'>
                  <h2 class='flex items-center text-lg font-semibold'>
                    <Icon name='tag-2' class='me-2' />
                    Tags
                  </h2>
                  <a href='/archive/tags' class='text-xs text-muted-foreground hover:text-foreground'>
                    查看全部 →
                  </a>
                </div>
                <ul class='flex flex-wrap gap-2'>
                  {uniqueTags.map((tag) => (
                    <li>
                      <a
                        href={`/archive/tags/${tag}`}
                        class='inline-flex rounded-md border border-border px-2 py-1 text-xs transition hover:border-foreground/20'
                      >
                        {tag}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )}

            <section>
              <h2 class='mb-4 flex items-center text-lg font-semibold'>
                <Icon name='list' class='me-2' />
                Status
              </h2>
              <ul class='space-y-2 text-sm'>
                {uniqueStatuses.map((status) => (
                  <li class='flex items-center justify-between gap-3'>
                    <span class='flex items-center gap-2'>
                      <span
                        class={`inline-block size-2 rounded-full ${statusDotColors[status] || 'bg-gray-400'}`}
                      />
                      <span class='text-foreground'>{statusLabels[status] || status}</span>
                    </span>
                    <span class='text-xs text-muted-foreground'>{statusCounts[status] || 0}</span>
                  </li>
                ))}
              </ul>
            </section>
          </aside>
        </div>
      )
    }
  </main>
</PageLayout>
