---
/**
 * Archive Module - /archive (singular)
 * This is a knowledge base for ideas, snippets, and semi-finished materials.
 * Note: This is different from /archives (plural) which shows blog posts grouped by year.
 */
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { getCollection } from 'astro:content'
import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArchives = await getCollection('archive')
  const sortedArchives = allArchives
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

  return paginate(sortedArchives, {
    pageSize: 20
  })
}

interface Props {
  page: Page<CollectionEntry<'archive'>>
}

const { page } = Astro.props as unknown as Props

const allArchives = (await getCollection('archive')).filter((entry) => !entry.data.draft)
const uniqueTags = [...new Set(allArchives.flatMap((entry) => entry.data.tags))].sort()
const uniqueTypes = [...new Set(allArchives.map((entry) => entry.data.type))].sort()
const uniqueStatuses = [...new Set(allArchives.map((entry) => entry.data.status))].sort()

const typeCounts = allArchives.reduce(
  (acc, entry) => {
    acc[entry.data.type] = (acc[entry.data.type] || 0) + 1
    return acc
  },
  {} as Record<string, number>
)

const meta = {
  description: '知识库与工作笔记',
  title: page.currentPage === 1 ? 'Archive' : `Archive - Page ${page.currentPage}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: '← 上一页',
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: '下一页 →',
      url: page.url.next
    }
  })
}

const typeLabels: Record<string, string> = {
  note: '📝 笔记',
  snippet: '💡 片段',
  draft: '✏️ 草稿',
  idea: '🔮 想法',
  research: '🔬 研究',
  reference: '📚 参考'
}

const statusLabels: Record<string, string> = {
  'in-progress': '🚧 进行中',
  incomplete: '⏸️ 未完成',
  ready: '✅ 已整理',
  archived: '📦 已归档'
}

const statusColors: Record<string, string> = {
  'in-progress': 'text-blue-600 dark:text-blue-400',
  incomplete: 'text-yellow-600 dark:text-yellow-400',
  ready: 'text-green-600 dark:text-green-400',
  archived: 'text-gray-500 dark:text-gray-400'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-4 flex items-center gap-3'>
        <div class='rounded-lg bg-muted/50 p-3'>
          <span class='text-2xl'>🗂️</span>
        </div>
        <div class='space-y-1'>
          <h1 class='text-3xl font-medium'>Archive</h1>
          <p class='text-sm text-muted-foreground'>知识库与工作笔记</p>
        </div>
      </div>
      <p class='max-w-3xl text-muted-foreground'>
        这里放的是研究笔记、代码片段和一些尚未打磨成正式文章的内容。更像一个持续生长的工作台，而不是已经完成的博客成品区。
      </p>
    </div>

    {
      page.data.length === 0 ? (
        <p class='mt-8'>No archive entries yet.</p>
      ) : (
        <div class='mt-10 grid gap-y-10 sm:grid-cols-[minmax(0,3fr)_280px] sm:gap-x-10'>
          <section id='content' class='animate' aria-label='Archive entries'>
            <div class='mb-5 flex items-center justify-between text-sm text-muted-foreground'>
              <span>
                显示第 {page.start + 1}-{page.end + 1} 条，共 {page.total} 条
              </span>
              {page.lastPage > 1 && (
                <span>
                  第 {page.currentPage} / {page.lastPage} 页
                </span>
              )}
            </div>

            <ul class='space-y-4'>
              {page.data.map((entry) => (
                <li>
                  <a
                    href={`/archive/${entry.id}`}
                    class='group block rounded-xl border border-border bg-card px-5 py-5 transition hover:border-foreground/20 hover:shadow-sm'
                    data-astro-prefetch
                  >
                    <div class='flex items-start gap-4'>
                      <div class='mt-1 shrink-0 text-xl opacity-80 group-hover:opacity-100'>
                        {entry.data.type === 'note' && '📝'}
                        {entry.data.type === 'snippet' && '💡'}
                        {entry.data.type === 'draft' && '✏️'}
                        {entry.data.type === 'idea' && '🔮'}
                        {entry.data.type === 'research' && '🔬'}
                        {entry.data.type === 'reference' && '📚'}
                      </div>

                      <div class='min-w-0 flex-1'>
                        <div class='flex items-start justify-between gap-4'>
                          <div class='space-y-2'>
                            <h3 class='text-lg font-medium leading-tight group-hover:text-foreground'>
                              {entry.data.title}
                            </h3>
                            {entry.data.description && (
                              <p class='text-sm leading-6 text-muted-foreground'>
                                {entry.data.description}
                              </p>
                            )}
                          </div>
                          <span
                            class={`mt-0.5 shrink-0 text-xs ${statusColors[entry.data.status]}`}
                            title={statusLabels[entry.data.status]}
                          >
                            {entry.data.status === 'in-progress' && '🚧'}
                            {entry.data.status === 'incomplete' && '⏸️'}
                            {entry.data.status === 'ready' && '✅'}
                            {entry.data.status === 'archived' && '📦'}
                          </span>
                        </div>

                        <div class='mt-4 flex flex-wrap items-center gap-x-2 gap-y-2 text-xs text-muted-foreground'>
                          <time datetime={entry.data.date.toISOString()}>
                            {entry.data.date.toLocaleDateString('zh-CN', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric'
                            })}
                          </time>
                          {entry.data.updatedDate && (
                            <span>
                              · 更新于{' '}
                              {entry.data.updatedDate.toLocaleDateString('zh-CN', {
                                month: 'short',
                                day: 'numeric'
                              })}
                            </span>
                          )}
                          {entry.data.tags.length > 0 && (
                            <>
                              <span>·</span>
                              <div class='flex flex-wrap gap-1.5'>
                                {entry.data.tags.map((tag: string) => (
                                  <span class='rounded-md bg-muted px-2 py-1'>{tag}</span>
                                ))}
                              </div>
                            </>
                          )}
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>

            {page.lastPage > 1 && (
              <div class='mt-10'>
                <Paginator {...paginationProps} />
              </div>
            )}
          </section>

          <aside class='animate space-y-8' id='sidebar'>
            {!!uniqueTags.length && (
              <section class='rounded-xl border border-border bg-card p-5'>
                <div class='mb-4 flex items-center justify-between'>
                  <h2 class='flex items-center text-lg font-semibold'>
                    <Icon name='tag-2' class='me-2' />
                    Tags
                  </h2>
                  <a href='/archive/tags' class='text-xs text-muted-foreground hover:text-foreground'>
                    查看全部 →
                  </a>
                </div>
                <ul class='flex flex-wrap gap-2 text-xs'>
                  {uniqueTags.slice(0, 15).map((tag) => (
                    <li>
                      <a
                        href={`/archive/tags/${tag}`}
                        class='rounded-md border border-border bg-background px-2.5 py-1.5 transition hover:border-foreground/20'
                      >
                        {tag}
                      </a>
                    </li>
                  ))}
                  {uniqueTags.length > 15 && (
                    <li>
                      <a
                        href='/archive/tags'
                        class='rounded-md border border-dashed border-border bg-background px-2.5 py-1.5 text-muted-foreground hover:text-foreground'
                      >
                        +{uniqueTags.length - 15}
                      </a>
                    </li>
                  )}
                </ul>
              </section>
            )}

            <section class='rounded-xl border border-border bg-card p-5'>
              <h2 class='mb-4 text-lg font-semibold'>Status</h2>
              <ul class='space-y-3 text-sm'>
                {uniqueStatuses.map((status) => (
                  <li class='flex items-center justify-between gap-3'>
                    <span class={statusColors[status]}>{statusLabels[status] || status}</span>
                    <span class='text-xs text-muted-foreground'>
                      {allArchives.filter((entry) => entry.data.status === status).length}
                    </span>
                  </li>
                ))}
              </ul>
            </section>

            <section class='rounded-xl border border-border bg-card p-5'>
              <h2 class='mb-4 text-lg font-semibold'>Types</h2>
              <ul class='space-y-3 text-sm'>
                {uniqueTypes.map((type) => (
                  <li class='flex items-center justify-between gap-3'>
                    <span>{typeLabels[type] || type}</span>
                    <span class='text-xs text-muted-foreground'>({typeCounts[type] || 0})</span>
                  </li>
                ))}
              </ul>
            </section>
          </aside>
        </div>
      )
    }
  </main>
</PageLayout>
