---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import { getLocalizedBlogEntries } from '@/content-utils'
import PostPreview from '@/components/blog/PostPreview.astro'
import { LOCALES, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'
import { getLocaleFromParam } from '@/i18n'
import config from '@/site-config'
import { getSortedTags, getTagLabel } from '@/tags'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const staticPaths = []

  for (const locale of LOCALES) {
    const collections = await getLocalizedBlogEntries(locale)
    const uniqueTags = getSortedTags(collections, locale)
    const collectionsCount = collections.length

    staticPaths.push(
      ...paginate(collections, {
        pageSize: config.content.blogPageSize,
        params: { locale },
        props: { uniqueTags, collectionsCount, locale }
      })
    )
  }

  return staticPaths
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  collectionsCount: number
  locale: (typeof LOCALES)[number]
}

const { page, uniqueTags, collectionsCount } = Astro.props as Props
const locale = getLocaleFromParam(Astro.params.locale)
const copy =
  locale === 'zh'
    ? {
        title: '博客',
        description: '博客中的文章列表',
        back: '返回',
        empty: '还没有文章。',
        pageSummary: `第 ${page.currentPage} 页，当前显示 ${page.data.length} / ${collectionsCount} 篇`,
        previous: '← 上一页',
        next: '下一页 →',
        viewByYear: '按年份查看所有文章 →',
        tags: '标签',
        viewAll: '查看全部 →'
      }
    : {
        title: 'Blog',
        description: 'Some posts or archives of my blog',
        back: 'Back',
        empty: 'No posts yet.',
        pageSummary: `Page ${page.currentPage} - Showing ${page.data.length} of ${collectionsCount} posts`,
        previous: '← Previous Posts',
        next: 'Next Posts →',
        viewByYear: 'View all posts by years →',
        tags: 'Tags',
        viewAll: 'View all →'
      }

const meta = {
  description: copy.description,
  title: copy.title
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: copy.previous,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: copy.next,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title={copy.back} href={getLocalizedHref(Astro.url.pathname, '/', locale)} style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>{copy.title}</h1>
    </div>
    {
      page.data.length === 0 ? (
        <p>{copy.empty}</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='Blog posts list' class='animate' id='content'>
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>{copy.pageSummary}</span>
              <a
                aria-label={copy.viewByYear}
                href={getLocalizedHref(Astro.url.pathname, '/archives', locale)}
                data-astro-prefetch
              >
                {copy.viewByYear}
              </a>
            </div>
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} detailed />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-semibold'>
                <Icon name='tag-2' class='me-2' />
                {copy.tags}
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {uniqueTags.map((tag) => (
                  <li>
                    <Button
                      title={getTagLabel(tag, locale)}
                      href={getLocalizedHref(Astro.url.pathname, `/tags/${tag}`, locale)}
                      style='pill'
                    >
                      {getTagLabel(tag, locale)}
                    </Button>
                  </li>
                ))}
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a
                  aria-label={copy.viewAll}
                  href={getLocalizedHref(Astro.url.pathname, '/tags', locale)}
                  data-astro-prefetch
                >
                  {copy.viewAll}
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
