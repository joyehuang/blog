---
import { Button } from 'astro-pure/user'
import { getBlogCollection, groupCollectionsByYear, sortMDByDate } from 'astro-pure/server'
import PostPreview from '@/components/blog/PostPreview.astro'
import { getLocaleFromParam, getLocaleStaticPaths, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true
export const getStaticPaths = getLocaleStaticPaths

const locale = getLocaleFromParam(Astro.params.locale)
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts)
const allPostsByYear = groupCollectionsByYear(allPostsByDate)

const copy =
  locale === 'zh'
    ? {
        title: '归档',
        description: '按年份查看全部博客文章',
        empty: '还没有文章。',
        postsLabel: (count: number) => `${count} 篇文章`
      }
    : {
        title: 'Archives',
        description: 'A list of all the years of creating my posts',
        empty: 'No posts yet.',
        postsLabel: (count: number) => `${count} post${count > 1 ? 's' : ''}`
      }

const meta = {
  description: copy.description,
  title: copy.title
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/blog', locale)} style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>{copy.title}</h1>
    </div>

    {allPosts.length === 0 && <p>{copy.empty}</p>}

    <section id='content' class='animate' aria-label='Blog post list'>
      {
        allPostsByYear.map(([year, posts]) => (
          <div class='relative mt-20'>
            <h2
              class='absolute -start-6 -top-16 z-0 text-9xl font-bold text-transparent opacity-10'
              style='-webkit-text-stroke-width:2px;-webkit-text-stroke-color:hsl(var(--foreground)/var(--un-text-opacity))'
            >
              <samp>{year}</samp>
            </h2>
            <p class='px-5 text-muted-foreground'>{copy.postsLabel(posts.length)}</p>
            <ul class='flex flex-col text-start'>
              {posts.map((p) => (
                <PostPreview post={p} class='border-0 bg-transparent py-2' />
              ))}
            </ul>
          </div>
        ))
      }
    </section>
  </main>
</PageLayout>
