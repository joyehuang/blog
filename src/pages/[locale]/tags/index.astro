---
import { Button } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import { getUniqueTagsWithCount } from 'astro-pure/server'
import { getLocalizedBlogEntries } from '@/content-utils'
import { getLocaleFromParam, getLocaleStaticPaths, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true
export const getStaticPaths = getLocaleStaticPaths

const locale = getLocaleFromParam(Astro.params.locale)
const allPosts = await getLocalizedBlogEntries(locale)
const allTags = getUniqueTagsWithCount(allPosts)

const copy =
  locale === 'zh'
    ? {
        title: '标签',
        description: '博客中的所有标签',
        empty: '还没有标签。'
      }
    : {
        title: 'Tags',
        description: "A list of all the topics I've written about in my posts",
        empty: 'No tags yet.'
      }

const meta = {
  description: copy.description,
  title: copy.title
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/blog', locale)} style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>{copy.title}</h1>
    </div>

    <div id='content' class='animate'>
      {
        allTags.length > 0 ? (
          <ul class='flex flex-wrap gap-4'>
            {allTags.map(([tag, val]) => (
              <li>
                <Button
                  href={getLocalizedHref(Astro.url.pathname, `/tags/${tag}`, locale)}
                  style='pill'
                  class={cn(
                    'items-start gap-x-1',
                    val > 2 ? 'rounded-xl px-3 py-1 text-xl' : val > 1 && 'text-lg'
                  )}
                >
                  {tag}
                  <span class={val > 2 ? 'text-base' : 'text-xs'}>{val}</span>
                </Button>
              </li>
            ))}
          </ul>
        ) : (
          <p>{copy.empty}</p>
        )
      }
    </div>
  </main>
</PageLayout>
