---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import { getLocalizedBlogEntries } from '@/content-utils'
import PostPreview from '@/components/blog/PostPreview.astro'
import { LOCALES, getLocaleFromParam, getLocalePath, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'
import { getSortedTags, getTagAliases, getTagLabel } from '@/tags'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const staticPaths = []

  for (const locale of LOCALES) {
    const allPosts = await getLocalizedBlogEntries(locale)
    const uniqueTags = getSortedTags(allPosts, locale)

    staticPaths.push(
      ...uniqueTags.flatMap((tag) => {
        const filterPosts = allPosts.filter((post) => post.data.tags.includes(tag))
        const pages = paginate(filterPosts, {
          pageSize: config.content.blogPageSize,
          params: { locale, tag },
          props: {
            canonicalTag: tag,
            redirectTo: null
          }
        })

        const aliasPaths = getTagAliases(tag)
          .filter((alias) => alias !== tag)
          .flatMap((alias) =>
            Array.from({ length: pages.length }, (_, index) => ({
              params:
                index === 0
                  ? { locale, tag: alias }
                  : { locale, tag: alias, page: String(index + 1) },
              props: {
                redirectTo:
                  index === 0
                    ? getLocalePath(locale, `/tags/${tag}`)
                    : getLocalePath(locale, `/tags/${tag}/${index + 1}`)
              }
            }))
          )

        return [...pages, ...aliasPaths]
      })
    )
  }

  return staticPaths
}

interface Props {
  page?: Page<CollectionEntry<'blog'>>
  canonicalTag?: string
  redirectTo?: string | null
}

const { page, canonicalTag, redirectTo } = Astro.props as Props
const locale = getLocaleFromParam(Astro.params.locale)
const tag = String(canonicalTag ?? Astro.params.tag ?? '')
const tagLabel = getTagLabel(tag, locale)

if (redirectTo) {
  return Astro.redirect(redirectTo, 308)
}

const copy =
  locale === 'zh'
    ? {
        title: '标签',
        previous: '← 上一页',
        next: '下一页 →'
      }
    : {
        title: 'Tags',
        previous: '← Previous Tags',
        next: 'Next Tags →'
      }

const meta = {
  description:
    locale === 'zh'
      ? `查看标签 ${tagLabel} 下的全部文章`
      : `View all posts with the tag - ${tagLabel}`,
  title: `${copy.title}: ${tagLabel}`
}

const paginationProps = {
  ...(page?.url.prev && {
    prevUrl: {
      text: copy.previous,
      url: page.url.prev
    }
  }),
  ...(page?.url.next && {
    nextUrl: {
      text: copy.next,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/blog', locale)} style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 flex items-end gap-x-2 text-3xl font-medium'>
        {copy.title}:
        <span class='text-2xl'>#{tagLabel}</span>
      </h1>
    </div>

    <section id='content' class='animate' aria-label='Blog post list'>
      <ul class='flex flex-col gap-y-3 text-start'>
        {page?.data.map((post) => <PostPreview as='h2' {post} detailed />)}
      </ul>
      <Paginator {...paginationProps} />
    </section>
  </main>
</PageLayout>
