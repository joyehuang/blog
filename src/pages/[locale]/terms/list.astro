---
import { Button, CardList } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import { getLocaleFromParam, getLocaleStaticPaths, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'
import { getIntegrationConfig, getTerms } from '@/site-config'

export const prerender = true
export const getStaticPaths = getLocaleStaticPaths

const locale = getLocaleFromParam(Astro.params.locale)
const integ = getIntegrationConfig(locale)
const terms = getTerms(locale)
const localizedTerms = {
  ...terms,
  list: terms.list.map((item) => ({
    ...item,
    link: getLocalizedHref(Astro.url.pathname, item.link ?? '/terms/list', locale)
  }))
}

const copy =
  locale === 'zh'
    ? {
        title: '站点政策',
        description: '站点政策文档',
        subtitle: '站点政策文档',
        helpTitle: '说明',
        help: '相关的 md 文件位于 terms 目录中。'
      }
    : {
        title: 'Site Policy',
        description: 'Site policy documentation',
        subtitle: 'Site policy documentation',
        helpTitle: 'Help Information',
        help: 'The related md files live in the terms directory.'
      }

const meta = {
  title: copy.title,
  description: copy.description
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/', locale)} style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>{copy.title}</h1>
    </div>

    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <h2 class='text-xl font-medium'>{copy.subtitle}</h2>
      <CardList {...localizedTerms} />
      <h2 class='text-xl font-medium'>{copy.helpTitle}</h2>
      <p>{copy.help}</p>
    </div>
  </main>
</PageLayout>
