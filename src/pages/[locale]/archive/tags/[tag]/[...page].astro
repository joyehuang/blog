---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import { formatDateForLocale, LOCALES, getLocaleFromParam, getLocalePath, getLocalizedHref } from '@/i18n'
import { getLocalizedArchiveEntries } from '@/content-utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { getSortedTags, getTagAliases, getTagLabel } from '@/tags'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const staticPaths = []

  for (const locale of LOCALES) {
    const allArchives = await getLocalizedArchiveEntries(locale)
    const uniqueTags = getSortedTags(allArchives, locale)

    staticPaths.push(
      ...uniqueTags.flatMap((tag) => {
        const filteredEntries = allArchives
          .filter((entry) => entry.data.tags.includes(tag))
          .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

        const pages = paginate(filteredEntries, {
          params: { locale, tag },
          pageSize: 10,
          props: {
            canonicalTag: tag,
            redirectTo: null
          }
        })

        const aliasPaths = getTagAliases(tag)
          .filter((alias) => alias !== tag)
          .flatMap((alias) =>
            Array.from({ length: pages.length }, (_, index) => ({
              params:
                index === 0
                  ? { locale, tag: alias }
                  : { locale, tag: alias, page: String(index + 1) },
              props: {
                redirectTo:
                  index === 0
                    ? getLocalePath(locale, `/archive/tags/${tag}`)
                    : getLocalePath(locale, `/archive/tags/${tag}/${index + 1}`)
              }
            }))
          )

        return [...pages, ...aliasPaths]
      })
    )
  }

  return staticPaths
}

interface Props {
  page?: Page<CollectionEntry<'archive'>>
  canonicalTag?: string
  redirectTo?: string | null
}

const { page, canonicalTag, redirectTo } = Astro.props as Props
const locale = getLocaleFromParam(Astro.params.locale)
const tag = String(canonicalTag ?? Astro.params.tag ?? '')
const tagLabel = getTagLabel(tag, locale)

if (redirectTo) {
  return Astro.redirect(redirectTo, 308)
}

const statusLabels: Record<string, string> =
  locale === 'zh'
    ? {
        'in-progress': '🚧 进行中',
        incomplete: '⏸️ 未完成',
        ready: '✅ 就绪',
        archived: '📦 已归档'
      }
    : {
        'in-progress': '🚧 In Progress',
        incomplete: '⏸️ Incomplete',
        ready: '✅ Ready',
        archived: '📦 Archived'
      }

const statusColors: Record<string, string> = {
  'in-progress': 'text-blue-600 dark:text-blue-400',
  incomplete: 'text-yellow-600 dark:text-yellow-400',
  ready: 'text-green-600 dark:text-green-400',
  archived: 'text-gray-500 dark:text-gray-400'
}

const copy =
  locale === 'zh'
    ? {
        title: '归档标签',
        entryCount: `${page?.total ?? 0} 条相关条目`,
        previous: '← 上一页',
        next: '下一页 →',
        updated: '更新于'
      }
    : {
        title: 'Archive Tag',
        entryCount: `${page?.total ?? 0} ${(page?.total ?? 0) === 1 ? 'entry' : 'entries'} with this tag`,
        previous: '← Previous Entries',
        next: 'Next Entries →',
        updated: 'Updated'
      }

const meta = {
  title: `${copy.title}: ${tagLabel}`,
  description:
    locale === 'zh' ? `查看标签 ${tagLabel} 下的归档条目` : `Archive entries tagged with ${tagLabel}`
}

const paginationProps = {
  ...(page?.url.prev && {
    prevUrl: {
      text: copy.previous,
      url: page.url.prev
    }
  }),
  ...(page?.url.next && {
    nextUrl: {
      text: copy.next,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/archive', locale)} style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-2 flex items-center gap-2'>
        <Icon name='tag-2' class='text-muted-foreground' />
        <h1 class='text-3xl font-medium'>{tagLabel}</h1>
      </div>
      <p class='mb-6 text-muted-foreground'>{copy.entryCount}</p>
    </div>

    <section id='content' class='animate' aria-label='Archive entries'>
      <ul class='space-y-3'>
        {
          page?.data.map((entry) => (
            <li class='group relative rounded-lg border border-border bg-card p-4 transition hover:border-foreground/20 hover:shadow-sm'>
              <a
                href={getLocalizedHref(Astro.url.pathname, `/archive/${entry.data.routeSlug || entry.id}`, locale)}
                class='block'
                data-astro-prefetch
              >
                <div class='mb-2 flex items-start gap-3'>
                  <div class='mt-0.5 shrink-0 text-xl opacity-70 group-hover:opacity-100'>
                    {entry.data.type === 'note' && '📝'}
                    {entry.data.type === 'snippet' && '💡'}
                    {entry.data.type === 'draft' && '✏️'}
                    {entry.data.type === 'idea' && '🔮'}
                    {entry.data.type === 'research' && '🔬'}
                    {entry.data.type === 'reference' && '📚'}
                  </div>
                  <div class='min-w-0 flex-1'>
                    <div class='mb-1 flex items-start justify-between gap-4'>
                      <h3 class='font-medium leading-tight group-hover:text-foreground'>
                        {entry.data.title}
                      </h3>
                      <span
                        class={`shrink-0 text-xs ${statusColors[entry.data.status]}`}
                        title={statusLabels[entry.data.status]}
                      >
                        {entry.data.status === 'in-progress' && '🚧'}
                        {entry.data.status === 'incomplete' && '⏸️'}
                        {entry.data.status === 'ready' && '✅'}
                        {entry.data.status === 'archived' && '📦'}
                      </span>
                    </div>
                    {entry.data.description && (
                      <p class='mb-2 text-sm text-muted-foreground'>{entry.data.description}</p>
                    )}
                    <div class='flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
                      <time datetime={entry.data.date.toISOString()}>
                        {formatDateForLocale(entry.data.date, locale)}
                      </time>
                      {entry.data.updatedDate && (
                        <span>
                          · {copy.updated}{' '}
                          {formatDateForLocale(entry.data.updatedDate, locale, {
                            month: 'short',
                            day: 'numeric'
                          })}
                        </span>
                      )}
                      {entry.data.tags.length > 1 && (
                        <>
                          <span>·</span>
                          <div class='flex flex-wrap gap-1'>
                            {entry.data.tags
                              .filter((t) => t !== tag)
                              .map((t) => (
                                <span class='rounded bg-muted px-1.5 py-0.5'>
                                  {getTagLabel(t, locale)}
                                </span>
                              ))}
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      {(page?.lastPage ?? 0) > 1 && (
        <div class='mt-8'>
          <Paginator {...paginationProps} />
        </div>
      )}
    </section>
  </main>
</PageLayout>
