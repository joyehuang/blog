---
import { Button, Icon } from 'astro-pure/user'
import { getLocaleStaticPaths, getLocaleFromParam, getLocalizedHref } from '@/i18n'
import { getLocalizedArchiveEntries } from '@/content-utils'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true
export const getStaticPaths = getLocaleStaticPaths

const locale = getLocaleFromParam(Astro.params.locale)
const allArchives = await getLocalizedArchiveEntries(locale)

const tagCounts = allArchives.reduce(
  (acc, entry) => {
    entry.data.tags.forEach((tag) => {
      acc[tag] = (acc[tag] || 0) + 1
    })
    return acc
  },
  {} as Record<string, number>
)

const sortedTags = Object.entries(tagCounts).sort(([tagA, countA], [tagB, countB]) => {
  if (countB !== countA) return countB - countA
  return tagA.localeCompare(tagB)
})

const copy =
  locale === 'zh'
    ? {
        title: '归档标签',
        description: '按标签浏览归档条目',
        summary: `浏览 ${sortedTags.length} 个标签，覆盖 ${allArchives.length} 条归档`,
        empty: '暂无归档标签。'
      }
    : {
        title: 'Archive Tags',
        description: 'Browse archive entries by tag',
        summary: `Browse ${sortedTags.length} tags across ${allArchives.length} archive entries`,
        empty: 'No tags found in archive entries.'
      }

const meta = {
  title: copy.title,
  description: copy.description
}
---

<PageLayout {meta}>
  <Button title={locale === 'zh' ? '返回' : 'Back'} href={getLocalizedHref(Astro.url.pathname, '/archive', locale)} style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-2 flex items-center gap-2 text-3xl font-medium'>
        <Icon name='tag-2' />
        {copy.title}
      </h1>
      <p class='mb-6 text-muted-foreground'>{copy.summary}</p>
    </div>

    <section id='content' class='animate'>
      <div class='grid gap-3 sm:grid-cols-2 lg:grid-cols-3'>
        {
          sortedTags.map(([tag, count]) => (
            <a
              href={getLocalizedHref(Astro.url.pathname, `/archive/tags/${tag}`, locale)}
              class='group rounded-lg border border-border bg-card p-4 transition hover:border-foreground/20 hover:shadow-sm'
              data-astro-prefetch
            >
              <div class='flex items-center justify-between'>
                <span class='font-medium group-hover:text-foreground'>{tag}</span>
                <span class='rounded-full bg-muted px-2 py-0.5 text-xs text-muted-foreground'>
                  {count}
                </span>
              </div>
            </a>
          ))
        }
      </div>

      {sortedTags.length === 0 && <p class='text-muted-foreground'>{copy.empty}</p>}
    </section>
  </main>
</PageLayout>
