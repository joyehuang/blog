---
import { render, type CollectionEntry } from 'astro:content'

import { Button, Icon } from 'astro-pure/user'
import { findTranslatedEntry, getAllArchiveEntries, getAllBlogEntries, getEntryRoutePath, getLocalizedContentHref, getLocalizedArchiveEntries } from '@/content-utils'
import { formatDateForLocale, LOCALES, type Locale, getLocaleFromParam, getLocalizedHref } from '@/i18n'
import PageLayout from '@/layouts/ContentLayout.astro'
import { getTagLabel } from '@/tags'

export const prerender = true

export async function getStaticPaths() {
  const staticPaths = []

  for (const locale of LOCALES) {
    const entries = await getLocalizedArchiveEntries(locale)
    staticPaths.push(
      ...entries.map((entry) => ({
        params: { locale, id: getEntryRoutePath(entry) },
        props: { entry }
      }))
    )
  }

  return staticPaths
}

type Props = {
  entry: CollectionEntry<'archive'>
}

const { entry } = Astro.props as Props
const { Content } = await render(entry)
const locale = getLocaleFromParam(Astro.params.locale)

const {
  title,
  description,
  date,
  updatedDate,
  tags,
  type,
  status,
  relatedBlog,
  relatedArchive,
  source
} = entry.data

let relatedBlogPosts: CollectionEntry<'blog'>[] = []
if (relatedBlog && relatedBlog.length > 0) {
  const allBlogPosts = await getAllBlogEntries()
  relatedBlogPosts = allBlogPosts.filter((post) => relatedBlog.includes(post.id))
}

let relatedArchiveEntries: CollectionEntry<'archive'>[] = []
if (relatedArchive && relatedArchive.length > 0) {
  const allArchives = await getAllArchiveEntries()
  relatedArchiveEntries = allArchives.filter(
    (arch) => relatedArchive.includes(arch.id) && arch.id !== entry.id
  )
}

const allArchives = await getAllArchiveEntries()
const localeAlternates = Object.fromEntries(
  LOCALES.map((targetLocale) => {
    const translated = findTranslatedEntry(allArchives, entry, targetLocale as Locale)
    return [
      targetLocale,
      translated
        ? getLocalizedContentHref('archive', translated, targetLocale as Locale)
        : `/${targetLocale}/archive`
    ]
  })
) as Partial<Record<Locale, string>>

const statusLabels: Record<string, string> =
  locale === 'zh'
    ? {
        'in-progress': '🚧 进行中',
        incomplete: '⏸️ 未完成',
        ready: '✅ 就绪',
        archived: '📦 已归档'
      }
    : {
        'in-progress': '🚧 In Progress',
        incomplete: '⏸️ Incomplete',
        ready: '✅ Ready',
        archived: '📦 Archived'
      }

const typeLabels: Record<string, string> =
  locale === 'zh'
    ? {
        note: '📝 笔记',
        snippet: '💡 片段',
        draft: '✏️ 草稿',
        idea: '🔮 想法',
        research: '🔬 研究',
        reference: '📚 参考'
      }
    : {
        note: '📝 Note',
        snippet: '💡 Snippet',
        draft: '✏️ Draft',
        idea: '🔮 Idea',
        research: '🔬 Research',
        reference: '📚 Reference'
      }

const copy =
  locale === 'zh'
    ? {
        updated: '更新于',
        source: '来源',
        related: '相关内容',
        blogPosts: '博客文章',
        archiveEntries: '归档条目',
        note: `这是一条知识库中的${typeLabels[type]?.replace(/^[^\u4e00-\u9fa5a-zA-Z]+/, '') || type}。`,
        noteHint: '内容可能还不完整，或仍在持续更新。',
        back: '← 返回'
      }
    : {
        updated: 'Updated',
        source: 'Source',
        related: 'Related Content',
        blogPosts: 'Blog Posts',
        archiveEntries: 'Archive Entries',
        note: `This is a ${typeLabels[type]?.toLowerCase() || type} in the knowledge base.`,
        noteHint: 'Content may be incomplete or work-in-progress.',
        back: '← Back'
      }

const meta = {
  title,
  description: description || title
}
---

<PageLayout {meta} back='/archive' {localeAlternates}>
  <div slot='header' class='animate gap-y-4'>
    <div class='mb-2 flex flex-wrap items-center gap-2 text-sm text-muted-foreground'>
      <span class='rounded-md bg-muted px-2 py-1'>{typeLabels[type] || type}</span>
      <span class='rounded-md bg-muted px-2 py-1'>{statusLabels[status] || status}</span>
      {
        tags.length > 0 && (
          <>
            <span>·</span>
            {tags.map((tag) => (
              <a
                href={getLocalizedHref(Astro.url.pathname, `/archive/tags/${tag}`, locale)}
                class='rounded-md border border-border px-2 py-1 transition hover:border-foreground/20'
              >
                {getTagLabel(tag, locale)}
              </a>
            ))}
          </>
        )
      }
    </div>

    <h1 class='mb-4 text-3xl font-bold leading-tight sm:text-4xl'>{title}</h1>
    {description && <p class='text-lg text-muted-foreground'>{description}</p>}

    <div class='mt-4 flex flex-wrap items-center gap-4 text-sm text-muted-foreground'>
      <div class='flex items-center gap-2'>
        <Icon name='calendar' />
        <time datetime={date.toISOString()}>{formatDateForLocale(date, locale, { month: 'long' })}</time>
      </div>
      {
        updatedDate && (
          <div class='flex items-center gap-2'>
            <Icon name='calendar' />
            <span>
              {copy.updated} {formatDateForLocale(updatedDate, locale, { month: 'long' })}
            </span>
          </div>
        )
      }
    </div>

    {
      source && (
        <div class='mt-4 flex items-start gap-2 rounded-lg bg-muted/50 p-3 text-sm'>
          <span class='mt-0.5 shrink-0 text-muted-foreground'>🔗</span>
          <div>
            <span class='text-muted-foreground'>{copy.source}: </span>
            <a href={source} target='_blank' rel='noopener noreferrer' class='hover:underline'>
              {source}
            </a>
          </div>
        </div>
      )
    }
  </div>

  <article class='prose prose-pure dark:prose-invert max-w-none'>
    <Content />
  </article>

  <div slot='bottom' class='animate mt-8 border-t border-border pt-6'>
    {(relatedBlogPosts.length > 0 || relatedArchiveEntries.length > 0) && (
      <>
        <h2 class='mb-4 text-xl font-semibold'>{copy.related}</h2>

        {relatedBlogPosts.length > 0 && (
          <div class='mb-6'>
            <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
              <span>📰</span>
              {copy.blogPosts}
            </h3>
            <ul class='space-y-2'>
              {relatedBlogPosts.map((post) => (
                <li>
                  <a
                    href={getLocalizedHref(Astro.url.pathname, `/blog/${post.data.routeSlug || post.id}`, locale)}
                    class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                    data-astro-prefetch
                  >
                    <div class='font-medium'>{post.data.title}</div>
                    {post.data.description && (
                      <p class='mt-1 text-sm text-muted-foreground'>{post.data.description}</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {relatedArchiveEntries.length > 0 && (
          <div class='mb-6'>
            <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
              <span>🗂️</span>
              {copy.archiveEntries}
            </h3>
            <ul class='space-y-2'>
              {relatedArchiveEntries.map((arch) => (
                <li>
                  <a
                    href={getLocalizedHref(Astro.url.pathname, `/archive/${arch.data.routeSlug || arch.id}`, locale)}
                    class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                    data-astro-prefetch
                  >
                    <div class='flex items-center gap-2'>
                      <span class='font-medium'>{arch.data.title}</span>
                      <span class='text-xs text-muted-foreground'>
                        {typeLabels[arch.data.type] || arch.data.type}
                      </span>
                    </div>
                    {arch.data.description && (
                      <p class='mt-1 text-sm text-muted-foreground'>{arch.data.description}</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </>
    )}

    <div class='flex items-start justify-between gap-4 border-t border-border pt-6'>
      <div class='text-sm text-muted-foreground'>
        <p class='mb-2 flex items-center gap-2'>
          <span class='shrink-0'>🗂️</span>
          <span>{copy.note}</span>
        </p>
        <p class='text-xs'>{copy.noteHint}</p>
      </div>
      <Button title={copy.back} href={getLocalizedHref(Astro.url.pathname, '/archive', locale)} style='back' />
    </div>
  </div>
</PageLayout>
