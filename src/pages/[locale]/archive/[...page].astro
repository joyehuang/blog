---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import { formatDateForLocale, LOCALES, getLocaleFromParam, getLocalizedHref } from '@/i18n'
import { getLocalizedArchiveEntries } from '@/content-utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { getSortedTags, getTagLabel } from '@/tags'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const staticPaths = []

  for (const locale of LOCALES) {
    const allArchives = await getLocalizedArchiveEntries(locale)
    staticPaths.push(
      ...paginate(allArchives, {
        pageSize: 20,
        params: { locale }
      })
    )
  }

  return staticPaths
}

interface Props {
  page: Page<CollectionEntry<'archive'>>
}

const { page } = Astro.props as Props
const locale = getLocaleFromParam(Astro.params.locale)
const allArchives = await getLocalizedArchiveEntries(locale)
const uniqueTags = getSortedTags(allArchives, locale)
const uniqueTypes = [...new Set(allArchives.map((entry) => entry.data.type))].sort()
const uniqueStatuses = [...new Set(allArchives.map((entry) => entry.data.status))].sort()

const typeCounts = allArchives.reduce(
  (acc, entry) => {
    acc[entry.data.type] = (acc[entry.data.type] || 0) + 1
    return acc
  },
  {} as Record<string, number>
)

const copy =
  locale === 'zh'
    ? {
        title: page.currentPage === 1 ? '归档库' : `归档库 - 第 ${page.currentPage} 页`,
        description: '知识库与工作笔记，记录想法、片段和半成品',
        back: '返回',
        empty: '还没有归档条目。',
        introTitle: '归档库',
        introSubtitle: '知识库与工作台',
        intro:
          '这里收集研究笔记、代码片段和还没完全成型的材料。它更像我的数字工作台，而不是一组精修后的文章。',
        showing: `显示 ${page.start + 1}-${page.end + 1} / ${page.total} 条`,
        page: `第 ${page.currentPage} / ${page.lastPage} 页`,
        previous: '← 上一页',
        next: '下一页 →',
        tags: '标签',
        viewAll: '查看全部 →',
        more: (count: number) => `还有 ${count} 个`,
        status: '状态',
        types: '类型',
        noEntries: '暂无条目',
        updated: '更新于'
      }
    : {
        title: page.currentPage === 1 ? 'Archive' : `Archive - Page ${page.currentPage}`,
        description: 'Knowledge base and working notes - ideas, snippets, and semi-finished materials',
        back: 'Back',
        empty: 'No archive entries yet.',
        introTitle: 'Archive',
        introSubtitle: 'Knowledge Base & Working Notes',
        intro:
          'A collection of research notes, code snippets, and semi-finished materials. This is my digital workbench for ideas in progress.',
        showing: `Showing ${page.start + 1}-${page.end + 1} of ${page.total} entries`,
        page: `Page ${page.currentPage} of ${page.lastPage}`,
        previous: '← Previous Entries',
        next: 'Next Entries →',
        tags: 'Tags',
        viewAll: 'View all →',
        more: (count: number) => `+${count} more`,
        status: 'Status',
        types: 'Types',
        noEntries: 'No archive entries yet.',
        updated: 'Updated'
      }

const meta = {
  description: copy.description,
  title: copy.title
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: copy.previous,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: copy.next,
      url: page.url.next
    }
  })
}

const typeLabels: Record<string, string> =
  locale === 'zh'
    ? {
        note: '📝 笔记',
        snippet: '💡 片段',
        draft: '✏️ 草稿',
        idea: '🔮 想法',
        research: '🔬 研究',
        reference: '📚 参考'
      }
    : {
        note: '📝 Notes',
        snippet: '💡 Snippets',
        draft: '✏️ Drafts',
        idea: '🔮 Ideas',
        research: '🔬 Research',
        reference: '📚 Reference'
      }

const statusLabels: Record<string, string> =
  locale === 'zh'
    ? {
        'in-progress': '🚧 进行中',
        incomplete: '⏸️ 未完成',
        ready: '✅ 就绪',
        archived: '📦 已归档'
      }
    : {
        'in-progress': '🚧 In Progress',
        incomplete: '⏸️ Incomplete',
        ready: '✅ Ready',
        archived: '📦 Archived'
      }

const statusColors: Record<string, string> = {
  'in-progress': 'text-blue-600 dark:text-blue-400',
  incomplete: 'text-yellow-600 dark:text-yellow-400',
  ready: 'text-green-600 dark:text-green-400',
  archived: 'text-gray-500 dark:text-gray-400'
}
---

<PageLayout {meta}>
  <Button title={copy.back} href={getLocalizedHref(Astro.url.pathname, '/', locale)} style='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-2 flex items-center gap-3'>
        <div class='rounded-lg bg-muted/50 p-2'>
          <span class='text-2xl'>🗂️</span>
        </div>
        <div>
          <h1 class='text-3xl font-medium'>{copy.introTitle}</h1>
          <p class='text-sm text-muted-foreground'>{copy.introSubtitle}</p>
        </div>
      </div>
      <p class='mb-6 mt-4 text-muted-foreground'>{copy.intro}</p>
    </div>

    {
      page.data.length === 0 ? (
        <p>{copy.empty}</p>
      ) : (
        <div class='grid gap-y-8 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section id='content' class='animate' aria-label='Archive entries'>
            <div class='mb-3 flex items-center justify-between text-sm text-muted-foreground sm:mb-5'>
              <span>{copy.showing}</span>
              {page.lastPage > 1 && <span>{copy.page}</span>}
            </div>

            <ul class='space-y-3'>
              {page.data.map((entry) => (
                <li class='group relative rounded-lg border border-border bg-card p-4 transition hover:border-foreground/20 hover:shadow-sm'>
                  <a
                    href={getLocalizedHref(Astro.url.pathname, `/archive/${entry.data.routeSlug || entry.id}`, locale)}
                    class='block'
                    data-astro-prefetch
                  >
                    <div class='mb-2 flex items-start gap-3'>
                      <div class='mt-0.5 shrink-0 text-xl opacity-70 group-hover:opacity-100'>
                        {entry.data.type === 'note' && '📝'}
                        {entry.data.type === 'snippet' && '💡'}
                        {entry.data.type === 'draft' && '✏️'}
                        {entry.data.type === 'idea' && '🔮'}
                        {entry.data.type === 'research' && '🔬'}
                        {entry.data.type === 'reference' && '📚'}
                      </div>
                      <div class='min-w-0 flex-1'>
                        <div class='mb-1 flex items-start justify-between gap-4'>
                          <h3 class='font-medium leading-tight group-hover:text-foreground'>
                            {entry.data.title}
                          </h3>
                          <span
                            class={`shrink-0 text-xs ${statusColors[entry.data.status]}`}
                            title={statusLabels[entry.data.status]}
                          >
                            {entry.data.status === 'in-progress' && '🚧'}
                            {entry.data.status === 'incomplete' && '⏸️'}
                            {entry.data.status === 'ready' && '✅'}
                            {entry.data.status === 'archived' && '📦'}
                          </span>
                        </div>
                        {entry.data.description && (
                          <p class='mb-2 text-sm text-muted-foreground'>{entry.data.description}</p>
                        )}
                        <div class='flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
                          <time datetime={entry.data.date.toISOString()}>
                            {formatDateForLocale(entry.data.date, locale)}
                          </time>
                          {entry.data.updatedDate && (
                            <span>
                              · {copy.updated}{' '}
                              {formatDateForLocale(entry.data.updatedDate, locale, {
                                month: 'short',
                                day: 'numeric'
                              })}
                            </span>
                          )}
                          {entry.data.tags.length > 0 && (
                            <>
                              <span>·</span>
                              <div class='flex flex-wrap gap-1'>
                                {entry.data.tags.map((tag: string) => (
                                  <span class='rounded bg-muted px-1.5 py-0.5'>
                                    {getTagLabel(tag, locale)}
                                  </span>
                                ))}
                              </div>
                            </>
                          )}
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              ))}
            </ul>

            {page.lastPage > 1 && (
              <div class='mt-8'>
                <Paginator {...paginationProps} />
              </div>
            )}
          </section>

          <aside class='animate' id='sidebar'>
            {!!uniqueTags.length && (
              <div class='mb-6'>
                <div class='mb-4 flex items-center justify-between'>
                  <h2 class='flex items-center text-lg font-semibold'>
                    <Icon name='tag-2' class='me-2' />
                    {copy.tags}
                  </h2>
                  <a
                    href={getLocalizedHref(Astro.url.pathname, '/archive/tags', locale)}
                    class='text-xs text-muted-foreground hover:text-foreground'
                  >
                    {copy.viewAll}
                  </a>
                </div>
                <ul class='flex flex-wrap gap-2 text-xs'>
                  {uniqueTags.slice(0, 15).map((tag) => (
                    <li>
                      <a
                        href={getLocalizedHref(Astro.url.pathname, `/archive/tags/${tag}`, locale)}
                        class='rounded-md border border-border bg-card px-2 py-1 transition hover:border-foreground/20'
                      >
                        {getTagLabel(tag, locale)}
                      </a>
                    </li>
                  ))}
                  {uniqueTags.length > 15 && (
                    <li>
                      <a
                        href={getLocalizedHref(Astro.url.pathname, '/archive/tags', locale)}
                        class='rounded-md border border-dashed border-border bg-card px-2 py-1 text-muted-foreground hover:text-foreground'
                      >
                        {copy.more(uniqueTags.length - 15)}
                      </a>
                    </li>
                  )}
                </ul>
              </div>
            )}

            <div class='mb-6'>
              <h2 class='mb-4 text-lg font-semibold'>{copy.status}</h2>
              <ul class='space-y-2 text-sm'>
                {uniqueStatuses.map((status) => (
                  <li class={statusColors[status]}>{statusLabels[status] || status}</li>
                ))}
              </ul>
            </div>

            <div>
              <h2 class='mb-4 text-lg font-semibold'>{copy.types}</h2>
              <ul class='space-y-2 text-sm'>
                {uniqueTypes.map((type) => (
                  <li>
                    {typeLabels[type] || type}
                    <span class='ml-2 text-muted-foreground'>({typeCounts[type] || 0})</span>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        </div>
      )
    }
  </main>
</PageLayout>
