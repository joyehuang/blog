</style>

<script>
  function initTalks() {
    const root = document.querySelector<HTMLElement>('.talks')
    if (!root || root.dataset.tkInit === '1') return
    root.dataset.tkInit = '1'

    // ----- accordion: expand / collapse each session -----
    root.querySelectorAll<HTMLButtonElement>('.tk-head').forEach((head) => {
      head.addEventListener('click', () => {
        const entry = head.closest<HTMLElement>('.tk-entry')
        if (!entry) return
        const open = entry.dataset.open === 'true'
        entry.dataset.open = open ? 'false' : 'true'
        head.setAttribute('aria-expanded', open ? 'false' : 'true')
      })
    })
  }

  initTalks()
  document.addEventListener('astro:after-swap', initTalks)
</script>
