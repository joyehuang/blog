---
import type { RoadmapItem, RoadmapStatus } from '@/data/roadmap'
import { useTranslations } from '@/i18n/ui'
import type { Lang } from '@/i18n/ui'

interface Props {
  status: RoadmapStatus
  items: RoadmapItem[]
  lang: Lang
}

const { status, items, lang } = Astro.props
const t = useTranslations(lang)

const dotClass: Record<RoadmapStatus, string> = {
  now: 'bg-primary',
  next: 'bg-foreground/60',
  later: 'bg-foreground/30',
  done: 'bg-foreground/20'
}

const isDone = status === 'done'
---

<section class='not-prose'>
  <div class='mb-3 flex items-center gap-2'>
    <span class={`inline-block size-2 rounded-full ${dotClass[status]}`}></span>
    <h2 class={`text-sm font-semibold tracking-wide ${isDone ? 'text-muted-foreground' : 'text-foreground'}`}>
      {t(`roadmap.horizon.${status}` as 'roadmap.horizon.now')}
    </h2>
    <span class='text-xs text-muted-foreground'>{items.length}</span>
  </div>

  {
    items.length === 0 ? (
      <p class='rounded-lg border border-dashed px-4 py-3 text-sm text-muted-foreground'>
        {t('roadmap.empty')}
      </p>
    ) : (
      <div class='flex flex-col gap-3'>
        {items.map((item) => (
          <article
            class={`flex flex-col gap-2 rounded-xl border bg-background p-4 sm:p-5 ${isDone ? 'opacity-80' : ''}`}
          >
            <div class='flex items-start justify-between gap-3'>
              <h3 class='m-0 font-mono text-base font-medium text-foreground'>
                <span class='text-muted-foreground'>#</span>
                {item.id}
              </h3>
              {item.shippedAt && (
                <span class='shrink-0 text-xs text-muted-foreground'>
                  {t('roadmap.shippedAt')} {item.shippedAt}
                </span>
              )}
            </div>

            <p class='m-0 text-sm leading-relaxed text-muted-foreground'>{item.summary}</p>

            {item.goals && item.goals.length > 0 && (
              <div class='mt-1'>
                <p class='mb-1 text-xs font-medium text-foreground/70'>
                  {t('roadmap.goals')}
                </p>
                <ul class='m-0 list-disc space-y-0.5 pl-5 text-sm text-muted-foreground'>
                  {item.goals.map((g) => <li>{g}</li>)}
                </ul>
              </div>
            )}

            {item.refs && item.refs.length > 0 && (
              <div class='mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs'>
                <span class='text-muted-foreground'>{t('roadmap.refs')}</span>
                {item.refs.map((ref) => (
                  <a
                    class='text-foreground underline-offset-4 hover:underline'
                    href={ref.href}
                    target={ref.href.startsWith('http') ? '_blank' : undefined}
                    rel={ref.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  >
                    {ref.label}
                  </a>
                ))}
              </div>
            )}

            {item.tags && item.tags.length > 0 && (
              <div class='flex flex-wrap gap-1.5'>
                {item.tags.map((tag) => (
                  <span class='rounded-md bg-muted px-1.5 py-0.5 text-xs text-muted-foreground'>
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    )
  }
</section>
