---
import type { MarkdownHeading } from 'astro'

import TableOfContentsItem from './TableOfContentsItem.astro'
import { generateToc } from './toc'

interface Props {
  headings: MarkdownHeading[]
  class?: string
  id?: string
}

const { headings, class: className, ...props } = Astro.props
const toc = generateToc(headings)
---

<site-table-of-contents class={className} {...props}>
  <h2 class='font-semibold'>TABLE OF CONTENTS</h2>
  <ul class='mt-4 text-card-foreground'>
    {toc.map((heading) => <TableOfContentsItem heading={heading} />)}
  </ul>
</site-table-of-contents>

<script>
  interface TOCLink {
    element: HTMLAnchorElement
    progressBar: HTMLElement | null
    slug: string
  }

  interface HeadingProgress {
    inView: boolean
    progress: number
  }

  class SiteTableOfContents extends HTMLElement {
    headings: HTMLElement[] = []
    tocLinks: TOCLink[] = []
    headingProgress: Record<string, HeadingProgress> = {}
    activeSlug = ''
    animationFrame = 0

    connectedCallback() {
      const articleHeadings = Array.from(
        document.querySelectorAll('article h2, article h3, article h4, article h5, article h6')
      )
      this.tocLinks = Array.from(this.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')).map(
        (link) => ({
          element: link,
          progressBar: link.parentElement?.querySelector('[data-toc-progress]') ?? null,
          slug: (link.getAttribute('href') || '').substring(1)
        })
      )
      this.headings = this.tocLinks
        .map(({ slug }) => articleHeadings.find((heading) => heading.id === slug))
        .filter((heading): heading is HTMLElement => Boolean(heading))

      this.tocLinks.forEach((link) => {
        link.element.addEventListener('click', (event) => {
          event.preventDefault()

          const directHeading = this.headings.find((heading) => heading.id === link.slug)
          if (!directHeading) {
            console.warn(`No heading found for slug: ${link.slug}`)
            return
          }

          history.pushState(null, directHeading.textContent || '', link.element.getAttribute('href'))
          directHeading.scrollIntoView({ behavior: 'smooth' })
        })
      })

      this.updatePositionAndStyle()
      window.addEventListener('scroll', this.scheduleUpdate, { passive: true })
      window.addEventListener('resize', this.scheduleUpdate)
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.scheduleUpdate)
      window.removeEventListener('resize', this.scheduleUpdate)
      if (this.animationFrame) window.cancelAnimationFrame(this.animationFrame)
    }

    scheduleUpdate = () => {
      if (this.animationFrame) return
      this.animationFrame = window.requestAnimationFrame(() => {
        this.animationFrame = 0
        this.updatePositionAndStyle()
      })
    }

    updatePositionAndStyle = () => {
      const windowHeight = window.innerHeight
      const contentElement = document.querySelector('#content') as HTMLElement | null
      const pageOffset = window.scrollY - (contentElement?.offsetTop || 0)
      const postOffset = (contentElement?.offsetHeight || 0) + 127

      this.headings.forEach((el, index) => {
        const nextHeadingTop = this.headings[index + 1]?.offsetTop || postOffset
        const range = [el.offsetTop - pageOffset, nextHeadingTop - pageOffset - el.offsetHeight]
        const progress = (windowHeight - range[0]) / (range[1] - range[0])

        this.headingProgress[el.id] = {
          inView: range[0] < windowHeight && range[1] > 0,
          progress: Math.max(0, Math.min(1, Number.isFinite(progress) ? progress : 1))
        }
      })

      let activeLink: HTMLAnchorElement | null = null

      this.tocLinks.forEach(({ element, progressBar, slug }, index) => {
        const headingProgress = this.headingProgress[slug]
        if (!headingProgress) return

        const { inView, progress } = headingProgress
        const previousProgress = this.headingProgress[this.tocLinks[index - 1]?.slug]
        const nextProgress = this.headingProgress[this.tocLinks[index + 1]?.slug]

        element.classList.toggle('highlight', inView)
        element.classList.toggle('highlight-bg-translucent', inView)
        element.classList.toggle('rounded-t-2xl', inView && (index === 0 || !previousProgress?.inView))
        element.classList.toggle(
          'rounded-b-2xl',
          inView && (index === this.tocLinks.length - 1 || !nextProgress?.inView)
        )

        progressBar?.classList.toggle('is-read', !inView && progress === 1)
        progressBar?.classList.toggle('highlight-bg', inView)
        progressBar?.style.setProperty('height', `${progress * 90}%`)

        if (inView && !activeLink) activeLink = element
      })

      if (!activeLink) {
        activeLink = this.findNearestPassedLink()
      }

      this.scrollActiveLinkIntoView(activeLink)
    }

    findNearestPassedLink() {
      const anchorOffset = 112
      let nearest: HTMLAnchorElement | null = null

      this.tocLinks.forEach(({ element, slug }) => {
        const heading = this.headings.find((item) => item.id === slug)
        if (heading && heading.getBoundingClientRect().top <= anchorOffset) nearest = element
      })

      return nearest
    }

    scrollActiveLinkIntoView(activeLink: HTMLAnchorElement | null) {
      if (!activeLink) return

      const slug = (activeLink.getAttribute('href') || '').substring(1)
      if (slug === this.activeSlug) return
      this.activeSlug = slug

      const scrollContainer = this.closest('#sidebar') ?? this
      const containerRect = scrollContainer.getBoundingClientRect()
      const linkRect = activeLink.getBoundingClientRect()
      const edgePadding = 56
      const isAbove = linkRect.top < containerRect.top + edgePadding
      const isBelow = linkRect.bottom > containerRect.bottom - edgePadding

      if (!isAbove && !isBelow) return

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      activeLink.scrollIntoView({
        block: 'center',
        behavior: reducedMotion ? 'auto' : 'smooth'
      })
    }
  }

  if (!customElements.get('site-table-of-contents')) {
    customElements.define('site-table-of-contents', SiteTableOfContents)
  }
</script>

<style>
  site-table-of-contents {
    display: block;
  }

  site-table-of-contents :global(.toc-item) {
    display: flow-root;
  }
</style>
