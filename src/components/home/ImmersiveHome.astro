    --home-muted: hsl(var(--muted-foreground));
    --home-border: hsl(var(--border));
    --home-accent: hsl(var(--primary));
    display: block;
    overflow: clip;
    color: var(--home-fg);
    background: var(--home-bg);
    font-family:
      'Geist Variable', 'PingFang SC', 'Microsoft YaHei UI', 'Noto Sans CJK SC', system-ui,
      sans-serif;
    text-rendering: optimizeLegibility;
  }

