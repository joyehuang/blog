---
import { Image } from 'astro:assets'
import avatar from 'src/assets/avatar.png'

import IntroOverlay from '@/components/intro/IntroOverlay.astro'
import JoJo from '@/components/mascot/JoJo'

type FeedItem = {
  title: string
  href: string
  meta: string
  kind: string
}

type RepoItem = {
  name: string
  description: string
  stars: number
}

interface Props {
  locale: 'zh' | 'en'
  posts: FeedItem[]
  notes: FeedItem[]
  repos: RepoItem[]
}

const { locale, posts, notes, repos } = Astro.props
const isEn = locale === 'en'
const prefix = isEn ? '/en' : ''

const copy = isEn
  ? {
      nav: ['Work', 'Field notes', 'Open source'],
      navLinks: ['#work', '#notes', '#open-source'],
      contact: 'Start a conversation',
      eyebrow: 'AI systems · product engineering · creative code',
      heroA: 'I BUILD',
      heroB: 'INTELLIGENCE',
      heroC: 'THAT SHIPS.',
      heroBody:
        'AI agent and full-stack engineer turning uncertain ideas into precise, useful products.',
      based: 'Melbourne / Shanghai / the internet',
      availability: 'Available for ambitious collaborations',
      scroll: 'Scroll to enter the system',
      statementA: 'Not another layer of AI theatre.',
      statementB:
        'I design the system, interaction and code as one continuous experience — from the first prompt to production.',
      selected: 'Selected systems',
      selectedMeta: 'Field work / 2025—2026',
      lab: 'Currently building',
      labBody:
        'Commercial research agents, image-generation workflows, and tools that make creative teams dramatically faster.',
      writing: 'Signals from the lab',
      writingBody: 'Long-form essays and short notes from building at the edge of applied AI.',
      posts: 'Essays',
      notes: 'Notes',
      morePosts: 'View all writing',
      openSource: 'Open source, in public',
      openSourceBody: 'I learn by opening the machine and rebuilding it from first principles.',
      stars: 'GitHub stars',
      projects: 'public projects',
      visitors: 'curious visitors',
      finaleA: 'HAVE A HARD',
      finaleB: 'PROBLEM?',
      finaleBody: "Let's make it useful, clear and a little unexpected.",
      email: 'Let’s talk',
      replay: 'Replay entrance',
      live: 'SYSTEM ONLINE'
    }
  : {
      nav: ['作品', '现场笔记', '开源'],
      navLinks: ['#work', '#notes', '#open-source'],
      contact: '聊一个想法',
      eyebrow: 'AI 系统 · 产品工程 · 创意开发',
      heroA: '构建',
      heroB: '真正运行的',
      heroC: '智能。',
      heroBody: 'AI Agent 与全栈工程师，把模糊的想法变成精确、好用、真正上线的产品。',
      based: '墨尔本 / 上海 / 互联网',
      availability: '开放有野心的合作',
      scroll: '向下滚动，进入系统',
      statementA: '不做又一层 AI 表演。',
      statementB: '我把系统、交互与代码设计成一段连续体验——从第一个 Prompt 到真实生产环境。',
      selected: '正在构建的系统',
      selectedMeta: '项目现场 / 2025—2026',
      lab: '此刻在做',
      labBody: '商业研究 Agent、图像生成工作流，以及让创意团队明显更快的智能工具。',
      writing: '来自实验现场的信号',
      writingBody: '关于应用 AI、Agent 工程与产品设计的长文和短笔记。',
      posts: '文章',
      notes: '笔记',
      morePosts: '查看全部写作',
      openSource: '开源，公开构建',
      openSourceBody: '我习惯打开机器，从第一性原理重新造一遍。',
      stars: 'GitHub Stars',
      projects: '公开项目',
      visitors: '位访客',
      finaleA: '有一个够难的',
      finaleB: '问题吗？',
      finaleBody: '让我们把它做得有用、清楚，而且出人意料。',
      email: '聊聊看',
      replay: '重播入场',
      live: '系统在线'
    }

const projects = [
  {
    index: '01',
    name: 'Playyy.ai',
    role: isEn ? 'AI design platform' : 'AI 设计平台',
    description: isEn
      ? 'A brand-aware image generation workspace built for real creative teams.'
      : '为真实创意团队打造的品牌感知图像生成工作台。',
    href: 'https://playyy.ai/',
    accent: '#8ed8ff'
  },
  {
    index: '02',
    name: 'atypica',
    role: isEn ? 'Multi-agent research' : '多智能体商业研究',
    description: isEn
      ? 'Research agents that turn fragmented market signals into decision-ready intelligence.'
      : '把碎片化市场信号转化为可直接决策的研究智能体。',
    href: 'https://atypica.ai/',
    accent: '#f6b6a5'
  },
  {
    index: '03',
    name: 'AIXCut',
    role: isEn ? 'Video editing agent' : '视频剪辑 Agent',
    description: isEn
      ? 'An agentic editing system that translates intent into a finished visual sequence.'
      : '把创作意图直接转译为完整视觉序列的智能剪辑系统。',
    href: 'https://aixcut.cn/',
    accent: '#b6f0c4'
  },
  {
    index: '04',
    name: 'Summer of Agents',
    role: isEn ? 'Community experiment' : 'Agent 社区实验',
    description: isEn
      ? 'A public arena for builders to form teams, ship agents and learn in the open.'
      : '让开发者公开组队、交付 Agent、一起学习的社区实验场。',
    href: '/agent-teams',
    accent: '#f7d277'
  }
]
---

<IntroOverlay locale={locale} />

<home-landing class='landing' data-locale={locale}>
  <div class='landing__noise' aria-hidden='true'></div>
  <div class='landing__cursor-glow' aria-hidden='true'></div>

  <nav class='landing-nav' aria-label={isEn ? 'Primary navigation' : '主导航'}>
    <a class='landing-nav__brand' href={prefix || '/'} aria-label='Joye home'>
      <span>J</span><span>OYE</span>
    </a>
    <div class='landing-nav__links'>
      {copy.nav.map((label, index) => <a href={copy.navLinks[index]}>{label}</a>)}
    </div>
    <div class='landing-nav__actions'>
      <span class='landing-nav__status'><i></i>{copy.live}</span>
      <a class='landing-nav__language' href={isEn ? '/' : '/en'}>{isEn ? '中' : 'EN'}</a>
      <a class='landing-nav__contact' href={`${prefix}/contact`}>{copy.contact}<span>↗</span></a>
    </div>
  </nav>

  <main>
    <section class='hero' id='top' data-landing-hero>
      <div class='hero__grid' aria-hidden='true'></div>
      <div class='hero__orbit hero__orbit--one' aria-hidden='true'></div>
      <div class='hero__orbit hero__orbit--two' aria-hidden='true'></div>
      <div class='hero__beam' aria-hidden='true'></div>

      <div class='hero__meta hero__meta--top' data-hero-reveal>
        <span>PORTFOLIO / 2026</span>
        <span>{copy.eyebrow}</span>
      </div>

      <div class='hero__avatar-wrap' data-hero-reveal>
        <div class='hero__avatar-orbit' aria-hidden='true'><span></span><span></span></div>
        <Image
          src={avatar}
          alt={isEn ? 'Portrait of Joye' : 'Joye 的头像'}
          class='hero__avatar'
          data-intro-target='avatar'
          loading='eager'
        />
        <span class='hero__avatar-label'>SUBJECT / JOYE</span>
      </div>

      <div class='hero__title' data-intro-target='wordmark'>
        <p class='hero__eyebrow' data-hero-reveal>{copy.eyebrow}</p>
        <h1>
          <span data-hero-line>{copy.heroA}</span>
          <span class='hero__title-accent' data-hero-line>{copy.heroB}</span>
          <span data-hero-line>{copy.heroC}</span>
        </h1>
      </div>

      <div class='hero__footer' data-hero-reveal>
        <p>{copy.heroBody}</p>
        <div class='hero__coordinates'>
          <span>{copy.based}</span>
          <span>{copy.availability}</span>
        </div>
      </div>

      <a class='hero__scroll' href='#manifesto' data-hero-reveal>
        <span class='hero__scroll-line'></span>
        <span>{copy.scroll}</span>
      </a>
    </section>

    <section class='manifesto landing-section' id='manifesto'>
      <div class='section-index' data-reveal>01 / POSITION</div>
      <div class='manifesto__copy'>
        <p class='manifesto__lead' data-reveal>{copy.statementA}</p>
        <p data-reveal>{copy.statementB}</p>
      </div>
      <div class='manifesto__signal' aria-hidden='true' data-reveal>
        <span>HUMAN INTENT</span><i></i><span>WORKING SYSTEM</span>
      </div>
    </section>

    <section class='work landing-section' id='work'>
      <header class='section-heading' data-reveal>
        <div>
          <span class='section-index'>02 / WORK</span>
          <h2>{copy.selected}</h2>
        </div>
        <p>{copy.selectedMeta}</p>
      </header>

      <div class='project-grid'>
        {
          projects.map((project) => (
            <a
              class='project-panel'
              href={project.href}
              target={project.href.startsWith('http') ? '_blank' : undefined}
              rel={project.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              style={`--project-accent:${project.accent}`}
              data-project-card
              data-reveal
            >
              <div class='project-panel__top'>
                <>
                  <span>{project.index}</span>
                  <span>{project.role}</span>
                  <span>↗</span>
                </>
              </div>
              <div class='project-panel__visual' aria-hidden='true'>
                <span class='project-panel__disc' />
                <span class='project-panel__axis project-panel__axis--x' />
                <span class='project-panel__axis project-panel__axis--y' />
                <span class='project-panel__pulse' />
              </div>
              <div class='project-panel__copy'>
                <h3>{project.name}</h3>
                <p>{project.description}</p>
              </div>
            </a>
          ))
        }
      </div>

      <div class='work__ticker' aria-hidden='true'>
        <div>
          <span>AGENT SYSTEMS</span><i></i><span>CREATIVE ENGINEERING</span><i></i><span
            >PRODUCTS THAT SHIP</span
          ><i></i><span>AGENT SYSTEMS</span><i></i><span>CREATIVE ENGINEERING</span><i></i><span
            >PRODUCTS THAT SHIP</span
          >
        </div>
      </div>
    </section>

    <section class='now landing-section'>
      <div class='section-index' data-reveal>03 / NOW</div>
      <div class='now__layout'>
        <h2 data-reveal>{copy.lab}</h2>
        <p data-reveal>{copy.labBody}</p>
        <div class='now__machine' data-reveal aria-hidden='true'>
          <span class='now__machine-core'>AI</span>
          <span class='now__machine-ring now__machine-ring--a'></span>
          <span class='now__machine-ring now__machine-ring--b'></span>
          <span class='now__machine-node now__machine-node--a'>01</span>
          <span class='now__machine-node now__machine-node--b'>02</span>
          <span class='now__machine-node now__machine-node--c'>03</span>
        </div>
      </div>
    </section>

    <section class='notes landing-section' id='notes'>
      <header class='section-heading' data-reveal>
        <div>
          <span class='section-index'>04 / NOTES</span>
          <h2>{copy.writing}</h2>
        </div>
        <p>{copy.writingBody}</p>
      </header>

      <div class='feed-columns'>
        <div class='feed-column' data-reveal>
          <div class='feed-column__label'>
            <span>{copy.posts}</span><span>{String(posts.length).padStart(2, '0')}</span>
          </div>
          {
            posts.map((item, index) => (
              <a class='feed-row' href={item.href}>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{item.title}</strong>
                <em>{item.meta}</em>
                <i>↗</i>
              </a>
            ))
          }
        </div>
        <div class='feed-column' data-reveal>
          <div class='feed-column__label'>
            <span>{copy.notes}</span><span>{String(notes.length).padStart(2, '0')}</span>
          </div>
          {
            notes.map((item, index) => (
              <a class='feed-row' href={item.href}>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{item.title}</strong>
                <em>{item.kind}</em>
                <i>↗</i>
              </a>
            ))
          }
        </div>
      </div>
      <a class='text-link' href={`${prefix}/blog`} data-reveal>{copy.morePosts}<span>↗</span></a>
    </section>

    <section class='open-source landing-section' id='open-source'>
      <div class='open-source__intro'>
        <span class='section-index' data-reveal>05 / SOURCE</span>
        <h2 data-reveal>{copy.openSource}</h2>
        <p data-reveal>{copy.openSourceBody}</p>
      </div>

      <div class='repo-list'>
        {
          repos.map((repo, index) => (
            <a
              class='repo-row'
              href={`https://github.com/joyehuang/${repo.name}`}
              target='_blank'
              rel='noopener noreferrer'
              data-reveal
            >
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{repo.name}</h3>
              <p>{repo.description}</p>
              <strong>★ {repo.stars}</strong>
              <i>↗</i>
            </a>
          ))
        }
      </div>

      <div class='stats' data-reveal>
        <div>
          <strong>{repos.reduce((sum, repo) => sum + repo.stars, 0)}+</strong><span
            >{copy.stars}</span
          >
        </div>
        <div><strong>12</strong><span>{copy.projects}</span></div>
        <div><strong>1K+</strong><span>{copy.visitors}</span></div>
      </div>
    </section>

    <section class='finale landing-section'>
      <div class='finale__halo' aria-hidden='true'></div>
      <span class='section-index' data-reveal>06 / CONTACT</span>
      <div class='finale__title'>
        <span data-reveal>{copy.finaleA}</span>
        <span data-reveal>{copy.finaleB}</span>
      </div>
      <p data-reveal>{copy.finaleBody}</p>
      <div class='finale__actions' data-reveal>
        <a href={`${prefix}/contact`}>{copy.email}<span>↗</span></a>
        <button type='button' data-replay-intro>{copy.replay}<span>↻</span></button>
      </div>
      <footer class='finale__footer'>
        <span>© {new Date().getFullYear()} JOYE HUANG</span>
        <span>DESIGNED + ENGINEERED IN THE OPEN</span>
        <a href='#top'>BACK TO SIGNAL ↑</a>
      </footer>
    </section>
  </main>

  <div id='home-jojo' class='landing-jojo'>
    <JoJo client:load size='md' quipPool='idle' />
  </div>
</home-landing>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  class HomeLanding extends HTMLElement {
    private context?: gsap.Context
    private cleanups: Array<() => void> = []

    connectedCallback() {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const heroLines = this.querySelectorAll<HTMLElement>('[data-hero-line]')
      const heroDetails = this.querySelectorAll<HTMLElement>('[data-hero-reveal]')
      const revealItems = this.querySelectorAll<HTMLElement>('[data-reveal]')
      const hero = this.querySelector<HTMLElement>('[data-landing-hero]')

      this.context = gsap.context(() => {
        if (!reduced) {
          const enterHero = () => {
            if (this.dataset.heroEntered === 'true') return
            this.dataset.heroEntered = 'true'
            gsap
              .timeline({ defaults: { ease: 'power4.out' } })
              .fromTo(
                heroLines,
                { yPercent: 42, rotateX: -10 },
                {
                  yPercent: 0,
                  rotateX: 0,
                  duration: 1.05,
                  stagger: 0.11,
                  immediateRender: false
                }
              )
              .fromTo(
                heroDetails,
                { opacity: 0, y: 18 },
                {
                  opacity: 1,
                  y: 0,
                  duration: 0.72,
                  stagger: 0.08,
                  immediateRender: false
                },
                '-=0.62'
              )
          }

          const introOverlay = document.getElementById('intro-overlay')
          if (!introOverlay || introOverlay.classList.contains('intro-idle')) {
            requestAnimationFrame(enterHero)
          } else {
            const queueHeroEntry = () => requestAnimationFrame(enterHero)
            window.addEventListener('joye:intro:complete', queueHeroEntry, { once: true })
            this.cleanups.push(() =>
              window.removeEventListener('joye:intro:complete', queueHeroEntry)
            )
            const overlayObserver = new MutationObserver(() => {
              if (
                introOverlay.classList.contains('intro-idle') ||
                introOverlay.classList.contains('intro-exit')
              ) {
                enterHero()
                overlayObserver.disconnect()
              }
            })
            overlayObserver.observe(introOverlay, { attributes: true, attributeFilter: ['class'] })
            this.cleanups.push(() => overlayObserver.disconnect())
          }

          revealItems.forEach((item) => {
            gsap.fromTo(
              item,
              { opacity: 0, y: 44 },
              {
                opacity: 1,
                y: 0,
                duration: 0.85,
                ease: 'power3.out',
                scrollTrigger: { trigger: item, start: 'top 88%', once: true }
              }
            )
          })

          if (hero) {
            gsap.to(hero.querySelector('.hero__title'), {
              yPercent: 16,
              opacity: 0.22,
              ease: 'none',
              scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.7 }
            })
            gsap.to(hero.querySelector('.hero__avatar-wrap'), {
              yPercent: -24,
              rotate: 8,
              ease: 'none',
              scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.7 }
            })
          }
        } else {
          gsap.set([...heroLines, ...heroDetails, ...revealItems], { clearProps: 'all' })
        }
      }, this)

      const pointerMove = (event: PointerEvent) => {
        this.style.setProperty('--pointer-x', `${event.clientX}px`)
        this.style.setProperty('--pointer-y', `${event.clientY}px`)
      }
      if (!reduced && window.matchMedia('(pointer: fine)').matches) {
        window.addEventListener('pointermove', pointerMove, { passive: true })
        this.cleanups.push(() => window.removeEventListener('pointermove', pointerMove))
      }

      this.querySelectorAll<HTMLElement>('[data-project-card]').forEach((card) => {
        const move = (event: PointerEvent) => {
          if (reduced) return
          const rect = card.getBoundingClientRect()
          const x = (event.clientX - rect.left) / rect.width - 0.5
          const y = (event.clientY - rect.top) / rect.height - 0.5
          gsap.to(card, { rotateY: x * 4, rotateX: y * -4, duration: 0.45, ease: 'power2.out' })
        }
        const leave = () =>
          gsap.to(card, { rotateY: 0, rotateX: 0, duration: 0.65, ease: 'power3.out' })
        card.addEventListener('pointermove', move)
        card.addEventListener('pointerleave', leave)
        this.cleanups.push(() => {
          card.removeEventListener('pointermove', move)
          card.removeEventListener('pointerleave', leave)
        })
      })

      const replay = this.querySelector<HTMLButtonElement>('[data-replay-intro]')
      const playIntro = () => window.__joyeIntro?.play('jojo')
      replay?.addEventListener('click', playIntro)
      this.cleanups.push(() => replay?.removeEventListener('click', playIntro))
    }

    disconnectedCallback() {
      this.cleanups.forEach((cleanup) => cleanup())
      this.cleanups = []
      this.context?.revert()
      ScrollTrigger.getAll().forEach((trigger) => trigger.kill())
    }
  }

  if (!customElements.get('home-landing')) customElements.define('home-landing', HomeLanding)

  declare global {
    interface Window {
      __joyeIntro?: { play(variant: 'focus' | 'line' | 'jojo'): void }
    }
  }
</script>

<style>
  .landing {
    --ink: #080b0d;
    --ink-soft: #0d1215;
    --paper: #f2f0e9;
    --steel: #78bad8;
    --line: rgb(234 242 245 / 16%);
    --muted: rgb(234 242 245 / 58%);
    --pointer-x: 50vw;
    --pointer-y: 35vh;
    position: relative;
    display: block;
    overflow: clip;
    color: var(--paper);
    background: var(--ink);
    font-family: 'Satoshi', sans-serif;
    isolation: isolate;
  }

  .landing::before {
    position: fixed;
    inset: 0;
    z-index: -3;
    background:
      radial-gradient(circle at 18% 12%, rgb(120 186 216 / 11%), transparent 32rem),
      radial-gradient(circle at 82% 70%, rgb(113 149 162 / 7%), transparent 34rem), var(--ink);
    content: '';
    pointer-events: none;
  }

  .landing__noise {
    position: fixed;
    inset: 0;
    z-index: 80;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.8'/%3E%3C/svg%3E");
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .landing__cursor-glow {
    position: fixed;
    top: var(--pointer-y);
    left: var(--pointer-x);
    z-index: -1;
    width: 34rem;
    height: 34rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgb(120 186 216 / 7%), transparent 66%);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .landing-nav {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 90;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 5.4rem;
    padding: 0 clamp(1.2rem, 4vw, 4.5rem);
    color: var(--paper);
    background: linear-gradient(to bottom, rgb(8 11 13 / 82%), transparent);
  }

  .landing-nav a {
    color: inherit;
    text-decoration: none;
  }
  .landing-nav__brand {
    display: inline-flex;
    align-items: baseline;
    width: fit-content;
    font-size: 1rem;
    font-weight: 760;
    letter-spacing: 0.08em;
  }
  .landing-nav__brand span:first-child {
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    place-items: center;
    margin-right: 0.45rem;
    border: 1px solid rgb(242 240 233 / 42%);
    border-radius: 50%;
    font-size: 0.78rem;
  }
  .landing-nav__links {
    display: flex;
    gap: 2rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .landing-nav__links a {
    position: relative;
    color: var(--muted);
  }
  .landing-nav__links a::after {
    position: absolute;
    right: 0;
    bottom: -0.55rem;
    left: 0;
    height: 1px;
    background: var(--paper);
    content: '';
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  .landing-nav__links a:hover {
    color: var(--paper);
  }
  .landing-nav__links a:hover::after {
    transform: scaleX(1);
  }
