---
import { Image } from 'astro:assets'
import avatar from 'src/assets/avatar.png'
import interior from 'src/assets/projects/alex-tyson-2BAXJ7ha74s-unsplash.jpg'
import architectureGrid from 'src/assets/projects/angelica-teran-Bk9hpaXHK4o-unsplash.jpg'
import flowers from 'src/assets/projects/kseniia-zapiatkina-yATU3rg8tNI-unsplash.jpg'
import architectureLight from 'src/assets/projects/wen-qiao-g_w8I64FiO0-unsplash.jpg'

import IntroOverlay from '@/components/intro/IntroOverlay.astro'
import JoJo from '@/components/mascot/JoJo'

type FeedItem = {
  title: string
  href: string
  meta: string
  kind: string
}

type RepoItem = {
  name: string
  description: string
  stars: number
}

interface Props {
  locale: 'zh' | 'en'
  posts: FeedItem[]
  notes: FeedItem[]
  repos: RepoItem[]
}

const { locale, posts, notes, repos } = Astro.props
const isEn = locale === 'en'
const prefix = isEn ? '/en' : ''

const copy = isEn
  ? {
      work: 'Work',
      journal: 'Journal',
      about: 'About',
      contact: 'Contact',
      role: 'AI agent & product engineer',
      intro: 'I make intelligent products feel tangible.',
      location: 'Melbourne · Shanghai · Remote',
      explore: 'Scroll to explore',
      selected: 'Selected work',
      playyyRole: 'AI image generation / product engineering',
      playyyBody:
        'A brand-aware creative workspace for teams that need more than another prompt box.',
      atypicaRole: 'Multi-agent research / full-stack engineering',
      atypicaBody:
        'A commercial research system where planning, testing, insight and creation work as one agent team.',
      aixcutRole: 'AI video editing / agent experience',
      aixcutBody:
        'An editing agent built to remove the repetitive timeline work between an idea and a finished cut.',
      visit: 'Visit project',
      personal: 'Outside the prompt',
      personalBody:
        'Architecture, photography, piano and the small visual decisions that make software feel human.',
      journalTitle: 'Notes from building',
      journalBody: 'No content cards. Just the latest useful things I learned while shipping.',
      essays: 'Essays',
      notes: 'Notes',
      openSource: 'Open source',
      sourceBody:
        'Learning in public, from agent harnesses to language models rebuilt from scratch.',
      finale: 'Have something difficult in mind?',
      finaleBody: 'Send the unfinished version. That is usually where the interesting work starts.',
      talk: 'Start a conversation',
      replay: 'Replay entrance',
      copyright: 'Built by Joye, with code and a camera.'
    }
  : {
      work: '作品',
      journal: '写作',
      about: '关于',
      contact: '联系',
      role: 'AI Agent 与产品工程师',
      intro: '让智能产品变得具体、可用、可感知。',
      location: '墨尔本 · 上海 · 远程',
      explore: '向下探索',
      selected: '代表作品',
      playyyRole: 'AI 图像生成 / 产品工程',
      playyyBody: '为真实创意团队打造的品牌感知工作台——不只是另一个 Prompt 输入框。',
      atypicaRole: '多智能体研究 / 全栈工程',
      atypicaBody: '让规划、测试、洞察与创作协同工作的商业研究 Agent 系统。',
      aixcutRole: 'AI 视频剪辑 / Agent 体验',
      aixcutBody: '减少想法与成片之间重复时间线劳动的智能剪辑 Agent。',
      visit: '访问项目',
      personal: 'Prompt 之外',
      personalBody: '建筑、摄影、钢琴，以及那些让软件重新有人味的细小视觉决定。',
      journalTitle: '来自开发现场',
      journalBody: '不再堆内容卡片，只留下最近真正有用的文章与笔记。',
      essays: '文章',
      notes: '笔记',
      openSource: '开源',
      sourceBody: '公开学习：从 Agent Harness 到从零重建语言模型。',
      finale: '有个难题？',
      finaleBody: '把还没整理好的版本发来。最有意思的合作通常从那里开始。',
      talk: '聊聊看',
      replay: '重播入场',
      copyright: 'Joye 用代码与相机完成。'
    }

const totalStars = repos.reduce((sum, repo) => sum + repo.stars, 0)
---

<IntroOverlay locale={locale} />

<visual-home class='visual-home'>
  <nav class='reel-nav' aria-label={isEn ? 'Primary navigation' : '主导航'}>
    <a class='reel-nav__brand' href={prefix || '/'}>Joye Huang</a>
    <div class='reel-nav__links'>
      <a href='#work'>{copy.work}</a>
      <a href='#journal'>{copy.journal}</a>
      <a href={`${prefix}/about`}>{copy.about}</a>
    </div>
    <div class='reel-nav__end'>
      <a href={isEn ? '/' : '/en'}>{isEn ? '中文' : 'EN'}</a>
      <a href={`${prefix}/contact`}>{copy.contact} ↗</a>
    </div>
  </nav>

  <main>
    <section class='cover' id='top' data-cover>
      <div class='cover__media' data-cover-media>
        <img
          src='/images/landing/aixcut-video-still.jpg'
          alt={isEn ? 'AIXCut AI video-editing visual' : 'AIXCut AI 视频剪辑视觉'}
        />
      </div>
      <div class='cover__veil'></div>
      <div class='cover__topline'>
        <span>PORTFOLIO / 2026</span>
        <span>{copy.location}</span>
      </div>
      <div class='cover__identity'>
        <div class='cover__portrait'>
          <Image
            src={avatar}
            alt={isEn ? 'Portrait of Joye' : 'Joye 的头像'}
            data-intro-target='avatar'
            loading='eager'
          />
        </div>
        <p>{copy.role}</p>
      </div>
      <div class='cover__title'>
        <h1>Joye Huang</h1>
        <p>{copy.intro}</p>
      </div>
      <a class='cover__scroll' href='#work'><span></span>{copy.explore}</a>
    </section>

    <section class='work-index' id='work'>
      <div class='work-index__header'>
        <p>01 — 03</p>
        <h2>{copy.selected}</h2>
        <p>2025 — 2026</p>
      </div>
    </section>

    <section class='project-reel project-reel--playyy' data-project-reel>
      <div class='project-reel__sticky'>
        <div class='project-reel__copy'>
          <span>01</span>
          <p>{copy.playyyRole}</p>
          <h2>Playyy</h2>
          <p class='project-reel__body'>{copy.playyyBody}</p>
          <a href='https://playyy.ai/' target='_blank' rel='noopener noreferrer'>{copy.visit} ↗</a>
        </div>
        <div class='project-reel__media project-reel__media--playyy'>
          <Image src={architectureLight} width={1400} alt='' class='project-reel__backdrop' />
          <figure class='browser-frame'>
            <div class='browser-frame__bar'><i></i><i></i><i></i><span>playyy.ai</span></div>
            <img src='/images/landing/playyy-ui.png' alt='Playyy product interface' />
          </figure>
        </div>
      </div>
    </section>

    <section class='project-reel project-reel--atypica' data-project-reel>
      <div class='project-reel__sticky'>
        <div class='project-reel__copy'>
          <span>02</span>
          <p>{copy.atypicaRole}</p>
          <h2>atypica</h2>
          <p class='project-reel__body'>{copy.atypicaBody}</p>
          <a href='https://atypica.ai/' target='_blank' rel='noopener noreferrer'>{copy.visit} ↗</a
          >
        </div>
        <div class='project-reel__media project-reel__media--atypica'>
          <img
            class='atypica-research'
            src='/images/landing/atypica-video-still-15.jpg'
            alt='Consumer research signals visualized by atypica'
          />
          <img
            class='atypica-poster'
            src='/images/landing/atypica-poster.jpg'
            alt='atypica multi-agent research system'
          />
        </div>
      </div>
    </section>

    <section class='project-reel project-reel--aixcut' data-project-reel>
      <div class='project-reel__sticky'>
        <div class='project-reel__copy'>
          <span>03</span>
          <p>{copy.aixcutRole}</p>
          <h2>AIXCut</h2>
          <p class='project-reel__body'>{copy.aixcutBody}</p>
          <a href='https://aixcut.cn/' target='_blank' rel='noopener noreferrer'>{copy.visit} ↗</a>
        </div>
        <div class='project-reel__media project-reel__media--aixcut'>
          <img
            class='aixcut-editor'
            src='/images/landing/aixcut-video-still.jpg'
            alt='AI video editing environment'
          />
          <img
            class='aixcut-result'
            src='/images/landing/aixcut-landscape.webp'
            alt='AIXCut generated landscape'
          />
          <span class='aixcut-caption'>RAW TIMELINE → FINISHED FRAME</span>
        </div>
      </div>
    </section>

    <section class='personal-reel' id='about' data-personal-reel>
      <div class='personal-reel__sticky'>
        <div class='personal-reel__heading'>
          <span>04 / PERSONAL</span>
          <h2>{copy.personal}</h2>
          <p>{copy.personalBody}</p>
        </div>
        <div class='personal-reel__viewport'>
          <div class='personal-reel__track' data-gallery-track>
            <figure>
              <Image src={architectureGrid} width={900} alt='Architectural rhythm' /><figcaption>
                RHYTHM
              </figcaption>
            </figure>
            <figure>
              <Image src={flowers} width={900} alt='White hydrangea flowers' /><figcaption>
                DETAIL
              </figcaption>
            </figure>
            <figure>
              <Image src={interior} width={900} alt='Quiet interior' /><figcaption>
                LIGHT
              </figcaption>
            </figure>
            <figure>
              <Image
                src={architectureLight}
                width={900}
                alt='White architectural curves'
              /><figcaption>SPACE</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <section class='journal' id='journal'>
      <div class='journal__intro'>
        <span>05 / JOURNAL</span>
        <h2>{copy.journalTitle}</h2>
        <p>{copy.journalBody}</p>
      </div>
      <div class='journal__columns'>
        <div class='journal__column'>
          <header><span>{copy.essays}</span><span>{posts.length}</span></header>
          {
            posts.slice(0, 4).map((post) => (
              <a href={post.href}>
                <>
                  <span>{post.meta}</span>
                  <h3>{post.title}</h3>
                  <i>↗</i>
                </>
              </a>
            ))
          }
        </div>
        <div class='journal__column'>
          <header><span>{copy.notes}</span><span>{notes.length}</span></header>
          {
            notes.slice(0, 4).map((note) => (
              <a href={note.href}>
                <>
                  <span>{note.kind}</span>
                  <h3>{note.title}</h3>
                  <i>↗</i>
                </>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class='source'>
      <div class='source__image'>
        <img
          src='/talks/2026-from-interview-to-agent/engineering-scope.png'
          alt={isEn ? 'Agent engineering system diagram' : 'Agent 工程系统图'}
        />
      </div>
      <div class='source__copy'>
        <span>06 / SOURCE</span>
        <h2>{copy.openSource}</h2>
        <p>{copy.sourceBody}</p>
        <strong>{totalStars}+ GitHub Stars</strong>
        <ul>
          {
            repos.map((repo) => (
              <li>
                <a
                  href={`https://github.com/joyehuang/${repo.name}`}
                  target='_blank'
                  rel='noopener noreferrer'
                >
                  <>
                    <span>{repo.name}</span>
                    <span>★ {repo.stars} ↗</span>
                  </>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class='finale'>
      <Image src={flowers} width={1600} alt='' class='finale__image' />
      <div class='finale__veil'></div>
      <div class='finale__copy'>
        <h2>{copy.finale}</h2>
        <p>{copy.finaleBody}</p>
        <div>
          <a href={`${prefix}/contact`}>{copy.talk} ↗</a>
          <button type='button' data-replay-intro>{copy.replay} ↻</button>
        </div>
      </div>
      <footer>
        <span>© {new Date().getFullYear()} JOYE HUANG</span><span>{copy.copyright}</span><a
          href='#top'>TOP ↑</a
        >
      </footer>
    </section>
  </main>

  <div id='home-jojo' class='home-jojo'><JoJo client:load size='md' quipPool='idle' /></div>
</visual-home>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  class VisualHome extends HTMLElement {
    private context?: gsap.Context
    private cleanups: Array<() => void> = []

    connectedCallback() {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

      this.context = gsap.context(() => {
        if (reduced) return

        const cover = this.querySelector<HTMLElement>('[data-cover]')
        const coverMedia = this.querySelector<HTMLElement>('[data-cover-media]')
        if (cover && coverMedia) {
          gsap.fromTo(coverMedia, { scale: 1.08 }, { scale: 1, duration: 1.6, ease: 'power3.out' })
          gsap.to(coverMedia, {
            yPercent: 14,
            scale: 1.08,
            ease: 'none',
            scrollTrigger: { trigger: cover, start: 'top top', end: 'bottom top', scrub: 0.7 }
          })
          gsap.from('.cover__title, .cover__identity, .cover__topline', {
            opacity: 0,
            y: 24,
            duration: 1,
            stagger: 0.1,
            delay: 0.25,
            ease: 'power3.out'
          })
        }

        this.querySelectorAll<HTMLElement>('[data-project-reel]').forEach((section) => {
          const media = section.querySelector<HTMLElement>('.project-reel__media')
          const copy = section.querySelector<HTMLElement>('.project-reel__copy')
          if (media) {
            gsap.fromTo(
              media,
              { clipPath: 'inset(9% 9% 9% 9%)', scale: 0.96 },
              {
                clipPath: 'inset(0% 0% 0% 0%)',
                scale: 1,
                ease: 'none',
                scrollTrigger: { trigger: section, start: 'top 80%', end: 'top top', scrub: 0.6 }
              }
            )
          }
          if (copy) {
            gsap.fromTo(
              copy,
              { opacity: 0.2, y: 40 },
              {
                opacity: 1,
                y: 0,
                ease: 'none',
                scrollTrigger: { trigger: section, start: 'top 75%', end: 'top 20%', scrub: 0.5 }
              }
            )
          }
        })

        const personal = this.querySelector<HTMLElement>('[data-personal-reel]')
        const galleryTrack = this.querySelector<HTMLElement>('[data-gallery-track]')
        if (personal && galleryTrack) {
          gsap.to(galleryTrack, {
            x: () => -(galleryTrack.scrollWidth - window.innerWidth + window.innerWidth * 0.14),
            ease: 'none',
            scrollTrigger: { trigger: personal, start: 'top top', end: 'bottom bottom', scrub: 0.7 }
          })
        }

        gsap.utils
          .toArray<HTMLElement>('.journal__intro, .journal__column, .source__copy')
          .forEach((element) => {
            gsap.from(element, {
              opacity: 0,
              y: 42,
              duration: 0.9,
              ease: 'power3.out',
              scrollTrigger: { trigger: element, start: 'top 88%', once: true }
            })
          })
      }, this)

      const replay = this.querySelector<HTMLButtonElement>('[data-replay-intro]')
      const playIntro = () => window.__joyeIntro?.play('jojo')
      replay?.addEventListener('click', playIntro)
      this.cleanups.push(() => replay?.removeEventListener('click', playIntro))
    }

    disconnectedCallback() {
      this.cleanups.forEach((cleanup) => cleanup())
      this.cleanups = []
      this.context?.revert()
    }
  }

  if (!customElements.get('visual-home')) customElements.define('visual-home', VisualHome)

  declare global {
    interface Window {
      __joyeIntro?: { play(variant: 'focus' | 'line' | 'jojo'): void }
    }
  }
</script>

<style>
  .visual-home {
    --paper: #f1efe8;
    --ink: #141414;
    --rule: rgb(20 20 20 / 18%);
    display: block;
    color: var(--ink);
    background: var(--paper);
    font-family: 'Satoshi', sans-serif;
  }

  .visual-home a {
    color: inherit;
    text-decoration: none;
  }

  .reel-nav {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 90;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 5rem;
    padding: 0 clamp(1rem, 3vw, 3rem);
    color: #fff;
    mix-blend-mode: difference;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .reel-nav__brand {
    width: fit-content;
    font-size: 0.86rem;
  }
  .reel-nav__links {
    display: flex;
    gap: 2rem;
  }
  .reel-nav__end {
    display: flex;
    justify-content: flex-end;
    gap: 1.4rem;
  }

  .cover {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    color: #fff;
    background: #090b0f;
  }
  .cover__media,
  .cover__media img,
  .cover__veil {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .cover__media {
    will-change: transform;
  }
  .cover__media img {
    object-fit: cover;
    object-position: center;
  }
  .cover__veil {
    background: linear-gradient(180deg, rgb(0 0 0 / 28%), transparent 38%, rgb(0 0 0 / 58%));
  }
  .cover__topline {
    position: absolute;
    top: 6.8rem;
    right: clamp(1rem, 3vw, 3rem);
    left: clamp(1rem, 3vw, 3rem);
    display: flex;
    justify-content: space-between;
    font-family: ui-monospace, monospace;
    font-size: 0.56rem;
    letter-spacing: 0.12em;
  }
  .cover__identity {
    position: absolute;
    top: 34%;
    left: clamp(1rem, 3vw, 3rem);
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .cover__identity p {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cover__portrait {
    width: 3.2rem;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 70%);
    border-radius: 50%;
    background: #dceaf3;
  }
  .cover__portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover__title {
    position: absolute;
    right: clamp(1rem, 3vw, 3rem);
    bottom: clamp(3rem, 6vw, 6rem);
    left: clamp(1rem, 3vw, 3rem);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .cover__title h1 {
    margin: 0;
    font-size: clamp(4.8rem, 12.5vw, 13rem);
    font-weight: 570;
    line-height: 0.7;
    letter-spacing: -0.075em;
  }
  .cover__title p {
    width: min(24rem, 28vw);
    margin: 0 0 0.6rem;
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    line-height: 1.35;
  }
  .cover__scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.62rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    transform: translateX(-50%);
  }
  .cover__scroll span {
    width: 3rem;
    height: 1px;
    background: currentColor;
  }

  .work-index {
    padding: clamp(7rem, 13vw, 12rem) clamp(1rem, 3vw, 3rem);
  }
  .work-index__header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
  }
  .work-index h2 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 530;
    letter-spacing: -0.055em;
  }
  .work-index p {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
  }
  .work-index p:last-child {
    text-align: right;
  }

  .project-reel {
    position: relative;
    height: 165vh;
  }
  .project-reel__sticky {
    position: sticky;
    top: 0;
    display: grid;
    grid-template-columns: minmax(18rem, 28vw) 1fr;
    height: 100svh;
    overflow: hidden;
  }
  .project-reel__copy {
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5.5rem clamp(1rem, 3vw, 3rem) 3rem;
    background: var(--paper);
  }
  .project-reel__copy > span,
  .project-reel__copy > p:first-of-type {
    font-family: ui-monospace, monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .project-reel__copy > span {
    margin-bottom: auto;
  }
  .project-reel__copy h2 {
    margin: 0 0 1rem;
    font-size: clamp(3.2rem, 6vw, 6.8rem);
    font-weight: 560;
    line-height: 0.82;
    letter-spacing: -0.065em;
  }
  .project-reel__body {
    margin: 0 0 2rem;
    font-size: 1rem;
    line-height: 1.45;
  }
  .project-reel__copy a {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--rule);
    padding-top: 0.85rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .project-reel__media {
    position: relative;
    overflow: hidden;
    will-change: clip-path, transform;
  }
  .project-reel__backdrop,
  .project-reel__backdrop :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .project-reel__media--playyy {
    display: grid;
    place-items: center;
    background: #e4e1d8;
  }
  .project-reel__backdrop {
    position: absolute;
    inset: 0;
    opacity: 0.72;
    filter: contrast(0.94);
  }
  .browser-frame {
    position: relative;
    width: min(78%, 64rem);
    margin: 0;
    overflow: hidden;
    border-radius: 0.8rem;
    background: #050505;
    box-shadow: 0 2.5rem 7rem rgb(33 27 22 / 28%);
    transform: rotate(-2deg);
  }
  .browser-frame__bar {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    height: 2.6rem;
    padding: 0 0.9rem;
