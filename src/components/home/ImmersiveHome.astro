---
import { Image } from 'astro:assets'
import avatar from 'src/assets/avatar.png'

import '@fontsource-variable/geist'

import IntroOverlay from '@/components/intro/IntroOverlay.astro'
import JoJo from '@/components/mascot/JoJo'

type FeedItem = {
  title: string
  href: string
  meta: string
  kind: string
}

type RepoItem = {
  name: string
  description: string
  stars: number
  href?: string
  eyebrow?: string
  image?: string
  imageAlt?: string
}

type ProductItem = {
  index: string
  key: string
  title: string
  role: string
  body: string
  metrics: string[][]
  href: string
  image: string
  imageLight: string
  alt: string
  domain: string
  accent: string
  embeddable: boolean
}

interface Props {
  locale: 'zh' | 'en'
  posts: FeedItem[]
  notes: FeedItem[]
  repos: RepoItem[]
}

const { locale, posts, notes, repos } = Astro.props
const isEn = locale === 'en'
const prefix = isEn ? '/en' : ''

const copy = isEn
  ? {
      work: 'Work',
      journal: 'Journal',
      about: 'Practice',
      contact: 'Contact',
      role: 'AI agent & product engineer',
      intro: 'I take AI agents from promising demos to products that hold up in real workflows.',
      location: 'Melbourne · Shanghai · Remote',
      explore: 'Enter the work',
      selected: 'I do more than build the interface. I make the AI product work.',
      selectedBody:
        'From workflow modelling and agent behaviour to full-stack delivery, these are three products I helped move toward real users.',
      visit: 'Visit product',
      livePreview: 'Live preview',
      staticPreview: 'Back to overview',
      openLive: 'Open live site',
      evidence: 'Turn experience into methods others can use.',
      evidenceBody:
        'I break complex engineering work into talks, diagrams, and public notes—not just to present an answer, but to expose a process that others can test, discuss, and reuse.',
      evidenceCta: 'Open the full talk',
      journalTitle: 'Writing & Notes',
      journalBody:
        'Long-form essays and compact research notes from the things I am building and learning.',
      essays: 'Essays',
      notes: 'Notes',
      openSource: 'Open source & upstream work',
      sourceBody: 'Original projects and contributions to products maintained by other builders.',
      finale: 'Let’s put AI into a real product.',
      finaleBody:
        'I’m open to AI agent and full-stack product engineering opportunities. Ask for my résumé, dig into a project, or tell me what your team is trying to ship.',
      context: 'Team',
      constraint: 'Hard part',
      outcome: 'Role',
      contextValue: 'What is your team building?',
      constraintValue: 'What is hardest to move forward?',
      outcomeValue: 'What should this engineer deliver?',
      ready: 'See if we fit',
      talk: 'Ask for my résumé',
      replay: 'Replay entrance',
      copyright: 'Designed and engineered by Joye.'
    }
  : {
      work: '作品',
      journal: '写作',
      about: '方法',
      contact: '联系',
      role: 'AI Agent 产品工程师 · 全栈研发',
      intro: '把 AI Agent 从 Demo 推进到真实业务：能运行、能交付，也有人愿意用。',
      location: '墨尔本 · 上海 · 远程',
      explore: '进入作品',
      selected: '我负责的不只是界面，而是让 AI 产品真正跑起来。',
      selectedBody:
        '从工作流建模、Agent 行为到全栈交付，下面是我参与推进到真实用户面前的三个产品。',
      visit: '访问产品',
      livePreview: '在线预览',
      staticPreview: '返回概览',
      openLive: '打开官网',
      evidence: '把经验拆成别人也能用的方法。',
      evidenceBody:
        '我把复杂工程拆成讲稿、图解和公开笔记：不是展示答案，而是留下可以验证、讨论和复用的过程。',
      evidenceCta: '查看完整演讲',
      journalTitle: '博客与 Notes',
      journalBody: '长文章记录完整思考，Notes 留下正在研究和实践中的小结。',
      essays: '文章',
      notes: '笔记',
      openSource: '开源与上游贡献',
      sourceBody: '既从零做自己的项目，也把改进提交到其他开发者维护的产品里。',
      finale: '一起把 AI 做进真实产品。',
      finaleBody:
        '我正在寻找 AI Agent / 全栈产品工程方向的机会。想看简历、深入了解项目，或聊聊你的团队正在交付什么，欢迎联系。',
      context: '团队',
      constraint: '难点',
      outcome: '角色',
      contextValue: '你的团队正在做什么？',
      constraintValue: '现在最难推进的是什么？',
      outcomeValue: '希望这个角色交付什么？',
      ready: '看看我们是否匹配',
      talk: '索取简历 / 联系我',
      replay: '重播入场',
      copyright: 'Joye 设计与开发。'
    }

const projects: ProductItem[] = isEn
  ? [
      {
        index: '01',
        key: 'playyy',
        title: 'Playyy',
        role: 'Brand-aware AI image workspace',
        body: 'A creative environment that keeps brand context, generation, and iteration in one product surface.',
        metrics: [
          ['10+', 'AI creation tools'],
          ['4K', 'export ready'],
          ['02', 'frontier image models']
        ],
        href: 'https://playyy.ai/',
        image: '/images/landing/playyy-ui.png',
        imageLight: '/images/landing/playyy-ui-light.webp',
        alt: 'Playyy product interface from the public website',
        domain: 'playyy.ai',
        accent: '#659eb9',
        embeddable: true
      },
      {
        index: '02',
        key: 'atypica',
        title: 'atypica',
        role: 'Commercial research multi-agent system',
        body: 'At Tezign, I worked on a commercial-research agent workflow spanning clarification, persona interviews, memory, and resilient asynchronous tool execution.',
        metrics: [
          ['300K', 'AI personas'],
          ['1M+', 'interviews'],
          ['<30m', 'per research']
        ],
        href: 'https://atypica.ai/',
        image: '/images/landing/atypica-site.png',
        imageLight: '/images/landing/atypica-site-light.webp',
        alt: 'Atypica public website showing the research agent interface',
        domain: 'atypica.ai',
        accent: '#69c978',
        embeddable: false
      },
      {
        index: '03',
        key: 'aixcut',
        title: 'AIXCut',
        role: 'Agent-assisted video editing',
        body: 'I worked across the product and full-stack workflow that helps an editing agent shape scripts, organise source footage, and move toward a deliverable cut.',
        metrics: [
          ['03', 'workflow stages'],
          ['01', 'continuous agent loop'],
          ['FULL', 'stack delivery']
        ],
        href: 'https://aixcut.cn/',
        image: '/images/landing/aixcut-site.png',
        imageLight: '/images/landing/aixcut-site-light.webp',
        alt: 'AIXCut public website showing the video editing product',
        domain: 'aixcut.cn',
        accent: '#50d8b1',
        embeddable: false
      }
    ]
  : [
      {
        index: '01',
        key: 'playyy',
        title: 'Playyy',
        role: '品牌感知的 AI 图像工作台',
        body: '在 Adastra Labs 参与品牌感知 AI 图像工作台的产品与工程研发，把品牌上下文、生成与迭代放进同一个创作界面。',
        metrics: [
          ['10+', 'AI 创作工具'],
          ['4K', '高清输出'],
          ['02', '前沿图像模型']
        ],
        href: 'https://playyy.ai/',
        image: '/images/landing/playyy-ui.png',
        imageLight: '/images/landing/playyy-ui-light.webp',
        alt: 'Playyy 官网公开的产品界面',
        domain: 'playyy.ai',
        accent: '#659eb9',
        embeddable: true
      },
      {
        index: '02',
        key: 'atypica',
        title: 'atypica',
        role: '商业研究多智能体系统',
        body: '在 Tezign AIGC 研发团队参与商业研究 Multi-Agent，覆盖澄清式反问、Persona 访谈、分层记忆与异步工具调用。',
        metrics: [
          ['300K', 'AI Personas'],
          ['1M+', '完成访谈'],
          ['<30m', '单次研究']
        ],
        href: 'https://atypica.ai/',
        image: '/images/landing/atypica-site.png',
        imageLight: '/images/landing/atypica-site-light.webp',
        alt: 'Atypica 官网展示的研究 Agent 产品界面',
        domain: 'atypica.ai',
        accent: '#69c978',
        embeddable: false
      },
      {
        index: '03',
        key: 'aixcut',
        title: 'AIXCut',
        role: 'Agent 辅助视频剪辑',
        body: '参与 Agent 辅助视频剪辑产品与全栈流程，把脚本塑形、素材组织和剪辑定位推进到可交付的成片工作流。',
        metrics: [
          ['03', '核心流程阶段'],
          ['01', '连续 Agent 闭环'],
          ['FULL', '全栈交付']
        ],
        href: 'https://aixcut.cn/',
        image: '/images/landing/aixcut-site.png',
        imageLight: '/images/landing/aixcut-site-light.webp',
        alt: 'AIXCut 官网展示的视频剪辑产品界面',
        domain: 'aixcut.cn',
        accent: '#50d8b1',
        embeddable: false
      }
    ]

const evidence = isEn
  ? [
      {
        label: 'Talk / Engineering scope',
        title: 'What agent engineering actually contains',
        summary:
          'Map the real boundary from prompt and context to harnesses, loops, and production behaviour.',
        image: '/talks/2026-from-interview-to-agent/engineering-scope.png'
      },
      {
        label: 'Method / Growth loop',
        title: 'A repeatable loop from interview to production',
        summary:
          'Make projects, judgement, and failed paths visible so learning becomes testable and repeatable.',
        image: '/talks/2026-from-interview-to-agent/growth-loop.png'
      },
      {
        label: 'Practice / Agent legwork',
        title: 'The unglamorous work behind reliable agents',
        summary:
          'Give repetitive information work to an agent and reserve human attention for judgement and craft.',
        image: '/talks/2026-from-interview-to-agent/agent-legwork.png'
      }
    ]
  : [
      {
        label: '分享 / 工程边界',
        title: 'Agent 工程真正包含什么',
        summary: '从 Prompt、Context 到 Harness 与 Loop，拆清 Agent 工程真正需要负责的边界。',
        image: '/talks/2026-from-interview-to-agent/engineering-scope.png'
      },
      {
        label: '方法 / 成长回路',
        title: '从面试到生产的可重复成长路径',
        summary: '公开项目、判断与失败路径，让学习过程变得可验证，也能被下一次复用。',
        image: '/talks/2026-from-interview-to-agent/growth-loop.png'
      },
      {
        label: '实践 / Agent 苦工',
        title: '可靠 Agent 背后那些不光鲜的工作',
        summary: '让 Agent 接管重复的信息筛选，把人的注意力留给判断、创造和真正困难的问题。',
        image: '/talks/2026-from-interview-to-agent/agent-legwork.png'
      }
    ]

const capabilities = isEn
  ? [
      {
        index: '01',
        title: 'Product judgement',
        body: 'Turn an ambiguous need into a workflow with explicit users, constraints, and success criteria.'
      },
      {
        index: '02',
        title: 'Agent systems',
        body: 'Design clarification, memory, tools, retries, and state recovery as one dependable loop.'
      },
      {
        index: '03',
        title: 'Full-stack delivery',
        body: 'Carry the product from interaction and APIs through asynchronous jobs and production behaviour.'
      }
    ]
  : [
      {
        index: '01',
        title: '产品判断',
        body: '把模糊需求拆成明确的用户、约束、工作流与成功标准。'
      },
      {
        index: '02',
        title: 'Agent 系统',
        body: '把澄清、记忆、工具、重试和状态恢复设计成可靠闭环。'
      },
      {
        index: '03',
        title: '全栈交付',
        body: '从交互与 API 一直做到异步任务和生产环境中的真实行为。'
      }
    ]

const totalStars = repos.reduce((sum, repo) => sum + repo.stars, 0)
---

<IntroOverlay locale={locale} />

<visual-home class='visual-home' data-locale={locale}>
  <nav class='home-nav' aria-label={isEn ? 'Primary navigation' : '主导航'}>
    <a class='home-nav__brand' href={isEn ? '/en/v2' : '/v2'}>Joye Huang / V2</a>
    <div class='home-nav__links'>
      <a href='#work'>{copy.work}</a>
      <a href='#evidence'>{copy.about}</a>
      <a href='#journal'>{copy.journal}</a>
    </div>
    <div class='home-nav__end'>
      <button
        class='home-theme-toggle'
        type='button'
        data-theme-toggle
        aria-label={isEn ? 'Switch colour theme' : '切换深浅色主题'}
        title={isEn ? 'Switch colour theme' : '切换深浅色主题'}
      >
        <svg class='home-theme-toggle__sun' viewBox='0 0 24 24' aria-hidden='true'>
          <circle cx='12' cy='12' r='3.5'></circle>
          <path
            d='M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42'
          ></path>
        </svg>
        <svg class='home-theme-toggle__moon' viewBox='0 0 24 24' aria-hidden='true'>
          <path d='M20.2 15.5A8.5 8.5 0 0 1 8.5 3.8 8.5 8.5 0 1 0 20.2 15.5Z'></path>
        </svg>
      </button>
      <a href={isEn ? '/v2' : '/en/v2'}>{isEn ? '中文' : 'EN'}</a>
      <a href={`${prefix}/contact`}>{copy.contact} ↗</a>
    </div>
  </nav>

  <main>
    <section class='hero' id='top' data-hero>
      <div class='hero__copy'>
        <div class='hero__eyebrow'><span>{copy.role}</span><span>{copy.location}</span></div>
        <h1>Joye<br />Huang</h1>
        <p>{copy.intro}</p>
        <a href='#work'><i></i>{copy.explore}</a>
      </div>

      <div class='hero__world' aria-label={isEn ? 'Selected product interfaces' : '代表产品界面'}>
        <div class='hero__stage' data-hero-stage>
          <figure class='hero-screen hero-screen--playyy'>
            <img
              class='theme-image theme-image--light'
              src='/images/landing/playyy-ui-light.webp'
              alt='Playyy product interface'
              loading='eager'
            />
            <img
              class='theme-image theme-image--dark'
              src='/images/landing/playyy-ui.png'
              alt='Playyy product interface'
              loading='eager'
            />
            <figcaption>01 / PLAYYY</figcaption>
          </figure>
          <figure class='hero-screen hero-screen--atypica'>
            <img
              class='theme-image theme-image--light'
              src='/images/landing/atypica-site-light.webp'
              alt='atypica public product page'
              loading='eager'
            />
            <img
              class='theme-image theme-image--dark'
              src='/images/landing/atypica-site.png'
              alt='atypica public product page'
              loading='eager'
            />
            <figcaption>02 / ATYPICA</figcaption>
          </figure>
          <figure class='hero-screen hero-screen--aixcut'>
            <img
              class='theme-image theme-image--light'
              src='/images/landing/aixcut-site-light.webp'
              alt='AIXCut public product page'
              loading='eager'
            />
            <img
              class='theme-image theme-image--dark'
              src='/images/landing/aixcut-site.png'
              alt='AIXCut public product page'
              loading='eager'
            />
            <figcaption>03 / AIXCUT</figcaption>
          </figure>
        </div>
      </div>

      <div class='hero__portrait'>
        <Image
          src={avatar}
          alt={isEn ? 'Portrait of Joye' : 'Joye 的头像'}
          data-intro-target='avatar'
        />
      </div>
      <span class='hero__index'>PORTFOLIO / 2026</span>
    </section>

    <section class='work-intro' id='work'>
      <span>01—03 / PRODUCTS</span>
      <h2>{copy.selected}</h2>
      <p>{copy.selectedBody}</p>
      <div class='work-intro__capabilities' data-reveal>
        {
          capabilities.map((item) => (
            <article>
              <span>{item.index}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    {
      projects.map((project, index) => (
        <section
          class:list={['case-study', `case-study--${project.key}`]}
          style={`--case-accent:${project.accent}`}
          data-case
        >
          <div class='case-study__sticky'>
            <div class='case-study__copy' data-case-copy>
              <span>{project.index} / 2025—26</span>
              <h2>{project.title}</h2>
              <strong>{project.role}</strong>
              <p>{project.body}</p>
              <dl class='case-study__metrics'>
                {project.metrics.map(([value, label]) => (
                  <div>
                    <dt>{value}</dt>
                    <dd>{label}</dd>
                  </div>
                ))}
              </dl>
              <a href={project.href} target='_blank' rel='noopener noreferrer'>
                {copy.visit} ↗
              </a>
            </div>

            <div class='case-study__scene' data-case-scene>
              <div class='case-study__halo' aria-hidden='true' />
              <figure class='product-plane' data-case-screen>
                <div class='product-plane__bar'>
                  <span>
                    <>
                      <i />
                      <i />
                      <i />
                    </>
                  </span>
                  <em>{project.domain}</em>
                  <div class='product-plane__actions'>
                    {project.embeddable ? (
                      <button
                        type='button'
                        data-live-toggle
                        aria-pressed='false'
                        aria-label={copy.livePreview}
                      >
                        <span data-preview-label='static'>{copy.livePreview}</span>
                        <span data-preview-label='live'>{copy.staticPreview}</span>
                      </button>
                    ) : (
                      <a href={project.href} target='_blank' rel='noopener noreferrer'>
                        {copy.openLive} ↗
                      </a>
                    )}
                    <b>0{index + 1}</b>
                  </div>
                </div>
                <div class='product-plane__viewport'>
                  <img
                    class='theme-image theme-image--light'
                    src={project.imageLight}
                    alt={project.alt}
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                  <img
                    class='theme-image theme-image--dark'
                    src={project.image}
                    alt={project.alt}
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                  {project.embeddable && (
                    <iframe
                      title={`${project.title} live landing page`}
                      data-live-frame
                      data-src={project.href}
                      aria-hidden='true'
                      tabindex='-1'
                      inert
                      loading='lazy'
                      sandbox='allow-scripts allow-same-origin allow-forms allow-popups'
                      referrerpolicy='strict-origin-when-cross-origin'
                    />
                  )}
                </div>
              </figure>
              <aside class='case-study__depth' data-depth-card>
                <span>SYSTEM LAYER</span>
                <strong>{project.role}</strong>
                <i>{project.index}</i>
              </aside>
            </div>
          </div>
        </section>
      ))
    }

    <section class='evidence' id='evidence' data-evidence>
      <div class='evidence__sticky'>
        <div class='evidence__copy'>
          <header>
            <span>04 / PUBLIC THINKING</span>
            <h2>{copy.evidence}</h2>
            <p>{copy.evidenceBody}</p>
            <a href='/talks'>{copy.evidenceCta} ↗</a>
          </header>

          <ol class='evidence__index' aria-label={isEn ? 'Talk chapters' : '演讲章节'}>
            {
              evidence.map((item, index) => (
                <li data-evidence-index>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <div>
                    <strong>{item.title}</strong>
                    <p>{item.summary}</p>
                  </div>
                  <i data-evidence-index-line />
                </li>
              ))
            }
          </ol>
        </div>

        <div class='evidence__scene' data-evidence-scene>
          {
            evidence.map((item, index) => (
              <figure class={`evidence-card evidence-card--${index + 1}`} data-evidence-card>
                <img src={item.image} alt={item.title} loading='lazy' />
                <figcaption>
                  <span>
                    {String(index + 1).padStart(2, '0')} /{' '}
                    {String(evidence.length).padStart(2, '0')} · {item.label}
                  </span>
                  <strong>{item.title}</strong>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <section class='journal' id='journal'>
      <header class='journal__intro' data-reveal>
        <span>05 / JOURNAL</span>
        <h2>{copy.journalTitle}</h2>
        <p>{copy.journalBody}</p>
      </header>
      <div class='journal__columns'>
        <section class='journal__column' data-reveal>
          <div>
            <span>{copy.essays}</span><strong>{posts.length.toString().padStart(2, '0')}</strong>
          </div>
          {
            posts.slice(0, 4).map((post) => (
              <a href={post.href}>
                <>
                  <span>{post.meta}</span>
                  <h3>{post.title}</h3>
                  <i>↗</i>
                </>
              </a>
            ))
          }
        </section>
        <section class='journal__column' data-reveal>
          <div>
            <span>{copy.notes}</span><strong>{notes.length.toString().padStart(2, '0')}</strong>
          </div>
          {
            notes.slice(0, 4).map((note) => (
              <a href={note.href}>
                <>
                  <span>{note.meta}</span>
                  <h3>{note.title}</h3>
                  <i>↗</i>
                </>
              </a>
            ))
          }
        </section>
      </div>
    </section>

    <section class='source' data-reveal>
      <header class='source__copy'>
        <span>06 / SOURCE</span>
        <h2>{copy.openSource}</h2>
        <p>{copy.sourceBody}</p>
        <strong>{totalStars}+ GitHub Stars</strong>
      </header>
      <div class='source__repos'>
        {
          repos.slice(0, 3).map((repo, index) => (
            <a
              class='repo-card'
              href={repo.href ?? `https://github.com/joyehuang/${repo.name}`}
              target='_blank'
              rel='noopener noreferrer'
            >
              <span>{repo.eyebrow ?? (isEn ? 'Original project' : '独立项目')}</span>
              {repo.image && (
                <figure class='repo-card__visual'>
                  <img src={repo.image} alt={repo.imageAlt ?? repo.name} loading='lazy' />
                </figure>
              )}
              <div>
                <i>0{index + 1}</i>
                <strong>{repo.name}</strong>
              </div>
              <p>{repo.description}</p>
              <footer>
                <>
                  <span>★ {repo.stars}</span>
                  <em>GitHub ↗</em>
                </>
              </footer>
            </a>
          ))
        }
      </div>
    </section>

    <section class='finale' data-finale>
      <div class='finale__copy'>
        <span>07 / OPEN TO OPPORTUNITIES</span>
        <h2>{copy.finale}</h2>
        <p>{copy.finaleBody}</p>
        <div>
          <a href={`${prefix}/contact`}>{copy.talk} ↗</a>
          <button type='button' data-replay-intro>{copy.replay} ↻</button>
        </div>
      </div>

      <div
        class='problem-portal'
        data-problem-portal
        aria-label={isEn ? 'Brief structure' : 'Brief 结构'}
      >
        <div class='problem-card problem-card--context' data-problem-layer>
          <span>01 / {copy.context}</span><p>{copy.contextValue}</p>
        </div>
        <div class='problem-card problem-card--constraint' data-problem-layer>
          <span>02 / {copy.constraint}</span><p>{copy.constraintValue}</p>
        </div>
        <div class='problem-card problem-card--outcome' data-problem-layer>
          <span>03 / {copy.outcome}</span><p>{copy.outcomeValue}</p>
        </div>
        <div class='problem-card problem-card--ready' data-solution>
          <i></i><strong>{copy.ready}</strong><span>JOYE / 2026</span>
        </div>
      </div>

      <footer>
        <span>© {new Date().getFullYear()} JOYE HUANG</span>
        <span>{copy.copyright}</span>
        <a href='#top'>TOP ↑</a>
      </footer>
    </section>
  </main>

  <div id='home-jojo' class='home-jojo'><JoJo client:load size='md' quipPool='idle' /></div>
</visual-home>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  class VisualHome extends HTMLElement {
    private context?: gsap.Context
    private cleanups: Array<() => void> = []

    connectedCallback() {
      if (this.context) return

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const compact = window.matchMedia('(max-width: 600px)').matches

      this.context = gsap.context(() => {
        if (reduced) return

        const hero = this.querySelector<HTMLElement>('[data-hero]')
        const heroStage = this.querySelector<HTMLElement>('[data-hero-stage]')
        const heroScreens = this.querySelectorAll<HTMLElement>('.hero-screen')

        gsap
          .timeline({ defaults: { ease: 'power3.out' } })
          .from('.hero__eyebrow, .hero__copy h1, .hero__copy > p, .hero__copy > a', {
            opacity: 0,
            y: 28,
            duration: 0.9,
            stagger: 0.08
          })
          .from(
            heroScreens,
            {
              opacity: 0,
              z: -700,
              rotationY: 28,
              duration: 1.35,
              stagger: 0.12
            },
            0.12
          )
          .from(
            '.hero__portrait',
            { opacity: 0, scale: 0.72, y: -18, duration: 0.9, ease: 'back.out(1.2)' },
            0.32
          )

        if (hero && heroStage) {
          gsap.to(heroStage, {
            rotationX: -12,
            rotationY: 8,
            z: -320,
            yPercent: 20,
            ease: 'none',
            scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 1.1 }
          })

          const toX = gsap.quickTo(heroStage, 'rotationY', { duration: 0.8, ease: 'power3.out' })
          const toY = gsap.quickTo(heroStage, 'rotationX', { duration: 0.8, ease: 'power3.out' })
          const move = (event: PointerEvent) => {
            const rect = hero.getBoundingClientRect()
            if (rect.bottom < 0) return
            toX(((event.clientX - rect.width / 2) / rect.width) * 10)
            toY(((event.clientY - rect.height / 2) / rect.height) * -7)
          }
          hero.addEventListener('pointermove', move)
          this.cleanups.push(() => hero.removeEventListener('pointermove', move))
        }

        this.querySelectorAll<HTMLElement>('[data-case]').forEach((section) => {
          const screen = section.querySelector<HTMLElement>('[data-case-screen]')
          const copy = section.querySelector<HTMLElement>('[data-case-copy]')
          const depth = section.querySelector<HTMLElement>('[data-depth-card]')
          if (!screen || !copy || !depth) return

          if (compact) {
            gsap.from(screen, {
              opacity: 0,
              y: 32,
              scale: 0.94,
              rotationX: 8,
              duration: 0.85,
              ease: 'power3.out',
              scrollTrigger: { trigger: section, start: 'top 72%', once: true }
            })
            gsap.from(copy, {
              opacity: 0,
              y: 24,
              duration: 0.75,
              ease: 'power3.out',
              scrollTrigger: { trigger: section, start: 'top 78%', once: true }
            })
            return
          }

          const timeline = gsap.timeline({
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom bottom',
              scrub: 1.15
            }
          })

          if (section.classList.contains('case-study--playyy')) {
            timeline
              .fromTo(
                screen,
                { opacity: 0, scale: 0.78, yPercent: 18, rotationX: 15 },
                {
                  opacity: 1,
                  scale: 1,
                  yPercent: 0,
                  rotationX: 0,
                  duration: 0.56,
                  ease: 'power3.out'
                }
              )
              .fromTo(
                copy,
                { opacity: 0, y: 42 },
                { opacity: 1, y: 0, duration: 0.36, ease: 'power2.out' },
                0.1
              )
              .fromTo(
                depth,
                { opacity: 0, y: 70, scale: 0.88 },
                { opacity: 1, y: 0, scale: 1, duration: 0.4 },
                0.24
              )
          } else if (section.classList.contains('case-study--atypica')) {
            timeline
              .fromTo(
                screen,
                { opacity: 0, xPercent: -24, scale: 0.96 },
                {
                  opacity: 1,
                  xPercent: 0,
                  scale: 1,
                  duration: 0.6,
                  ease: 'expo.out'
                }
              )
              .fromTo(
                copy,
                { opacity: 0, xPercent: 14 },
                { opacity: 1, xPercent: 0, duration: 0.38, ease: 'power2.out' },
                0.12
              )
              .fromTo(
                depth,
                { opacity: 0, scale: 0.72, rotation: -5 },
                { opacity: 1, scale: 1, rotation: 0, duration: 0.42 },
                0.26
              )
          } else {
            timeline
              .fromTo(
                screen,
                { opacity: 0, xPercent: 14, clipPath: 'inset(0% 0% 0% 100% round .85rem)' },
                {
                  opacity: 1,
                  xPercent: 0,
                  clipPath: 'inset(0% 0% 0% 0% round .85rem)',
                  duration: 0.62,
                  ease: 'power3.inOut'
                }
              )
              .fromTo(
                copy,
                { opacity: 0, yPercent: -12 },
                { opacity: 1, yPercent: 0, duration: 0.36, ease: 'power2.out' },
                0.12
              )
              .fromTo(
                depth,
                { opacity: 0, scaleX: 0.3, transformOrigin: 'left center' },
                { opacity: 1, scaleX: 1, duration: 0.42 },
                0.28
              )
          }

          timeline
            .to(screen, { opacity: 0.36, scale: 0.96, duration: 0.18 }, 0.88)
            .to(copy, { opacity: 0.12, y: -24, duration: 0.16 }, 0.9)
        })

        const evidenceSection = this.querySelector<HTMLElement>('[data-evidence]')
        const evidenceCards = gsap.utils.toArray<HTMLElement>('[data-evidence-card]', this)
        const evidenceIndexItems = gsap.utils.toArray<HTMLElement>('[data-evidence-index]', this)
        const evidenceIndexLines = gsap.utils.toArray<HTMLElement>(
          '[data-evidence-index-line]',
          this
        )
        if (evidenceSection && evidenceCards.length && !compact) {
          gsap.set(evidenceCards, {
            autoAlpha: 0,
            clipPath: 'inset(0 0 0 100%)',
            filter: 'blur(0px)',
            zIndex: 0
          })
          gsap.set(evidenceCards[0], {
            autoAlpha: 1,
            clipPath: 'inset(0 0% 0 0)',
            zIndex: 1
          })
          gsap.set(evidenceIndexItems, { opacity: 0.28 })
          gsap.set(evidenceIndexItems[0], { opacity: 1 })
          gsap.set(evidenceIndexLines, { scaleX: 0 })
          gsap.set(evidenceIndexLines[0], { scaleX: 1 })

          const evidenceTimeline = gsap.timeline({
            scrollTrigger: {
              trigger: evidenceSection,
              start: 'top top',
              end: 'bottom bottom',
              scrub: 1.15
            }
          })

          evidenceTimeline.addLabel('chapterTwo', 0.35)
          evidenceTimeline
            .to(
              evidenceCards[0],
              { autoAlpha: 0.08, filter: 'blur(10px)', duration: 0.42, ease: 'power2.inOut' },
              'chapterTwo'
            )
            .set(evidenceCards[1], { zIndex: 2 }, 'chapterTwo')
            .fromTo(
              evidenceCards[1],
              { autoAlpha: 1, clipPath: 'inset(0 0 0 100%)' },
              { clipPath: 'inset(0 0 0 0%)', duration: 0.52, ease: 'power3.inOut' },
              'chapterTwo'
            )
            .to(evidenceIndexItems[0], { opacity: 0.28, duration: 0.2 }, 'chapterTwo')
            .to(evidenceIndexLines[0], { scaleX: 0, duration: 0.24 }, 'chapterTwo')
            .to(evidenceIndexItems[1], { opacity: 1, duration: 0.24 }, 'chapterTwo+=0.08')
            .to(evidenceIndexLines[1], { scaleX: 1, duration: 0.3 }, 'chapterTwo+=0.08')

          evidenceTimeline.addLabel('chapterThree', 1.08)
          evidenceTimeline
            .to(
              evidenceCards[1],
              { autoAlpha: 0.08, filter: 'blur(10px)', duration: 0.42, ease: 'power2.inOut' },
              'chapterThree'
            )
            .set(evidenceCards[2], { zIndex: 3 }, 'chapterThree')
            .fromTo(
              evidenceCards[2],
              { autoAlpha: 1, clipPath: 'inset(0 0 0 100%)' },
              { clipPath: 'inset(0 0 0 0%)', duration: 0.52, ease: 'power3.inOut' },
              'chapterThree'
            )
            .to(evidenceIndexItems[1], { opacity: 0.28, duration: 0.2 }, 'chapterThree')
            .to(evidenceIndexLines[1], { scaleX: 0, duration: 0.24 }, 'chapterThree')
            .to(evidenceIndexItems[2], { opacity: 1, duration: 0.24 }, 'chapterThree+=0.08')
            .to(evidenceIndexLines[2], { scaleX: 1, duration: 0.3 }, 'chapterThree+=0.08')
        }

        gsap.utils.toArray<HTMLElement>('[data-reveal]', this).forEach((element) => {
          gsap.from(element, {
            opacity: 0,
            y: 48,
            duration: 0.9,
            ease: 'power3.out',
            scrollTrigger: { trigger: element, start: 'top 86%', once: true }
          })
        })

        const finale = this.querySelector<HTMLElement>('[data-finale]')
        const problemLayers = gsap.utils.toArray<HTMLElement>('[data-problem-layer]', this)
        const solution = this.querySelector<HTMLElement>('[data-solution]')
        if (finale && solution && problemLayers.length && compact) {
          gsap.from(problemLayers, {
            opacity: 0,
            y: 34,
            rotationX: 8,
            duration: 0.75,
            stagger: 0.08,
            ease: 'power3.out',
            scrollTrigger: { trigger: finale, start: 'top 70%', once: true }
          })
          gsap.from(solution, {
            opacity: 0,
            scale: 0.86,
            duration: 0.7,
            ease: 'power3.out',
            scrollTrigger: { trigger: finale, start: 'top 62%', once: true }
          })
        } else if (finale && solution && problemLayers.length) {
          const problemTimeline = gsap.timeline({
            scrollTrigger: { trigger: finale, start: 'top 78%', end: 'center 44%', scrub: 1.8 }
          })
          problemTimeline
            .fromTo(
              problemLayers,
              {
                opacity: 0,
                z: -520,
                rotationY: (i) => (i - 1) * 28,
                xPercent: (i) => (i - 1) * 44
              },
              {
                opacity: 1,
                z: (i) => i * 55,
                rotationY: (i) => (i - 1) * 8,
                xPercent: (i) => (i - 1) * 13,
                stagger: 0.14,
                duration: 1.05,
                ease: 'power2.out'
              }
            )
            .fromTo(
              solution,
              { opacity: 0, scale: 0.72, z: -260 },
              { opacity: 1, scale: 1, z: 180, duration: 0.7, ease: 'power2.out' },
              0.86
            )
        }
      }, this)

      const replay = this.querySelector<HTMLButtonElement>('[data-replay-intro]')
      const playIntro = () => window.__joyeIntro?.play('jojo', 'replay')
      replay?.addEventListener('click', playIntro)
      this.cleanups.push(() => replay?.removeEventListener('click', playIntro))

      this.querySelectorAll<HTMLButtonElement>('[data-live-toggle]').forEach((button) => {
        const plane = button.closest<HTMLElement>('.product-plane')
        const frame = plane?.querySelector<HTMLIFrameElement>('[data-live-frame]')
        if (!plane || !frame) return

        const togglePreview = () => {
          const nextLive = plane.dataset.live !== 'true'
          if (nextLive && !frame.src) frame.src = frame.dataset.src ?? ''
          plane.dataset.live = String(nextLive)
          button.setAttribute('aria-pressed', String(nextLive))
          frame.toggleAttribute('inert', !nextLive)
          frame.tabIndex = nextLive ? 0 : -1
          frame.setAttribute('aria-hidden', String(!nextLive))
          const nextLabel = button.querySelector<HTMLElement>(
            `[data-preview-label='${nextLive ? 'live' : 'static'}']`
          )
          if (nextLabel?.textContent) button.setAttribute('aria-label', nextLabel.textContent)
        }

        button.addEventListener('click', togglePreview)
        this.cleanups.push(() => button.removeEventListener('click', togglePreview))
      })

      const themeToggle = this.querySelector<HTMLButtonElement>('[data-theme-toggle]')
      const syncThemeToggle = () => {
        const isDark = document.documentElement.classList.contains('dark')
        themeToggle?.setAttribute('aria-pressed', String(isDark))
        themeToggle?.setAttribute(
          'aria-label',
          this.dataset.locale === 'en'
            ? `Switch to ${isDark ? 'light' : 'dark'} mode`
            : `切换到${isDark ? '浅色' : '深色'}模式`
        )
      }
      const toggleTheme = () => {
        const root = document.documentElement
        const nextTheme = root.classList.contains('dark') ? 'light' : 'dark'
        localStorage.setItem('theme', nextTheme)
        root.classList.toggle('dark', nextTheme === 'dark')
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', nextTheme === 'dark' ? '#0B0B10' : '#FCFCFD')
        syncThemeToggle()
      }
      syncThemeToggle()
      themeToggle?.addEventListener('click', toggleTheme)
      this.cleanups.push(() => themeToggle?.removeEventListener('click', toggleTheme))

      requestAnimationFrame(() => ScrollTrigger.refresh())
    }

    disconnectedCallback() {
      this.cleanups.forEach((cleanup) => cleanup())
      this.cleanups = []
      this.context?.revert()
      this.context = undefined
    }
  }

  if (!customElements.get('visual-home')) customElements.define('visual-home', VisualHome)

  declare global {
    interface Window {
      __joyeIntro?: {
        play(variant: 'focus' | 'line' | 'jojo', trigger?: 'event' | 'replay'): void
      }
    }
  }
</script>

