---
import { Image } from 'astro:assets'
import avatar from 'src/assets/avatar.png'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import { getUiCopy, localizeHref, type Locale } from '@/i18n'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import PageLayout from '@/layouts/BaseLayout.astro'

interface Props {
  locale?: Locale
}

const { locale = 'zh' } = Astro.props
const copy = getUiCopy(locale)

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)
---

<PageLayout meta={{ title: copy.home.metaTitle }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate relative z-50 mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={avatar}
        alt={copy.home.profileAlt}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{copy.site.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title={copy.home.labels.location}>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title={copy.home.labels.sourceCode}
            as='a'
            href='https://github.com/joyehuang/blog'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <div class='flex flex-row gap-3'>
        <a
          href='https://www.linkedin.com/in/deshiouhuang/'
          target='_blank'
          class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
        >
          <span class='relative flex items-center justify-center'>
            <span
              class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
            ></span>
            <span class='size-2 rounded-full bg-green-400'></span>
          </span>
          <p class='font-medium text-muted-foreground'>{copy.home.connectMe}</p>
        </a>
      </div>
    </section>

    <div id='content' class='animate relative z-0 flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title={copy.home.sections.about}>
        <p class='text-muted-foreground'>{copy.home.role}</p>
        <p class='text-muted-foreground'>
          {copy.home.bio}
        </p>
        <Button
          title={copy.home.actions.moreAbout}
          class='w-fit self-end'
          href={localizeHref(locale, '/about')}
          style='ahead'
        />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title={copy.home.sections.posts}>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((post) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={post} />
                </li>
              ))}
            </ul>
            <Button
              title={copy.home.actions.morePosts}
              class='w-fit self-end'
              href={localizeHref(locale, '/blog')}
              style='ahead'
            />
          </Section>
        )
      }

      <Section title={copy.home.sections.experience}>
        <Card
          heading={copy.home.experience.company}
          subheading={copy.home.experience.role}
          date={copy.home.experience.date}
        >
          <ul class='ms-4 list-disc text-muted-foreground'>
            {copy.home.experience.bullets.map((item: string) => <li>{item}</li>)}
          </ul>
        </Card>
      </Section>
      <Section title={copy.home.sections.education}>
        <Card
          as='a'
          heading={copy.home.education.school}
          subheading={copy.home.education.degree}
          date={copy.home.education.date}
        />
      </Section>

      <Section title={copy.home.sections.skills}>
        <SkillLayout title={copy.home.skills.languagesTitle} skills={copy.home.skills.languages} />
        <SkillLayout title={copy.home.skills.frontendTitle} skills={copy.home.skills.frontend} />
        <SkillLayout title={copy.home.skills.backendTitle} skills={copy.home.skills.backend} />
        <SkillLayout title={copy.home.skills.toolsTitle} skills={copy.home.skills.tools} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
