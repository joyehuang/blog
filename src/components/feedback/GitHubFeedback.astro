---
interface Props {
  title: string
  source?: 'article' | 'page'
  slug?: string
}

const { title, source = 'article', slug } = Astro.props as Props

const issueUrl = new URL('https://github.com/joyehuang/blog/issues/new')
issueUrl.searchParams.set('template', '03_site_feedback.yml')
issueUrl.searchParams.set('title', `Feedback: ${title}`)
issueUrl.searchParams.set('page-url', Astro.url.toString())

const labels =
  source === 'article'
    ? {
        heading: '结构性建议或功能请求',
        body: '内容上的错漏、没看懂的地方，直接在下面评论区告诉我就好。如果你希望补充某个方向、或对文章结构/站点功能有建议，可以开一个 GitHub issue，它会进入公开的 roadmap 与 changelog 工作流。',
        action: '开一个 Issue'
      }
    : {
        heading: '对这个页面有建议？',
        body: '页面结构或功能上的改进建议，可以开一个 GitHub issue。建议会进入公开工作流，方便后续整理和跟进。',
        action: '开一个 Issue'
      }
---

<aside
  class='not-prose mt-6 rounded-lg border border-border bg-muted/40 p-4 text-sm text-muted-foreground sm:p-5'
>
  <div class='flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between'>
    <div class='space-y-1.5'>
      <h2 class='text-base font-medium text-foreground'>
        {labels.heading}
      </h2>
      <p class='leading-6'>
        {labels.body}
      </p>
    </div>
    <a
      class='inline-flex shrink-0 items-center justify-center rounded-md border border-border bg-background px-3 py-2 font-medium text-foreground transition hover:border-foreground/40 hover:bg-background/80'
      href={issueUrl.toString()}
      target='_blank'
      rel='noreferrer'
      data-analytics-event='site_feedback_click'
      data-analytics-surface={`${source}_footer`}
      data-analytics-target='github_issue'
      data-analytics-article-slug={slug ?? null}
    >
      {labels.action}
    </a>
  </div>
</aside>
