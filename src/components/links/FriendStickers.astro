---
import { Image } from 'astro:assets'

interface Friend {
  name: string
  intro: string
  link: string
  avatar: string
  since?: string
  met?: string
  note?: string
}

interface FriendList {
  id_name: string
  desc: string
  link_list: Friend[]
}

interface Props {
  list: FriendList
}

const { list } = Astro.props
const friends = list.link_list

// Cycle through three sticker shapes — polaroid / note / mini-postcard.
// Deterministic per index so order is stable across rebuilds.
const SHAPES = ['polaroid', 'note', 'mini'] as const
const TILTS = [-3.5, 2.4, -1.6, 4.1, -2.8, 1.9, 3.2, -4.0, 2.1, -1.2]
const PIN_COLORS = ['#d23a2a', '#f0b840', '#3f7bff', '#3aa86b', '#a23ad2', '#e74c8e']
const decorated = friends.map((frd, i) => ({
  frd,
  shape: SHAPES[i % SHAPES.length],
  tilt: TILTS[i % TILTS.length],
  pinColor: PIN_COLORS[i % PIN_COLORS.length]
}))
---

<section class='friend-stickers' aria-label='Friend stickers'>
  <div class='cork-board'>
    {decorated.map(({ frd, shape, tilt, pinColor }) => (
      <a
        class={`sticker sticker-${shape}`}
        href={frd.link}
        target='_blank'
        rel='noopener noreferrer'
        style={`--tilt:${tilt}deg; --pin:${pinColor}`}
      >
        <span class='sticker-pin' aria-hidden='true'></span>
        {shape === 'polaroid' && (
          <>
            <div class='polaroid-photo'>
              <Image src={frd.avatar} width={140} height={140} alt='' loading='lazy' class='m-0 h-full w-full object-cover' />
            </div>
            <div class='polaroid-caption'>
              <span class='caption-name'>{frd.name}</span>
              {frd.since && <span class='caption-date'>{frd.since}</span>}
            </div>
          </>
        )}
        {shape === 'note' && (
          <>
            <div class='note-header'>
              <div class='note-avatar'>
                <Image src={frd.avatar} width={56} height={56} alt='' loading='lazy' class='m-0 h-full w-full object-cover' />
              </div>
              <div class='note-name'>{frd.name}</div>
            </div>
            {frd.intro && <p class='note-intro'>"{frd.intro}"</p>}
            {frd.since && <p class='note-since'>—— {frd.since}</p>}
          </>
        )}
        {shape === 'mini' && (
          <>
            <div class='mini-stamp'>POSTCARD</div>
            <div class='mini-divider'></div>
            <div class='mini-body'>
              <p class='mini-name'>{frd.name}</p>
              {frd.intro && <p class='mini-intro'>{frd.intro}</p>}
            </div>
          </>
        )}
      </a>
    ))}
  </div>
</section>

<style>
  .friend-stickers {
    --board-base: #b88858;
  }

  .cork-board {
    position: relative;
    padding: 1.5rem 1rem 2rem;
    border-radius: 0.7rem;
    border: 6px solid #6e4a23;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.2),
      inset 0 0 60px rgba(0, 0, 0, 0.2),
      0 12px 30px rgba(0, 0, 0, 0.25);
    background-color: var(--board-base);
    background-image:
      radial-gradient(2px 2px at 12% 18%, rgba(80, 50, 20, 0.5) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 78% 22%, rgba(80, 50, 20, 0.4) 50%, transparent 51%),
      radial-gradient(2px 2px at 24% 80%, rgba(80, 50, 20, 0.5) 50%, transparent 51%),
      radial-gradient(1px 1px at 88% 72%, rgba(255, 230, 200, 0.3) 50%, transparent 51%),
      radial-gradient(2px 2px at 65% 92%, rgba(80, 50, 20, 0.4) 50%, transparent 51%),
      radial-gradient(1px 1px at 5% 60%, rgba(255, 230, 200, 0.25) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 95% 40%, rgba(80, 50, 20, 0.4) 50%, transparent 51%),
      radial-gradient(1px 1px at 40% 8%, rgba(80, 50, 20, 0.3) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 55% 35%, rgba(80, 50, 20, 0.35) 50%, transparent 51%),
      radial-gradient(1px 1px at 18% 50%, rgba(80, 50, 20, 0.3) 50%, transparent 51%),
      radial-gradient(2px 2px at 70% 60%, rgba(80, 50, 20, 0.4) 50%, transparent 51%),
      linear-gradient(135deg, #c5946a 0%, #a87646 100%);
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem 1.6rem;
    justify-content: center;
    align-items: flex-start;
  }

  .sticker {
    position: relative;
    text-decoration: none;
    color: inherit;
    transform: rotate(var(--tilt, 0deg));
    transition: transform 220ms ease, box-shadow 220ms ease;
    flex: 0 0 auto;
  }
  .sticker:hover {
    transform: rotate(0deg) scale(1.04);
    z-index: 5;
  }

  .sticker-pin {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    background:
      radial-gradient(circle at 35% 35%, #fff 0%, var(--pin) 30%, color-mix(in srgb, var(--pin) 70%, black) 100%);
    box-shadow:
      0 1px 1px rgba(0, 0, 0, 0.4),
      0 3px 5px rgba(0, 0, 0, 0.3);
    z-index: 2;
  }

  /* Polaroid */
  .sticker-polaroid {
    width: 180px;
    background: #fdfaf2;
    padding: 10px 10px 0;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.15),
      0 12px 28px rgba(0, 0, 0, 0.35);
  }
  .polaroid-photo {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: #ddd;
  }
  .polaroid-caption {
    padding: 0.55rem 0.4rem 0.7rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    color: #2a2a2a;
  }
  .caption-name {
    font-family: 'Apple Chancery', 'Brush Script MT', cursive;
    font-size: 1.05rem;
  }
  .caption-date {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.65rem;
    color: #777;
  }

  /* Sticky note */
  .sticker-note {
    width: 200px;
    min-height: 130px;
    padding: 1rem 0.85rem 0.85rem;
    background: linear-gradient(180deg, #fff5a8 0%, #f0e07a 100%);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 8px 18px rgba(80, 60, 0, 0.25);
    color: #3a2f10;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .note-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .note-avatar {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    overflow: hidden;
    border: 2px solid #fff;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
    flex: 0 0 auto;
  }
  .note-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: #2a1f08;
  }
  .note-intro {
    margin: 0;
    font-style: italic;
    font-size: 0.8rem;
    line-height: 1.4;
    color: #3a2f10;
  }
  .note-since {
    margin: auto 0 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.65rem;
    color: rgba(58, 47, 16, 0.65);
    text-align: right;
  }

  /* Mini postcard */
  .sticker-mini {
    width: 220px;
    min-height: 110px;
    background: #f5ecd9;
    padding: 0.7rem 0.8rem;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 8px 18px rgba(80, 50, 0, 0.3);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    color: #3a2f10;
    border: 1px solid #c8b890;
  }
  .mini-stamp {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    color: #a83b2a;
    border: 1.5px dashed #a83b2a;
    padding: 0.15rem 0.35rem;
    align-self: flex-start;
    transform: rotate(-3deg);
    background: rgba(255, 255, 255, 0.4);
  }
  .mini-divider {
    height: 1px;
    background: rgba(120, 90, 50, 0.3);
  }
  .mini-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .mini-name {
    margin: 0;
    font-family: 'Apple Chancery', 'Brush Script MT', cursive;
    font-size: 1.15rem;
    color: #2a1f08;
    line-height: 1.1;
  }
  .mini-intro {
    margin: 0;
    font-size: 0.75rem;
    color: #5a4a36;
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 640px) {
    .cork-board {
      padding: 1.25rem 0.75rem 1.5rem;
      gap: 1.2rem 1rem;
    }
    .sticker-polaroid {
      width: 150px;
    }
    .sticker-note {
      width: 170px;
    }
    .sticker-mini {
      width: 200px;
    }
  }
</style>
