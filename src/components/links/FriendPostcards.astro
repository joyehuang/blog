---
import { Image } from 'astro:assets'

interface Friend {
  name: string
  intro: string
  link: string
  avatar: string
  since?: string
  met?: string
  note?: string
}

interface FriendList {
  id_name: string
  desc: string
  link_list: Friend[]
}

interface Props {
  list: FriendList
}

const { list } = Astro.props
const friends = [...list.link_list].sort((a, b) => (b.since ?? '').localeCompare(a.since ?? ''))
---

<section class='friend-postcards' aria-label='Friend postcards'>
  <div class='postcard-grid'>
    {friends.map((frd) => (
      <a href={frd.link} target='_blank' rel='noopener noreferrer' class='postcard'>
        <div class='postcard-stamp'>
          <span class='stamp-place'>BLOG</span>
          <span class='stamp-date'>{frd.since}</span>
        </div>
        <div class='postcard-divider' aria-hidden='true'></div>
        <div class='postcard-body'>
          <div class='postcard-avatar'>
            <Image
              src={frd.avatar}
              width={120}
              height={120}
              alt=''
              loading='lazy'
              class='m-0 h-full w-full object-cover'
            />
          </div>
          <div class='postcard-text'>
            <p class='postcard-greeting'>To Joye,</p>
            <p class='postcard-name'>{frd.name}</p>
            <p class='postcard-intro'>{frd.intro}</p>
            {frd.note && <p class='postcard-note'>{frd.note}</p>}
          </div>
        </div>
        <div class='postcard-footer'>
          <span class='postcard-met'>{frd.met}</span>
          <span class='postcard-host'>{new URL(frd.link).host} ↗</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .friend-postcards {
    --postcard-paper: #f6efe1;
    --postcard-paper-dim: #e8dec9;
    --postcard-ink: #3d2f1f;
    --postcard-ink-soft: #6b5a45;
    --postcard-stamp: #b9492c;
  }

  .postcard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .postcard-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
  }

  .postcard {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    text-decoration: none;
    color: var(--postcard-ink);
    background:
      repeating-linear-gradient(0deg, transparent 0 22px, rgba(120, 90, 50, 0.05) 22px 23px),
      linear-gradient(180deg, #f9f3e6 0%, #efe5cf 100%);
    border: 1px solid #d8c9a8;
    border-radius: 0.6rem;
    padding: 0.9rem 1rem 0.85rem;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(120, 80, 30, 0.08);
    position: relative;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease;
    min-height: 200px;
  }
  .postcard::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.4), transparent 40%);
    pointer-events: none;
  }
  .postcard:hover {
    transform: translateY(-3px) rotate(-0.3deg);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 16px 32px rgba(120, 80, 30, 0.18);
  }

  .postcard-stamp {
    position: absolute;
    top: 0.7rem;
    right: 0.85rem;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
    padding: 0.25rem 0.45rem;
    border: 1.5px dashed var(--postcard-stamp);
    color: var(--postcard-stamp);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    transform: rotate(6deg);
    background: rgba(255, 255, 255, 0.4);
  }
  .postcard-stamp .stamp-place {
    font-weight: 700;
  }
  .postcard-stamp .stamp-date {
    font-size: 0.55rem;
  }

  .postcard-divider {
    grid-row: 2;
    width: 1px;
    height: 100%;
    background: rgba(120, 90, 50, 0.25);
    position: absolute;
    top: 1rem;
    bottom: 1rem;
    left: 38%;
    pointer-events: none;
  }

  .postcard-body {
    grid-row: 3;
    display: grid;
    grid-template-columns: 38% 1fr;
    gap: 0.75rem;
    align-items: start;
    padding-top: 0.5rem;
  }

  .postcard-avatar {
    width: 64px;
    height: 64px;
    overflow: hidden;
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .postcard-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .postcard-greeting {
    margin: 0;
    font-family: 'Brush Script MT', cursive;
    font-size: 0.95rem;
    color: var(--postcard-ink-soft);
  }
  .postcard-name {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--postcard-ink);
    line-height: 1.2;
  }
  .postcard-intro {
    margin: 0.15rem 0 0;
    font-size: 0.8rem;
    color: var(--postcard-ink-soft);
    line-height: 1.35;
  }
  .postcard-note {
    margin: 0.4rem 0 0;
    font-size: 0.78rem;
    color: var(--postcard-ink);
    font-style: italic;
    line-height: 1.4;
    padding-left: 0.5rem;
    border-left: 2px solid rgba(120, 90, 50, 0.35);
  }

  .postcard-footer {
    grid-row: 4;
    margin-top: 0.85rem;
    padding-top: 0.55rem;
    border-top: 1px dashed rgba(120, 90, 50, 0.3);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.65rem;
    color: var(--postcard-ink-soft);
  }
  .postcard-host {
    color: var(--postcard-stamp);
  }
</style>
