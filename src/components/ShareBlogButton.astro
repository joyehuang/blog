---
import { cn } from 'astro-pure/utils'

const { class: className, variant = 'default' } = Astro.props

const variants = {
  default: 'rounded-lg border bg-background px-4 py-2 text-sm font-medium hover:bg-muted hover:border-foreground/25',
  icon: 'flex h-10 w-10 items-center justify-center rounded-full border bg-background hover:bg-muted hover:border-foreground/25',
  ghost: 'rounded-lg px-4 py-2 text-sm font-medium hover:bg-muted'
}
---

<button
  id='share-blog-button'
  class={cn(className, variants[variant as keyof typeof variants], 'transition-all')}
  aria-label='Share blog'
  title='Share blog'
>
  <svg
    xmlns='http://www.w3.org/2000/svg'
    width='18'
    height='18'
    viewBox='0 0 24 24'
    fill='none'
    stroke='currentColor'
    stroke-width='2'
    stroke-linecap='round'
    stroke-linejoin='round'
    class='inline-block'
  >
    <circle cx='18' cy='5' r='3'></circle>
    <circle cx='6' cy='12' r='3'></circle>
    <circle cx='18' cy='19' r='3'></circle>
    <line x1='8.59' y1='13.51' x2='15.42' y2='17.49'></line>
    <line x1='15.41' y1='6.51' x2='8.59' y2='10.49'></line>
  </svg>
  {variant === 'default' && <span class='ml-2'>Share</span>}
</button>

<script>
  const button = document.getElementById('share-blog-button')
  button?.addEventListener('click', () => {
    // Call the global function exposed by the modal
    if (typeof (window as any).openShareBlogModal === 'function') {
      ;(window as any).openShareBlogModal()
    }
  })
</script>
