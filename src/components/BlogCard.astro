---
import { cn } from 'astro-pure/utils'
import config from '@/site.config'

const {
  as: Tag = 'a',
  class: className,
  href = '/blog',
  heading = 'Personal Blog',
  subheading = 'Thoughts, notes, and explorations',
  author = config.author,
  description = config.description,
  showSocial = true
} = Astro.props

const socialLinks = config.footer?.social || {}
---

<Tag
  class={cn(
    className,
    'blog-card group overflow-hidden relative flex flex-col gap-y-3 rounded-2xl border bg-muted ',
    'transition-all hover:border-foreground/25 hover:shadow-sm'
  )}
  href={href}
>
  <div class='blog-card-bg absolute inset-0 opacity-60 transition-opacity group-hover:opacity-100 dark:opacity-35'>
    <div class='h-full w-full bg-gradient-to-br from-blue-500/20 via-purple-500/20 to-pink-500/20'></div>
  </div>
  <div class='blog-card-fg z-10 flex flex-col gap-y-2 px-5 pb-4 pt-24 transition-all'>
    <div class='flex flex-col gap-y-0.5'>
      <h2 class='text-lg font-medium'>{heading}</h2>
      <p class='text-muted-foreground text-sm'>{subheading}</p>
    </div>

    <div class='flex flex-col gap-y-1.5 text-sm'>
      <div class='flex items-center gap-x-2 text-muted-foreground'>
        <span class='opacity-70'>By</span>
        <span class='font-medium text-foreground'>{author}</span>
      </div>

      {description && (
        <p class='text-muted-foreground text-xs italic opacity-80'>
          "{description}"
        </p>
      )}

      {showSocial && Object.keys(socialLinks).length > 0 && (
        <div class='mt-1 flex items-center gap-x-2'>
          {socialLinks.github && (
            <a
              href={socialLinks.github}
              target='_blank'
              rel='noopener noreferrer'
              class='text-muted-foreground transition-colors hover:text-foreground'
              aria-label='GitHub'
              onclick='event.stopPropagation()'
            >
              <svg class='h-4 w-4' fill='currentColor' viewBox='0 0 24 24'>
                <path d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z'/>
              </svg>
            </a>
          )}
          {socialLinks.linkedin && (
            <a
              href={socialLinks.linkedin}
              target='_blank'
              rel='noopener noreferrer'
              class='text-muted-foreground transition-colors hover:text-foreground'
              aria-label='LinkedIn'
              onclick='event.stopPropagation()'
            >
              <svg class='h-4 w-4' fill='currentColor' viewBox='0 0 24 24'>
                <path d='M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z'/>
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
  <slot />
</Tag>

<style>
  .blog-card-fg {
    --un-gradient-shape: to bottom in oklch;
    --un-gradient: var(--un-gradient-shape), var(--un-gradient-stops);
    --un-gradient-from-position: 0%;
    --un-gradient-from: transparent var(--un-gradient-from-position);
    --un-gradient-to-position: 65%;
    --un-gradient-to: hsl(var(--primary-foreground) / var(--un-to-opacity, 1))
      var(--un-gradient-to-position);
    --un-gradient-stops: var(--un-gradient-from), var(--un-gradient-to);
    background-image: linear-gradient(var(--un-gradient));
  }

  .blog-card:hover .blog-card-fg {
    --un-gradient-to-position: 80%;
  }
</style>
