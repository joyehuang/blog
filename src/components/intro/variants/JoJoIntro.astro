<section data-intro-variant='jojo' class='intro-variant intro-jojo' aria-hidden='true' hidden>
  <div class='intro-jojo__sheet intro-jojo__sheet--far' data-jojo-paper-layer aria-hidden='true'>
  </div>
  <div class='intro-jojo__sheet intro-jojo__sheet--mid' data-jojo-paper-layer aria-hidden='true'>
  </div>

  <div class='intro-jojo__sheet intro-jojo__paper' data-jojo-paper aria-hidden='true'>
    <div class='intro-jojo__grain'></div>

    <div class='intro-jojo__media'>
      <figure>
        <img data-intro-src='/images/landing/playyy-ui.png' alt='' decoding='async' />
        <figcaption>PLAYYY / PRODUCT</figcaption>
      </figure>
      <figure>
        <img data-intro-src='/images/landing/atypica-site.png' alt='' decoding='async' />
        <figcaption>ATYPICA / AGENTS</figcaption>
      </figure>
      <figure>
        <img data-intro-src='/images/landing/aixcut-site.png' alt='' decoding='async' />
        <figcaption>AIXCUT / VIDEO</figcaption>
      </figure>
    </div>

    <div class='intro-jojo__structure' aria-hidden='true'>
      <span class='intro-jojo__structure-frame'></span>
      <span class='intro-jojo__axis intro-jojo__axis--x'></span>
      <span class='intro-jojo__axis intro-jojo__axis--y'></span>
      <span class='intro-jojo__orbit intro-jojo__orbit--outer'></span>
      <span class='intro-jojo__orbit intro-jojo__orbit--inner'></span>
      <span class='intro-jojo__structure-index intro-jojo__structure-index--start'>00</span>
      <span class='intro-jojo__structure-index intro-jojo__structure-index--end'>01</span>
    </div>

    <div class='intro-jojo__register intro-jojo__register--top'>
      <span>JY / PROJECT REEL</span>
      <span class='intro-jojo__live'><i></i> REAL WORK</span>
      <span>03 / LIVE</span>
    </div>

    <div class='intro-jojo__monogram'>J.</div>

    <div class='intro-jojo__register intro-jojo__register--bottom'>
      <span>PLAYYY</span>
      <span>ATYPICA</span>
      <span>AIXCUT</span>
    </div>

    <i class='intro-jojo__fold intro-jojo__fold--one' data-jojo-fold></i>
    <i class='intro-jojo__fold intro-jojo__fold--two' data-jojo-fold></i>
    <i class='intro-jojo__fold intro-jojo__fold--three' data-jojo-fold></i>

    <div class='intro-jojo__edge'>
      <span class='intro-jojo__tension' data-jojo-tension></span>
    </div>
  </div>

  <div class='intro-jojo__agent' data-jojo-agent aria-hidden='true'>
    <span class='intro-jojo__agent-label' data-jojo-label>JOJO / 01</span>

    <div class='intro-jojo__body'>
      <pre
        class='intro-jojo__ascii'><span data-jojo-part="crown">  .-------.  </span><span data-jojo-part="frame">  |       |  </span><span data-jojo-part="core">  |   -   |  </span><span data-jojo-part="base">  '---+---'  </span><span data-jojo-part="legs" data-jojo-detail>     | |     </span><span data-jojo-part="feet">    /   \    </span></pre>
      <span class='intro-jojo__eyes' data-jojo-eyes>o&nbsp;&nbsp;&nbsp;o</span>
    </div>

    <span class='intro-jojo__arm' data-jojo-arm>
      <i></i>
      <b data-jojo-grip>]</b>
    </span>
  </div>

  <span class='intro-jojo__snap' data-jojo-snap aria-hidden='true'></span>
</section>

<style>
