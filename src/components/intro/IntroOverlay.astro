---
/**
 * IntroOverlay — "joye.log" cinematic entry animation.
 *
 * Strategy:
 * 1. SSR renders a dark overlay shell with:
 *    - a boot line (`> open portfolio`) for the typewriter
 *    - a responsive grid of portfolio cards (work / repo / blog) already in
 *      the DOM, hidden via CSS, revealed as a staggered pop-in wave by the
 *      client script
 * 2. An inline script in <head> runs ASAP to decide whether to play:
 *    - skip if sessionStorage says we've played this session
 *    - skip if prefers-reduced-motion
 *    - otherwise lock the page (`intro-active` class) + scroll to top
 * 3. The client logic (src/scripts/intro.ts) drives the typewriter, the
 *    card-grid pop-in, and the dissolve → page reveal.
 */
import { PORTFOLIO_CARDS, type CardKind } from '@/data/joye-log'
import './intro.css'

const isDev = import.meta.env.DEV

const KIND_LABEL: Record<CardKind, string> = {
  work: 'EXPERIENCE',
  repo: 'OPEN SOURCE',
  blog: 'WRITING'
}

/** Inline SVG glyph for cards without a screenshot (repo / blog). */
function cardGlyph(kind: CardKind): string {
  if (kind === 'repo') {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H10v16H5.5A1.5 1.5 0 0 1 4 18.5z"/><path d="M14 4h4.5A1.5 1.5 0 0 1 20 5.5v13a1.5 1.5 0 0 1-1.5 1.5H14z"/><path d="M10 8h4M10 12h4M10 16h4"/></svg>`
  }
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4.5A1.5 1.5 0 0 1 6.5 3H15l4 4v12.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5z"/><path d="M14 3v5h5"/><path d="M8 13h8M8 16.5h5"/></svg>`
}

const cardCount = PORTFOLIO_CARDS.length
---

<script is:inline>
  ;(function () {
    try {
      var doc = document.documentElement
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      var played = sessionStorage.getItem('intro-played')
      if (reduce || played) {
        doc.classList.add('intro-skip')
      } else {
        doc.classList.add('intro-active')
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual'
        }
        window.scrollTo(0, 0)
        try {
          sessionStorage.setItem('intro-played', '1')
        } catch (e) {}
      }
    } catch (e) {
      document.documentElement.classList.add('intro-skip')
    }
  })()
</script>

<div id='intro-overlay' aria-hidden='true'>
  {/* Atmosphere layers — film grain, CRT scanlines, vignette. */}
  <div class='intro-atmosphere' aria-hidden='true'></div>
  {/* CRT power-on flash — classic tube turn-on, driven by GSAP. */}
  <div id='intro-crt-power' aria-hidden='true'></div>
  {/* Particle shatter layer — filled by the client on handoff. */}
  <div id='intro-particles' aria-hidden='true'></div>

  <div id='intro-log'>
    <div class='intro-boot'>
      <div class='intro-boot-line'>
        <span class='intro-boot-prompt'>&gt;</span>
        <span
          class='intro-boot-text'
          data-typewriter='ssh joye@mind'
        ></span>
      </div>
      <div class='intro-boot-line intro-boot-output'>
        <span
          class='intro-boot-text'
          data-typewriter={`loading portfolio · ${cardCount} cards... ok`}
        ></span>
      </div>
      <div class='intro-boot-line'>
        <span class='intro-boot-prompt'>&gt;</span>
        <span
          class='intro-boot-text'
          data-typewriter='open portfolio'
        ></span><span class='intro-boot-cursor' aria-hidden='true'></span>
      </div>
    </div>

    {/* 3D stage — perspective container; the grid floats inside it with a
        real depth tilt. Cards materialize from deep Z, hold, then shatter
        into particles that streak to the landing sections. */}
    <div id='intro-stage'>
      <div id='intro-grid' style={`--n:${cardCount}`}>
        {PORTFOLIO_CARDS.map((card, i) => (
          <article
            class='intro-card'
            data-kind={card.kind}
            data-weight={card.weight}
            data-index={i}
            data-url={card.url ?? null}
            style={`--i:${i}`}
          >
            <div class='intro-card-media'>
              {card.screenshot ? (
                <img
                  class='intro-card-shot'
                  src={card.screenshot}
                  alt=''
                  loading='eager'
                  draggable='false'
                />
              ) : (
                <div
                  class='intro-card-glyph'
                  aria-hidden='true'
                  set:html={cardGlyph(card.kind)}
                />
              )}
              <div class='intro-card-veil' aria-hidden='true' />
            </div>

            <div class='intro-card-body'>
              <div class='intro-card-top'>
                <span class='intro-card-kind'>{KIND_LABEL[card.kind]}</span>
                {card.meta && <span class='intro-card-meta'>{card.meta}</span>}
              </div>
              <h3 class='intro-card-title'>{card.title}</h3>
              {card.subtitle && (
                <p class='intro-card-subtitle'>{card.subtitle}</p>
              )}
              {card.tag && <span class='intro-card-tag'>{card.tag}</span>}
            </div>

            {/* Holographic overlays — scanlines, sheen, HUD corner brackets. */}
            <div class='intro-card-scanlines' aria-hidden='true' />
            <div class='intro-card-sheen' aria-hidden='true' />
            <span class='intro-card-corner intro-card-corner--tl' aria-hidden='true' />
            <span class='intro-card-corner intro-card-corner--tr' aria-hidden='true' />
            <span class='intro-card-corner intro-card-corner--bl' aria-hidden='true' />
            <span class='intro-card-corner intro-card-corner--br' aria-hidden='true' />
          </article>
        ))}
      </div>
    </div>

    <div class='intro-log-footer'>
      <span class='intro-log-footer-text'>
        {`${cardCount} cards · 4 roles · 2 repos · 12 posts`
          .split('')
          .map((ch, i) => (
            <span class='footer-char' style={`--i:${i}`}>
              {ch === ' ' ? '\u00A0' : ch}
            </span>
          ))}
      </span>
    </div>
  </div>
</div>

<script>
  import '@/scripts/intro.ts'
</script>

{
  isDev && (
    <button id='intro-replay' type='button' aria-label='Replay intro' title='Replay intro'>
      <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
        <path d='M3 12a9 9 0 1 0 3-6.7' />
        <path d='M3 4v5h5' />
      </svg>
    </button>
  )
}

{
  isDev && (
    <script is:inline>
      ;(function () {
        var btn = document.getElementById('intro-replay')
        if (!btn) return
        btn.addEventListener('click', function () {
          try {
            sessionStorage.removeItem('intro-played')
            sessionStorage.removeItem('tour-played')
          } catch (e) {}
          if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual'
          }
          window.scrollTo(0, 0)
          location.reload()
        })
      })()
    </script>
  )
}
