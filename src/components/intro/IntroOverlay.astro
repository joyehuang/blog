---
/**
 * IntroOverlay — "joye.log" cinematic entry animation.
 *
 * Strategy:
 * 1. SSR renders a dark overlay shell with:
 *    - a boot line (`> cat joye.log`) for the typewriter
 *    - all log lines from src/data/joye-log.ts already in the DOM
 *      (hidden via CSS, revealed staggered by the client script)
 *    - each title char is wrapped in a <span> for per-char stagger
 *    - keywords (Agent / LLM / RoPE …) and numbers get accent spans
 * 2. An inline script in <head> runs ASAP to decide whether to play:
 *    - skip if sessionStorage says we've played this session
 *    - skip if prefers-reduced-motion
 *    - otherwise lock the page (`intro-active` class) + scroll to top
 * 3. The client logic (src/scripts/intro.ts) drives the typewriter,
 *    log cascade, coalesce, and reveal via plain DOM + CSS transitions.
 */
import { JOYE_LOG_GROUPS } from '@/data/joye-log'
import './intro.css'

const isDev = import.meta.env.DEV

// Keywords that get an accent span — domain concepts the visitor should
// walk away remembering. Match is case-insensitive on word boundaries.
const KEYWORDS = [
  'Agent',
  'Agents',
  'LLM',
  'Transformer',
  'Transformers',
  'Attention',
  'RoPE',
  'Normalization',
  'RMSNorm',
  'FeedForward',
  'OpenHarness',
  'Interview',
  'Interviews',
  'Mock',
  'Playyy.ai',
  'atypica.ai',
  'AIXCut',
  'fAIshion.ai'
]

const KEYWORD_RE = new RegExp(`\\b(${KEYWORDS.join('|')})\\b`, 'gi')
const NUM_RE = /\b(\d[\d,]*(?:\.\d+)?(?:h\d+m)?|-?\d+)\b/g

function escapeHtml(ch: string): string {
  return ch === '<'
    ? '&lt;'
    : ch === '>'
      ? '&gt;'
      : ch === '&'
        ? '&amp;'
        : ch
}

type Span = { start: number; end: number; kind: 'kw' | 'num' }

/** Tokenize a string into char spans + accent spans for keywords / numbers.
 * Output is an HTML string meant for `set:html`. */
function renderTokenized(text: string): string {
  const spans: Span[] = []
  let m: RegExpExecArray | null

  KEYWORD_RE.lastIndex = 0
  while ((m = KEYWORD_RE.exec(text)) !== null) {
    spans.push({ start: m.index, end: m.index + m[0].length, kind: 'kw' })
  }
  NUM_RE.lastIndex = 0
  while ((m = NUM_RE.exec(text)) !== null) {
    spans.push({ start: m.index, end: m.index + m[0].length, kind: 'num' })
  }
  spans.sort((a, b) => a.start - b.start || b.end - a.end)

  let html = ''
  let i = 0
  let charIdx = 0
  while (i < text.length) {
    const span = spans.find((s) => s.start === i && s.end > s.start)
    if (span) {
      const cls = span.kind === 'kw' ? 'token-kw' : 'token-num'
      // Wrap the whole token in one accent span, but still char-stagger inside
      // so the reveal feels alive.
      const inner = text
        .slice(span.start, span.end)
        .split('')
        .map((ch) => {
          if (ch === ' ') return ' '
          const out = `<span class="char" style="--i:${charIdx}">${escapeHtml(ch)}</span>`
          charIdx++
          return out
        })
        .join('')
      html += `<span class="${cls}">${inner}</span>`
      i = span.end
    } else {
      const ch = text[i]
      if (ch === ' ') {
        html += ' '
      } else {
        html += `<span class="char" style="--i:${charIdx}">${escapeHtml(ch)}</span>`
        charIdx++
      }
      i++
    }
  }
  return html
}
---

<script is:inline>
  ;(function () {
    try {
      var doc = document.documentElement
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      var played = sessionStorage.getItem('intro-played')
      if (reduce || played) {
        doc.classList.add('intro-skip')
      } else {
        doc.classList.add('intro-active')
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual'
        }
        window.scrollTo(0, 0)
        try {
          sessionStorage.setItem('intro-played', '1')
        } catch (e) {}
      }
    } catch (e) {
      document.documentElement.classList.add('intro-skip')
    }
  })()
</script>

<div id='intro-overlay' aria-hidden='true'>
  {/* Atmosphere layers — film grain, chromatic aberration, vignette.
      All pseudo-elements so they don't add DOM weight. */}
  <div class='intro-atmosphere' aria-hidden='true'></div>

  <div id='intro-log'>
    <div class='intro-boot'>
      <span class='intro-boot-prompt'>&gt;</span>
      <span
        class='intro-boot-text'
        data-typewriter='cat joye.log'
      ></span><span class='intro-boot-cursor' aria-hidden='true'></span>
    </div>

    <div id='intro-log-list'>
      {
        JOYE_LOG_GROUPS.map((group) => (
          <div class='intro-log-group' data-type={group.type} data-morph-label={group.label}>
            <div class='intro-log-group-header'>
              <span class='intro-log-group-bracket'>[</span>
              <span class='intro-log-group-label'>{group.label}</span>
              <span class='intro-log-group-bracket'>]</span>
              <span class='intro-log-group-count'>{group.entries.length}</span>
            </div>
            {group.entries.map((entry) => (
              <div
                class='intro-log-line'
                data-type={entry.type}
                data-weight={entry.weight ?? 1}
              >
                <span class='intro-log-stamp'>
                  {entry.stamp.split('').map((ch, i) => (
                    <span class='stamp-char' style={`--i:${i}`}>
                      {ch === ' ' ? '\u00A0' : ch}
                    </span>
                  ))}
                </span>
                <span class='intro-log-sep' aria-hidden='true'>
                  ┄┄┄
                </span>
                <span class='intro-log-title' set:html={renderTokenized(entry.title)} />
                {entry.tag && (
                  <span
                    class='intro-log-meta'
                    set:html={renderTokenized(entry.tag)}
                  />
                )}
              </div>
            ))}
          </div>
        ))
      }
    </div>

    <div class='intro-log-footer'>
      <span class='intro-log-footer-text'>
        {'18 entries · 12 posts · 2 repos · 4 roles'
          .split('')
          .map((ch, i) => (
            <span class='footer-char' style={`--i:${i}`}>
              {ch === ' ' ? '\u00A0' : ch}
            </span>
          ))}
      </span>
    </div>
  </div>

  {/* Experience showcase — full-viewport terminal "company tour".
      Hidden by default, made visible by the client between the Experience
      cascade and the morph. Each panel is one company. */}
  <div id='intro-showcase' aria-hidden='true'>
    <div class='showcase-frame'>
      <div class='showcase-titlebar'>
        <span class='showcase-traffic'>
          <i></i><i></i><i></i>
        </span>
        <span class='showcase-title'>joye@experience — zsh</span>
        <span class='showcase-counter'>
          <span class='showcase-counter-current'>01</span>
          <span class='showcase-counter-sep'>/</span>
          <span class='showcase-counter-total'>04</span>
        </span>
      </div>
      <div class='showcase-stage'>
        {
          JOYE_LOG_GROUPS.map((group) =>
            group.type === 'work'
              ? group.entries
                  .filter((e) => e.screenshot)
                  .map((entry, i) => (
                    <div
                      class='showcase-panel'
                      data-panel-index={i}
                      data-total={group.entries.filter((e) => e.screenshot).length}
                    >
                      <img
                        class='showcase-screenshot'
                        src={entry.screenshot}
                        alt=''
                        loading='eager'
                      />
                      <div class='showcase-overlay' aria-hidden='true' />
                      <div class='showcase-caption'>
                        <span class='showcase-caption-prompt'>&gt;</span>
                        <span class='showcase-caption-title'>{entry.title}</span>
                        <span class='showcase-caption-desc'>
                          {entry.description}
                        </span>
                      </div>
                    </div>
                  ))
              : null
          )
        }
      </div>
    </div>
  </div>
</div>

<script>
  import '@/scripts/intro.ts'
</script>

{
  isDev && (
    <button id='intro-replay' type='button' aria-label='Replay intro' title='Replay intro'>
      <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
        <path d='M3 12a9 9 0 1 0 3-6.7' />
        <path d='M3 4v5h5' />
      </svg>
    </button>
  )
}

{
  isDev && (
    <script is:inline>
      ;(function () {
        var btn = document.getElementById('intro-replay')
        if (!btn) return
        btn.addEventListener('click', function () {
          try {
            sessionStorage.removeItem('intro-played')
            sessionStorage.removeItem('tour-played')
          } catch (e) {}
          if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual'
          }
          window.scrollTo(0, 0)
          location.reload()
        })
      })()
    </script>
  )
}

