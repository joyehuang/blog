---
interface Props {
  src: string
  alt: string
  caption?: string
  href?: string
  label?: string
  analyticsEpisode?: number
  analyticsResource?: 'deck' | 'slide'
}

const { alt, analyticsEpisode, analyticsResource = 'slide', caption, href, label, src } = Astro.props
---

<figure class='talk-slide-figure not-prose'>
  {
    href ? (
      <a
        class='talk-slide-frame'
        href={href}
        target='_blank'
        rel='noopener'
        aria-label={caption ?? alt}
        data-analytics-event='talk_resource_click'
        data-analytics-surface='article_slide'
        data-analytics-episode={analyticsEpisode}
        data-analytics-resource={analyticsResource}
      >
        <img src={src} alt={alt} loading='lazy' />
      </a>
    ) : (
      <div class='talk-slide-frame'>
        <img src={src} alt={alt} loading='lazy' />
      </div>
    )
  }
  {
    (label || caption) && (
      <figcaption>
        {label && <span class='talk-slide-label'>{label}</span>}
        {caption && <span>{caption}</span>}
      </figcaption>
    )
  }
</figure>

<style>
  .talk-slide-figure {
    position: relative;
    isolation: isolate;
    margin: 1.4rem 0 1.8rem;
  }

  .talk-slide-figure::before {
    content: '';
    position: absolute;
    inset: 8% -2% -8%;
    z-index: 0;
    border-radius: 999px;
    background:
      radial-gradient(ellipse at 50% 55%, hsl(var(--primary) / 0.2), transparent 58%),
      radial-gradient(ellipse at 36% 72%, hsl(var(--foreground) / 0.14), transparent 62%);
    filter: blur(48px);
    opacity: 0.82;
    pointer-events: none;
    transform: translateY(12px);
  }

  .talk-slide-frame {
    position: relative;
    z-index: 1;
    display: block;
    overflow: hidden;
    border: 1px solid hsl(var(--border) / 0.88);
    border-radius: 10px;
    background:
      linear-gradient(135deg, hsl(var(--foreground) / 0.045), transparent 30%),
      hsl(var(--background) / 0.82);
    padding: 5px;
    box-shadow:
      inset 0 1px 0 hsl(var(--foreground) / 0.06),
      0 0 0 1px hsl(var(--primary) / 0.05);
  }

  a.talk-slide-frame {
    text-decoration: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  a.talk-slide-frame:hover {
    border-color: hsl(var(--primary) / 0.38);
    box-shadow:
      inset 0 1px 0 hsl(var(--foreground) / 0.08),
      0 0 0 1px hsl(var(--primary) / 0.12);
  }

  .talk-slide-figure img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid hsl(var(--border));
    border-radius: 7px;
    background: hsl(var(--muted));
  }

  .talk-slide-figure figcaption {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.15rem 0.35rem;
    margin-top: 0.55rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.86rem;
    line-height: 1.55;
    text-align: center;
  }

  .talk-slide-label {
    color: hsl(var(--primary));
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 700;
  }

  .talk-slide-label::after {
    content: '：';
  }
</style>
