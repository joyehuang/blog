---
interface Props {
  class?: string
  label?: string
  prefix?: string
  suffix?: string
}

const { class: className, label = '微信号', prefix = 'joye', suffix = '050604' } = Astro.props
---

<span
  class:list={['wechat-reveal', className]}
  tabindex='0'
  data-a={prefix}
  data-b={suffix}
  data-analytics-reveal-event='article_contact_reveal'
  data-analytics-surface='article_inline'
  data-analytics-method-name='wechat'
  data-analytics-action='reveal'
  aria-label={`${label}，悬停或聚焦显示`}></span>

<style>
  .wechat-reveal {
    position: relative;
    display: inline-grid;
    place-items: center;
    min-width: 6.8em;
    min-height: 1.45em;
    margin-inline: 0.1em;
    padding: 0.02em 0.5em;
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    background: hsl(var(--muted) / 0.22);
    color: hsl(var(--muted-foreground));
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.92em;
    line-height: 1;
    vertical-align: 0.05em;
    cursor: pointer;
    user-select: none;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .wechat-reveal::before {
    content: '微信号';
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .wechat-reveal:hover,
  .wechat-reveal:focus {
    color: hsl(var(--foreground));
    border-color: hsl(var(--primary) / 0.45);
    background: hsl(var(--muted) / 0.5);
    outline: 2px solid hsl(var(--primary) / 0.22);
    outline-offset: 2px;
  }

  .wechat-reveal:hover::before,
  .wechat-reveal:focus::before {
    content: attr(data-a) attr(data-b);
  }
</style>
