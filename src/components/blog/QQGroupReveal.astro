---
const groupNumber = '831907794'
---

<span
  class="qq-group-reveal"
  tabindex="0"
  data-number={groupNumber}
  data-analytics-reveal-event="article_contact_reveal"
  data-analytics-surface="article_inline"
  data-analytics-method-name="qq_group"
  data-analytics-action="reveal"
  aria-label={`QQ 群 ${groupNumber}，悬停或聚焦显示群号`}
></span>

<style>
  .qq-group-reveal {
    position: relative;
    display: inline-grid;
    place-items: center;
    min-width: 7.5em;
    min-height: 1.45em;
    margin-inline: 0.1em;
    padding: 0.02em 0.5em;
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    background: hsl(var(--muted) / 0.22);
    color: hsl(var(--muted-foreground));
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.92em;
    line-height: 1;
    vertical-align: 0.05em;
    cursor: pointer;
    user-select: none;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .qq-group-reveal::before {
    content: 'QQ 群';
  }

  .qq-group-reveal:hover,
  .qq-group-reveal:focus {
    color: hsl(var(--foreground));
    border-color: hsl(var(--primary) / 0.45);
    background: hsl(var(--muted) / 0.5);
    outline: 2px solid hsl(var(--primary) / 0.22);
    outline-offset: 2px;
  }

  .qq-group-reveal:hover::before,
  .qq-group-reveal:focus::before {
    content: attr(data-number);
  }
</style>
